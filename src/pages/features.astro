---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Partners from "../components/sections/Partners.astro";
import FeatureMatrix from "../components/sections/FeatureMatrix.astro";
import { strings, t, localeFromPath, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = localeFromPath(Astro.url.pathname) } = Astro.props;
const fp = strings.features_page;
const prefix = locale === "fr" ? "/fr" : "";
const demoHref = `${prefix}/demo`;
const signupHref = "https://www.vomevolunteer.com/register";

// One shared module catalog feeding both the platform diagram (above)
// and the "Explore by module" cards (below). Order is clockwise from 12
// o'clock for the diagram; CSS positions each node via --angle (sin/cos).
//
// - `iconSvg`: 24x24 line-icon path string (stroke-based, currentColor).
//   The same SVG is used in BOTH views so the diagram and the cards stay
//   visually in sync — change once, both render the new icon.
// - `nodeTitle` / `nodeDesc`: short labels for the diagram (1 line each).
// - `cardTitle` / `cardDesc` / `cardFeatures` / `cardLink`: longer copy
//   for the module card. Bullet content draws from the comparison table
//   (strings.plans.*) and React landing pages
//   (vome-react/src/views/landingPage/feature{Onboarding,Hours,…}/).
// - `href`: marketing route. Mirrors the React app
//   (vome-react/src/routers/AppRouter.js).
const modules = [
  {
    href: `${prefix}/volunteer-application-forms`,
    iconSvg: '<circle cx="9" cy="8" r="3.5"/><path d="M3 20a6 6 0 0 1 12 0"/><line x1="18.5" y1="8" x2="18.5" y2="14"/><line x1="15.5" y1="11" x2="21.5" y2="11"/>',
    nodeTitle: t(fp.node_recruitment_title, locale),
    nodeDesc: t(fp.node_recruitment_desc, locale),
    cardTitle: t(fp.card_recruitment_title, locale),
    cardDesc: t(fp.card_recruitment_desc, locale),
    cardFeatures: [
      t(fp.card_recruitment_f1, locale),
      t(fp.card_recruitment_f2, locale),
      t(fp.card_recruitment_f3, locale),
      t(fp.card_recruitment_f4, locale),
    ],
    cardLink: t(fp.card_recruitment_link, locale),
  },
  {
    href: `${prefix}/volunteer-onboarding-software`,
    iconSvg: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/>',
    nodeTitle: t(fp.node_onboarding_title, locale),
    nodeDesc: t(fp.node_onboarding_desc, locale),
    cardTitle: t(fp.card_onboarding_title, locale),
    cardDesc: t(fp.card_onboarding_desc, locale),
    cardFeatures: [
      t(fp.card_onboarding_f1, locale),
      t(fp.card_onboarding_f2, locale),
      t(fp.card_onboarding_f3, locale),
      t(fp.card_onboarding_f4, locale),
    ],
    cardLink: t(fp.card_onboarding_link, locale),
  },
  {
    href: `${prefix}/volunteer-scheduling-software`,
    iconSvg: '<rect x="3" y="5" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="3" x2="8" y2="7"/><line x1="16" y1="3" x2="16" y2="7"/>',
    nodeTitle: t(fp.node_scheduling_title, locale),
    nodeDesc: t(fp.node_scheduling_desc, locale),
    cardTitle: t(fp.card_scheduling_title, locale),
    cardDesc: t(fp.card_scheduling_desc, locale),
    cardFeatures: [
      t(fp.card_scheduling_f1, locale),
      t(fp.card_scheduling_f2, locale),
      t(fp.card_scheduling_f3, locale),
      t(fp.card_scheduling_f4, locale),
    ],
    cardLink: t(fp.card_scheduling_link, locale),
  },
  {
    href: `${prefix}/volunteer-hour-tracking`,
    iconSvg: '<circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/>',
    nodeTitle: t(fp.node_hours_title, locale),
    nodeDesc: t(fp.node_hours_desc, locale),
    cardTitle: t(fp.card_hours_title, locale),
    cardDesc: t(fp.card_hours_desc, locale),
    cardFeatures: [
      t(fp.card_hours_f1, locale),
      t(fp.card_hours_f2, locale),
      t(fp.card_hours_f3, locale),
      t(fp.card_hours_f4, locale),
    ],
    cardLink: t(fp.card_hours_link, locale),
  },
  {
    // Recognition has no dedicated React landing page yet; the deep-dive
    // anchor lands on the plans page recognition section.
    href: `${prefix}/plans#recognition`,
    iconSvg: '<circle cx="12" cy="9" r="5"/><path d="M9 13l-1 8 4-2 4 2-1-8"/>',
    nodeTitle: t(fp.node_recognition_title, locale),
    nodeDesc: t(fp.node_recognition_desc, locale),
    cardTitle: t(fp.card_recognition_title, locale),
    cardDesc: t(fp.card_recognition_desc, locale),
    cardFeatures: [
      t(fp.card_recognition_f1, locale),
      t(fp.card_recognition_f2, locale),
      t(fp.card_recognition_f3, locale),
      t(fp.card_recognition_f4, locale),
    ],
    cardLink: t(fp.card_recognition_link, locale),
  },
  {
    href: `${prefix}/volunteer-communications`,
    iconSvg: '<path d="M21 12c0 4-4 7-9 7-1.4 0-2.7-.2-3.9-.7L3 20l1.5-3.7C3.6 15 3 13.6 3 12c0-4 4-7 9-7s9 3 9 7z"/>',
    nodeTitle: t(fp.node_comms_title, locale),
    nodeDesc: t(fp.node_comms_desc, locale),
    cardTitle: t(fp.card_comms_title, locale),
    cardDesc: t(fp.card_comms_desc, locale),
    cardFeatures: [
      t(fp.card_comms_f1, locale),
      t(fp.card_comms_f2, locale),
      t(fp.card_comms_f3, locale),
      t(fp.card_comms_f4, locale),
    ],
    cardLink: t(fp.card_comms_link, locale),
  },
  {
    href: `${prefix}/volunteer-database`,
    iconSvg: '<line x1="3" y1="20" x2="21" y2="20"/><rect x="5" y="13" width="3" height="7" rx="0.5"/><rect x="10.5" y="8" width="3" height="12" rx="0.5"/><rect x="16" y="15" width="3" height="5" rx="0.5"/>',
    nodeTitle: t(fp.node_data_title, locale),
    nodeDesc: t(fp.node_data_desc, locale),
    cardTitle: t(fp.card_data_title, locale),
    cardDesc: t(fp.card_data_desc, locale),
    cardFeatures: [
      t(fp.card_data_f1, locale),
      t(fp.card_data_f2, locale),
      t(fp.card_data_f3, locale),
      t(fp.card_data_f4, locale),
    ],
    cardLink: t(fp.card_data_link, locale),
  },
  {
    href: `${prefix}/app-for-volunteers`,
    iconSvg: '<rect x="7" y="3" width="10" height="18" rx="2"/><line x1="11" y1="18" x2="13" y2="18"/>',
    nodeTitle: t(fp.node_app_title, locale),
    nodeDesc: t(fp.node_app_desc, locale),
    cardTitle: t(fp.card_app_title, locale),
    cardDesc: t(fp.card_app_desc, locale),
    cardFeatures: [
      t(fp.card_app_f1, locale),
      t(fp.card_app_f2, locale),
      t(fp.card_app_f3, locale),
      t(fp.card_app_f4, locale),
    ],
    cardLink: t(fp.card_app_link, locale),
  },
];
---

<Layout
  locale={locale}
  title={t(fp.page_title, locale)}
  description={t(fp.page_description, locale)}
>
  <!-- ── Hero ── -->
  <section class="fp-hero">
    <div class="fp-hero__inner">
      <div class="fp-hero__eyebrow">{t(fp.hero_eyebrow, locale)}</div>
      <h1 class="fp-hero__h1">
        {t(fp.hero_h1_part1, locale)}<span class="accent">{t(fp.hero_h1_accent, locale)}</span>{t(fp.hero_h1_part2, locale)}
      </h1>
      <p class="fp-hero__sub" set:html={`${t(fp.hero_sub_l1, locale)} ${t(fp.hero_sub_l2, locale)} ${t(fp.hero_sub_l3, locale)}`} />
      <div class="fp-hero__ctas">
        <Button href={signupHref} variant="primary" class="btn--hero">
          {t(strings.nav.signup_free, locale)}
        </Button>
        <Button href={demoHref} variant="ghost" class="btn--hero">
          {t(strings.nav.book_demo, locale)}
        </Button>
      </div>
      <div class="fp-hero__meta">
        <span><span class="check">✓</span>{t(fp.hero_meta_unlimited, locale)}</span>
        <span><span class="check">✓</span>{t(fp.hero_meta_apps, locale)}</span>
        <span><span class="check">✓</span>{t(fp.hero_meta_trial, locale)}</span>
      </div>

      <!-- Platform visualization — square container, two concentric rings,
           7 module nodes laid out evenly on the outer ring (center sits ON
           the ring line, "necklace" style). Nodes are absolutely-positioned
           HTML anchors so the text is real, focusable, and links work; the
           SVG only paints the rings. CSS positions each node via sin/cos
           on a --angle CSS variable, so the geometry is exact. -->
      <div class="fp-platform" aria-label="Vome platform overview">
        <svg
          class="fp-platform__svg"
          viewBox="0 0 1000 1000"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <!-- Outer ring: passes through the node centers (r matches the
               nodes' --r in CSS, 40% of 1000 = 400). -->
          <circle cx="500" cy="500" r="400" stroke="rgba(250,147,91,0.18)" stroke-width="1.5" fill="none" />
          <!-- Inner ring: subtle dashed circle around the center logo. -->
          <circle cx="500" cy="500" r="280" stroke="rgba(250,147,91,0.10)" stroke-width="1" fill="none" stroke-dasharray="6 6" />
        </svg>

        <!-- Center: Vome logo -->
        <div class="fp-platform__center">
          <img class="fp-platform__logo" src="/logos/app-logo-orange.png" alt="Vome" />
        </div>

        <!-- Module nodes — clockwise from 12 o'clock; CSS places each node
             on the outer ring using --angle. -->
        {modules.map((m, i) => (
          <a href={m.href} class={`fp-platform__node fp-platform__node--${i + 1}`}>
            <div class="fp-platform__node-circle">
              <svg
                class="fp-platform__node-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={m.iconSvg}
              />
            </div>
            <div class="fp-platform__node-title">{m.nodeTitle}</div>
            <div class="fp-platform__node-desc">{m.nodeDesc}</div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- Partners marquee — same component as the homepage. Lives as its
       own white section, not inside the surface-1 hero, so the marquee
       doesn't read as a floating card on top of the hero background.
       Page rhythm: hero → partners → modules → CTA → feature matrix. -->
  <Partners locale={locale} />

  <!-- ── Explore by module — eight deep-dive cards ── -->
  <section class="fp-modules">
    <div class="fp-modules__inner">
      <div class="fp-modules__intro">
        <h2 class="fp-modules__h2">{t(fp.modules_h2, locale)}</h2>
        <p class="fp-modules__sub">{t(fp.modules_sub, locale)}</p>
      </div>
      <div class="fp-modules__grid">
        {modules.map((m) => (
          <a href={m.href} class="fp-mcard">
            <div class="fp-mcard__icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={m.iconSvg}
              />
            </div>
            <h3 class="fp-mcard__title">{m.cardTitle}</h3>
            <p class="fp-mcard__desc">{m.cardDesc}</p>
            <ul class="fp-mcard__features">
              {m.cardFeatures.map((f) => (<li>{f}</li>))}
            </ul>
            <span class="fp-mcard__link">{m.cardLink}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── See it in action — primary CTA between cards and matrix ── -->
  <section class="fp-cta">
    <div class="fp-cta__inner">
      <h2 class="fp-cta__h2">{t(fp.cta_h2, locale)}</h2>
      <p class="fp-cta__sub">{t(fp.cta_sub, locale)}</p>
      <div class="fp-cta__buttons">
        <Button href={signupHref} variant="primary" class="btn--hero">
          {t(strings.nav.signup_free, locale)}
        </Button>
        <Button href={demoHref} variant="ghost" class="btn--hero">
          {t(strings.nav.book_demo, locale)}
        </Button>
      </div>
    </div>
  </section>

  <!-- ── Full feature matrix — same comparison table as /plans ── -->
  <FeatureMatrix locale={locale} />
</Layout>
