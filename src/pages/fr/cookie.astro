---
/**
 * Cookie Policy route at /fr/cookie.
 *
 * Renders the English policy body because an authoritative French
 * translation does not exist yet — the vome-react source file `CookieFR.js`
 * is an empty 0-byte file and the React app also falls back to English for
 * the FR locale. When a proper FR translation is produced, create a
 * components/content/CookieBodyFr.astro and swap the import below.
 */
import Layout from "../../layouts/Layout.astro";
import CookieBody from "../../components/content/CookieBody.astro";
---

<Layout
  locale="fr"
  title="Cookie Policy | Vome Volunteer"
  description="How Vome uses cookies on vomevolunteer.com — functionality, analytical and social media cookies, and your options for managing them."
>
  <CookieBody />
</Layout>
