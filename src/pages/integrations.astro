---
/**
 * Module landing page — Integrations & API.
 *
 * Two structural deviations from the canonical module template
 * (see `docs/landing-playbook.md`):
 *   1. The `<HowItWorks>` 4-step stepper is replaced by an
 *      `<IntegrationLogoGrid>` showing every shipped integration
 *      grouped by category. The build → publish → automate flow
 *      doesn't fit an integrations page; the page is stronger when
 *      it puts every partner mark on screen at once.
 *   2. Spotlights focus on three angles (native, no-code, code)
 *      rather than three module mechanisms.
 *
 * Mockups (all hand-built HTML/CSS, no `<img>`):
 *   Hero        IntegrationsHubMock       (Vome at center, partner spokes)
 *   Spotlight 1 NativeIntegrationsMock    (5 native cards stacked)
 *   Spotlight 2 AutomationChainMock       (Zapier-style multi-step chain)
 *   Spotlight 3 ApiWebhookMock            (code-style payload + response)
 */
import Layout from "../layouts/Layout.astro";
import Partners from "../components/sections/Partners.astro";
import Faq from "../components/sections/Faq.astro";
import FeatureMatrix from "../components/sections/FeatureMatrix.astro";
import ClosingCta from "../components/sections/ClosingCta.astro";
import ModuleHero from "../components/module/ModuleHero.astro";
import BenefitGrid from "../components/module/BenefitGrid.astro";
import FeatureSpotlight from "../components/module/FeatureSpotlight.astro";
import IntegrationLogoGrid from "../components/module/IntegrationLogoGrid.astro";
import Differentiators from "../components/module/Differentiators.astro";
import IntegrationsHubMock from "../components/module/IntegrationsHubMock.astro";
import NativeIntegrationsMock from "../components/module/NativeIntegrationsMock.astro";
import AutomationChainMock from "../components/module/AutomationChainMock.astro";
import ApiWebhookMock from "../components/module/ApiWebhookMock.astro";
import { strings, t, localeFromPath, type Locale } from "../i18n";
import { appUrl } from "../lib/appUrl";

interface Props {
  locale?: Locale;
}

const { locale = localeFromPath(Astro.url.pathname) } = Astro.props;
const r = strings.module_integrations;
const prefix = locale === "fr" ? "/fr" : "";
const demoHref = `${prefix}/demo`;
const signupHref = appUrl("/register");

// ── Hero meta pills ──
const heroMeta = [
  { text: t(r.hero_meta_native, locale) },
  { text: t(r.hero_meta_nocode, locale) },
  { text: t(r.hero_meta_dev, locale) },
];

// ── Benefits grid (6 cards). Icons match the platform-diagram line style. ──
const benefits = [
  {
    // Cloud + arrows / sync
    iconSvg: '<path d="M7 18a5 5 0 0 1-1-9.9A6 6 0 0 1 17 7a4.5 4.5 0 0 1 1 8.9"/><path d="M12 13v8"/><path d="M9 18l3 3 3-3"/>',
    title: t(r.ben1_title, locale),
    desc: t(r.ben1_desc, locale),
  },
  {
    // Shield / check (background check)
    iconSvg: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/>',
    title: t(r.ben2_title, locale),
    desc: t(r.ben2_desc, locale),
  },
  {
    // Graduation cap / training
    iconSvg: '<path d="M2 9l10-5 10 5-10 5L2 9z"/><path d="M6 11v5c2 2 8 2 12 0v-5"/><path d="M22 9v5"/>',
    title: t(r.ben3_title, locale),
    desc: t(r.ben3_desc, locale),
  },
  {
    // Dollar sign in circle (matching gifts)
    iconSvg: '<circle cx="12" cy="12" r="9"/><path d="M14.5 9.5a3 3 0 0 0-2.5-1.5c-1.7 0-3 1-3 2.3 0 3 5.5 1.5 5.5 4.4 0 1.4-1.3 2.3-3 2.3a3 3 0 0 1-2.5-1.5"/><path d="M12 6v2M12 16v2"/>',
    title: t(r.ben4_title, locale),
    desc: t(r.ben4_desc, locale),
  },
  {
    // Envelope / mail
    iconSvg: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 7 9-7"/>',
    title: t(r.ben5_title, locale),
    desc: t(r.ben5_desc, locale),
  },
  {
    // Key / SSO
    iconSvg: '<circle cx="8" cy="15" r="4"/><path d="M11 12l9-9"/><path d="M17 6l3 3"/><path d="M14 9l3 3"/>',
    title: t(r.ben6_title, locale),
    desc: t(r.ben6_desc, locale),
  },
];

// ── Spotlight bullets ──
const spot1Bullets = [t(r.spot1_b1, locale), t(r.spot1_b2, locale), t(r.spot1_b3, locale), t(r.spot1_b4, locale)];
const spot2Bullets = [t(r.spot2_b1, locale), t(r.spot2_b2, locale), t(r.spot2_b3, locale), t(r.spot2_b4, locale)];
const spot3Bullets = [t(r.spot3_b1, locale), t(r.spot3_b2, locale), t(r.spot3_b3, locale), t(r.spot3_b4, locale)];

// ── Logo grid groups (4 categories). Brand keys map to .mp-logo__mark--<brand> CSS. ──
const logoGroups = [
  {
    title: t(r.logos_cat_native, locale),
    items: [
      { brand: "sf",       name: t(r.logo_sf, locale),       sub: t(r.logo_sf_sub, locale) },
      { brand: "sterling", name: t(r.logo_sterling, locale), sub: t(r.logo_sterling_sub, locale) },
      { brand: "scorm",    name: t(r.logo_scorm, locale),    sub: t(r.logo_scorm_sub, locale) },
      { brand: "dtd",      name: t(r.logo_dtd, locale),      sub: t(r.logo_dtd_sub, locale) },
      { brand: "sheets",   name: t(r.logo_sheets, locale),   sub: t(r.logo_sheets_sub, locale) },
    ],
  },
  {
    title: t(r.logos_cat_email, locale),
    items: [
      { brand: "google",  name: t(r.logo_google_mail, locale), sub: t(r.logo_google_mail_sub, locale) },
      { brand: "ms",      name: t(r.logo_outlook, locale),     sub: t(r.logo_outlook_sub, locale) },
      { brand: "entra",   name: t(r.logo_entra, locale),       sub: t(r.logo_entra_sub, locale) },
      { brand: "jc",      name: t(r.logo_jumpcloud, locale),   sub: t(r.logo_jumpcloud_sub, locale) },
    ],
  },
  {
    title: t(r.logos_cat_auto, locale),
    items: [
      { brand: "zap",     name: t(r.logo_zapier, locale),  sub: t(r.logo_zapier_sub, locale) },
      { brand: "power",   name: t(r.logo_power, locale),   sub: t(r.logo_power_sub, locale) },
    ],
  },
  {
    title: t(r.logos_cat_dev, locale),
    items: [
      { brand: "api",      name: t(r.logo_api, locale),       sub: t(r.logo_api_sub, locale) },
      { brand: "webhooks", name: t(r.logo_webhooks, locale),  sub: t(r.logo_webhooks_sub, locale) },
      { brand: "devdash",  name: t(r.logo_devdash, locale),   sub: t(r.logo_devdash_sub, locale) },
    ],
  },
];

// ── Differentiators (3) ──
const differentiators = [
  {
    // Plug / native
    iconSvg: '<path d="M9 4v4M15 4v4M7 8h10v4a5 5 0 0 1-10 0z"/><path d="M12 17v4"/>',
    title: t(r.diff1_title, locale),
    desc: t(r.diff1_desc, locale),
  },
  {
    // Branching / fork (no-code AND code)
    iconSvg: '<circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="20" r="2"/><path d="M6 8v3a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V8"/><path d="M12 14v4"/>',
    title: t(r.diff2_title, locale),
    desc: t(r.diff2_desc, locale),
  },
  {
    // Lock / shield with key (auth)
    iconSvg: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/><circle cx="12" cy="16" r="1.25"/>',
    title: t(r.diff3_title, locale),
    desc: t(r.diff3_desc, locale),
  },
];

// ── Module FAQs (6) ──
const faqItems = [
  { q: r.faq1_q, a: r.faq1_a, open: true },
  { q: r.faq2_q, a: r.faq2_a },
  { q: r.faq3_q, a: r.faq3_a },
  { q: r.faq4_q, a: r.faq4_a },
  { q: r.faq5_q, a: r.faq5_a },
  { q: r.faq6_q, a: r.faq6_a },
];
---

<Layout
  locale={locale}
  title={t(r.page_title, locale)}
  description={t(r.page_description, locale)}
>
  <ModuleHero
    locale={locale}
    eyebrow={t(r.hero_eyebrow, locale)}
    h1Part1={t(r.hero_h1_part1, locale)}
    h1Accent={t(r.hero_h1_accent, locale)}
    h1Part2={t(r.hero_h1_part2, locale)}
    sub={t(r.hero_sub, locale)}
    ctaPrimaryHref={signupHref}
    ctaPrimaryLabel={t(strings.nav.signup_free, locale)}
    ctaSecondaryHref={demoHref}
    ctaSecondaryLabel={t(strings.nav.book_demo, locale)}
    meta={heroMeta}
  >
    <IntegrationsHubMock slot="mockup" locale={locale} />
  </ModuleHero>

  <Partners locale={locale} />

  <BenefitGrid
    locale={locale}
    h2={t(r.benefits_h2, locale)}
    sub={t(r.benefits_sub, locale)}
    items={benefits}
  />

  <FeatureSpotlight
    locale={locale}
    kicker={t(r.spot1_kicker, locale)}
    title={t(r.spot1_title, locale)}
    body={t(r.spot1_body, locale)}
    bullets={spot1Bullets}
    side="right"
  >
    <NativeIntegrationsMock slot="mockup" locale={locale} />
  </FeatureSpotlight>

  <FeatureSpotlight
    locale={locale}
    kicker={t(r.spot2_kicker, locale)}
    title={t(r.spot2_title, locale)}
    body={t(r.spot2_body, locale)}
    bullets={spot2Bullets}
    side="left"
  >
    <AutomationChainMock slot="mockup" locale={locale} />
  </FeatureSpotlight>

  <FeatureSpotlight
    locale={locale}
    kicker={t(r.spot3_kicker, locale)}
    title={t(r.spot3_title, locale)}
    body={t(r.spot3_body, locale)}
    bullets={spot3Bullets}
    side="right"
  >
    <ApiWebhookMock slot="mockup" locale={locale} />
  </FeatureSpotlight>

  <IntegrationLogoGrid
    locale={locale}
    h2={t(r.logos_h2, locale)}
    sub={t(r.logos_sub, locale)}
    groups={logoGroups}
  />

  <Differentiators
    locale={locale}
    h2={t(r.diff_h2, locale)}
    sub={t(r.diff_sub, locale)}
    items={differentiators}
  />

  <Faq
    locale={locale}
    items={faqItems}
    heading={r.faq_h2}
    sub={r.faq_sub}
    ctaText={r.faq_cta_text}
    ctaLink={r.faq_cta_link}
  />

  <FeatureMatrix
    locale={locale}
    onlySection="advanced"
    heading={r.matrix_h2}
    showAllToggle
  />

  <ClosingCta locale={locale} />
</Layout>
