---
import Layout from "../layouts/Layout.astro";
import HeroMockupFull from "../components/sections/HeroMockupFull.astro";
import Button from "../components/Button.astro";
import Partners from "../components/sections/Partners.astro";
import FeatureTabs from "../components/sections/FeatureTabs.astro";
import MobileApp from "../components/sections/MobileApp.astro";
import Enterprise from "../components/sections/Enterprise.astro";
import Security from "../components/sections/Security.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import ClosingCta from "../components/sections/ClosingCta.astro";
import Faq from "../components/sections/Faq.astro";
---

<Layout
  title="Vome — Volunteer management software your team will actually use"
  description="Vome automates the manual work behind recruitment, onboarding, scheduling, hour tracking, reporting, and communication. Unlimited volunteers on every plan."
>
  <section class="hero hero--centered">
    <div class="hero__copy hero__copy--centered">
      <div class="hero__eyebrow">4.6 ★ on Capterra, GetApp &amp; G2</div>

      <h1 class="hero__h1">
        The volunteer management software<br class="h1-break" />your volunteers and staff <span class="accent">actually want to use</span>
      </h1>

      <p class="hero__sub">
        From a single coordinator to teams running programs across multiple sites, <strong>Vome automates the manual work</strong> behind onboarding, scheduling, and communication. All in one platform, with unlimited volunteers on every plan.
      </p>

      <div class="hero__ctas">
        <Button href="https://www.vomevolunteer.com/register" variant="primary" class="btn--hero">Sign up for Free</Button>
        <Button href="/demo" variant="ghost" class="btn--hero">Book a demo</Button>
      </div>

      <div class="hero__meta hero__meta--centered">
        <span><span class="check">✓</span>Free plan + 30-day trials on paid</span>
        <span><span class="check">✓</span>Set up in minutes</span>
        <span><span class="check">✓</span>HIPAA, GDPR &amp; SOC 2</span>
      </div>
    </div>

    <div class="hero__showcase">
      <!-- Floating cards — positions set in the CSS below -->
      <div class="hero__fly hero__fly--volunteer hero__fly--showcase-vol">
        <span class="avatar">DR</span>
        <div>
          <strong>Dylan Randall</strong>
          <span class="hours">Hours Logged: 1h 00</span>
          <div class="party">Party size: <span class="party__count">3 people</span></div>
        </div>
      </div>
      <div class="hero__fly hero__fly--msg hero__fly--showcase-msg">
        <span class="msg-ic"></span>
        <div><strong>New message</strong><small>Céline: See you Saturday!</small></div>
      </div>
      <!-- Separate clip wrapper — handles height + bottom fade only -->
      <div class="hero__showcase-clip">
        <div class="hero__showcase-inner">
          <HeroMockupFull />
        </div>
      </div>
    </div>
  </section>

  <Partners />
  <FeatureTabs />
  <MobileApp />
  <Enterprise />
  <Security />
  <Testimonials />
  <ClosingCta />
  <Faq />
</Layout>

<style is:global>
/* ── Centered hero with FULL original mockup ── */

.hero--centered {
  padding-bottom: 0;
  overflow: visible;
}

.hero__copy--centered {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 820px;
  margin: 0 auto;
  padding-bottom: 48px;
}

.hero__copy--centered .hero__h1 {
  max-width: none;
  font-size: clamp(26px, 2.6vw, 34px);
  font-weight: 800;
  line-height: 1.22;
  text-align: center;
}

.hero__copy--centered .hero__sub {
  max-width: 660px;
  text-align: center;
  text-wrap: balance;
}

.h1-break { display: inline; }
@media (max-width: 640px) { .h1-break { display: none; } }

.hero__copy--centered .hero__ctas {
  justify-content: center;
}

.hero__meta--centered {
  justify-content: center;
}

/* ┌─────────────────────────────────────────────────────────────┐
   │  FLOATING CARD POSITIONS — tweak these freely              │
   │  Positive = inset from that edge                           │
   │  Negative = bleed outside the mockup boundary             │
   └─────────────────────────────────────────────────────────────┘ */
.hero__fly--showcase-vol {
  left:  8%;           /* ← left edge distance          */
  bottom: -12px;       /* ← negative bleeds below image */
  right: auto;
  top: auto;
}
.hero__fly--showcase-msg {
  right: 4%;           /* ← right edge distance         */
  top: 20px;           /* ← distance from top edge      */
  left: auto;
  bottom: auto;
}

/* Wide mockup showcase — overflow:visible so cards can bleed */
.hero__showcase {
  width: 100%;
  max-width: 1000px;
  margin: 0 auto;
  position: relative;
  /* padding gives room for cards that bleed outside */
  padding-top: 32px;
}

/* Separate inner div handles the clipping + bottom fade */
.hero__showcase-clip {
  height: 400px;
  overflow: hidden;
  border-radius: 16px 16px 0 0;
  box-shadow: 0 -4px 40px -8px rgba(17,17,40,.12), 0 0 0 1px rgba(0,0,0,.05);
  position: relative;
}

.hero__showcase-clip::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 120px;
  background: linear-gradient(to bottom, transparent, var(--surface-1));
  pointer-events: none;
  z-index: 2;
}

.hero__showcase-inner {
  width: 100%;
  height: 500px;
}

.hero__showcase-inner .app {
  height: 100%;
  border-radius: 0;
  box-shadow: none;
  border: none;
}

/* ── Restore full sidebar for .app--full ── */
.app--full {
  grid-template-columns: 168px 1fr !important;
}

.app--full .app__side {
  align-items: flex-start !important;
  padding: 14px 10px !important;
}

.org-pill--full {
  display: flex !important;
}

.app__group--full {
  display: block !important;
}

.app__item--full {
  gap: 8px !important;
  padding: 4px 6px !important;
  width: auto !important;
  height: auto !important;
  justify-content: flex-start !important;
  font-size: 10px !important;
}

.app__item--full .i {
  width: 14px !important;
  height: 14px !important;
}

.app__item--full .i svg {
  width: 14px !important;
  height: 14px !important;
}

.app__crumb--full {
  display: block !important;
}

.add-btn--full {
  display: inline-flex !important;
}

.col__title--full {
  display: block !important;
}

.card__play--full {
  display: inline-flex !important;
}

.card__step-pill--full {
  display: inline-block !important;
}

</style>
