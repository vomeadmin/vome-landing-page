---
/**
 * Module landing page — Data & reports (volunteer database).
 *
 * Mirrors the canonical /volunteer-application-forms composition.
 * Copy lives in `strings.module_data`. Hand-built mockups:
 *   Hero        DatabaseTableMock      (volunteer database table view)
 *   Spotlight 1 CustomFieldsMock       (custom-field manager panel)
 *   Spotlight 2 CustomViewsMock        (saved views sidebar + active view)
 *   Spotlight 3 ReportsDashboardMock   (KPI cards + hours-by-program chart)
 */
import Layout from "../layouts/Layout.astro";
import Partners from "../components/sections/Partners.astro";
import Faq from "../components/sections/Faq.astro";
import FeatureMatrix from "../components/sections/FeatureMatrix.astro";
import ClosingCta from "../components/sections/ClosingCta.astro";
import ModuleHero from "../components/module/ModuleHero.astro";
import BenefitGrid from "../components/module/BenefitGrid.astro";
import FeatureSpotlight from "../components/module/FeatureSpotlight.astro";
import HowItWorks from "../components/module/HowItWorks.astro";
import Differentiators from "../components/module/Differentiators.astro";
import DatabaseTableMock from "../components/module/DatabaseTableMock.astro";
import CustomFieldsMock from "../components/module/CustomFieldsMock.astro";
import CustomViewsMock from "../components/module/CustomViewsMock.astro";
import ReportsDashboardMock from "../components/module/ReportsDashboardMock.astro";
import { strings, t, localeFromPath, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = localeFromPath(Astro.url.pathname) } = Astro.props;
const r = strings.module_data;
const prefix = locale === "fr" ? "/fr" : "";
const demoHref = `${prefix}/demo`;
const signupHref = "https://www.vomevolunteer.com/register";

// ── Hero meta pills ──
const heroMeta = [
  { text: t(r.hero_meta_import, locale) },
  { text: t(r.hero_meta_fields, locale) },
  { text: t(r.hero_meta_perms, locale) },
];

// ── Benefits grid (6 cards). Icons match the platform-diagram line style. ──
const benefits = [
  {
    // Up arrow into a box (import / upload)
    iconSvg: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>',
    title: t(r.ben1_title, locale),
    desc: t(r.ben1_desc, locale),
  },
  {
    // Layered shapes (custom field types)
    iconSvg: '<rect x="3" y="3" width="7" height="7" rx="1"/><circle cx="17.5" cy="6.5" r="3.5"/><rect x="3" y="14" width="7" height="7" rx="3.5"/><polygon points="17.5 14 21 21 14 21 17.5 14"/>',
    title: t(r.ben2_title, locale),
    desc: t(r.ben2_desc, locale),
  },
  {
    // Tag glyph
    iconSvg: '<path d="M20.6 13.4l-7.2 7.2a2 2 0 0 1-2.8 0L3 13V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><circle cx="8" cy="8" r="1.5"/>',
    title: t(r.ben3_title, locale),
    desc: t(r.ben3_desc, locale),
  },
  {
    // Funnel / filter
    iconSvg: '<polygon points="3 4 21 4 14 12 14 19 10 21 10 12 3 4"/>',
    title: t(r.ben4_title, locale),
    desc: t(r.ben4_desc, locale),
  },
  {
    // Two-way sync (refresh arrows)
    iconSvg: '<path d="M3 12a9 9 0 0 1 15.5-6.3L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15.5 6.3L3 16"/><path d="M3 21v-5h5"/>',
    title: t(r.ben5_title, locale),
    desc: t(r.ben5_desc, locale),
  },
  {
    // Bar chart
    iconSvg: '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="3" y1="20" x2="21" y2="20"/>',
    title: t(r.ben6_title, locale),
    desc: t(r.ben6_desc, locale),
  },
];

// ── Spotlight bullets ──
const spot1Bullets = [t(r.spot1_b1, locale), t(r.spot1_b2, locale), t(r.spot1_b3, locale), t(r.spot1_b4, locale)];
const spot2Bullets = [t(r.spot2_b1, locale), t(r.spot2_b2, locale), t(r.spot2_b3, locale), t(r.spot2_b4, locale)];
const spot3Bullets = [t(r.spot3_b1, locale), t(r.spot3_b2, locale), t(r.spot3_b3, locale), t(r.spot3_b4, locale)];

// ── How-it-works steps (4) ──
const steps = [
  { title: t(r.step1_title, locale), desc: t(r.step1_desc, locale) },
  { title: t(r.step2_title, locale), desc: t(r.step2_desc, locale) },
  { title: t(r.step3_title, locale), desc: t(r.step3_desc, locale) },
  { title: t(r.step4_title, locale), desc: t(r.step4_desc, locale) },
];

// ── Differentiators (3) ──
const differentiators = [
  {
    // Heart with handshake / built for volunteers
    iconSvg: '<path d="M12 21s-7-4.5-9-9a5 5 0 0 1 9-3 5 5 0 0 1 9 3c-2 4.5-9 9-9 9z"/><path d="M9 12l2 2 4-4"/>',
    title: t(r.diff1_title, locale),
    desc: t(r.diff1_desc, locale),
  },
  {
    // Lock with grid (permissions)
    iconSvg: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1.2"/>',
    title: t(r.diff2_title, locale),
    desc: t(r.diff2_desc, locale),
  },
  {
    // Document with bar chart (report ready)
    iconSvg: '<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><line x1="9" y1="17" x2="9" y2="13"/><line x1="13" y1="17" x2="13" y2="11"/><line x1="17" y1="17" x2="17" y2="14"/>',
    title: t(r.diff3_title, locale),
    desc: t(r.diff3_desc, locale),
  },
];

// ── Module FAQs (6) ──
const faqItems = [
  { q: r.faq1_q, a: r.faq1_a, open: true },
  { q: r.faq2_q, a: r.faq2_a },
  { q: r.faq3_q, a: r.faq3_a },
  { q: r.faq4_q, a: r.faq4_a },
  { q: r.faq5_q, a: r.faq5_a },
  { q: r.faq6_q, a: r.faq6_a },
];
---

<Layout
  locale={locale}
  title={t(r.page_title, locale)}
  description={t(r.page_description, locale)}
>
  <ModuleHero
    locale={locale}
    eyebrow={t(r.hero_eyebrow, locale)}
    h1Part1={t(r.hero_h1_part1, locale)}
    h1Accent={t(r.hero_h1_accent, locale)}
    h1Part2={t(r.hero_h1_part2, locale)}
    sub={t(r.hero_sub, locale)}
    ctaPrimaryHref={signupHref}
    ctaPrimaryLabel={t(strings.nav.signup_free, locale)}
    ctaSecondaryHref={demoHref}
    ctaSecondaryLabel={t(strings.nav.book_demo, locale)}
    meta={heroMeta}
  >
    <DatabaseTableMock slot="mockup" locale={locale} />
  </ModuleHero>

  <Partners locale={locale} />

  <BenefitGrid
    locale={locale}
    h2={t(r.benefits_h2, locale)}
    sub={t(r.benefits_sub, locale)}
    items={benefits}
  />

  <FeatureSpotlight
    locale={locale}
    kicker={t(r.spot1_kicker, locale)}
    title={t(r.spot1_title, locale)}
    body={t(r.spot1_body, locale)}
    bullets={spot1Bullets}
    side="right"
  >
    <CustomFieldsMock slot="mockup" locale={locale} />
  </FeatureSpotlight>

  <FeatureSpotlight
    locale={locale}
    kicker={t(r.spot2_kicker, locale)}
    title={t(r.spot2_title, locale)}
    body={t(r.spot2_body, locale)}
    bullets={spot2Bullets}
    side="left"
  >
    <CustomViewsMock slot="mockup" locale={locale} />
  </FeatureSpotlight>

  <FeatureSpotlight
    locale={locale}
    kicker={t(r.spot3_kicker, locale)}
    title={t(r.spot3_title, locale)}
    body={t(r.spot3_body, locale)}
    bullets={spot3Bullets}
    side="right"
  >
    <ReportsDashboardMock slot="mockup" locale={locale} />
  </FeatureSpotlight>

  <HowItWorks
    locale={locale}
    h2={t(r.how_h2, locale)}
    sub={t(r.how_sub, locale)}
    steps={steps}
  />

  <Differentiators
    locale={locale}
    h2={t(r.diff_h2, locale)}
    sub={t(r.diff_sub, locale)}
    items={differentiators}
  />

  <Faq
    locale={locale}
    items={faqItems}
    heading={r.faq_h2}
    sub={r.faq_sub}
    ctaText={r.faq_cta_text}
    ctaLink={r.faq_cta_link}
  />

  <FeatureMatrix
    locale={locale}
    onlySection="data"
    heading={r.matrix_h2}
    showAllToggle
  />

  <ClosingCta locale={locale} />
</Layout>
