---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Watch Vome in Action | Volunteer Management Software"
  description="See how Vome handles volunteer recruitment, scheduling, and reporting in 2 minutes. No signup required."
>
  <!-- ── HERO ── -->
  <section class="vhero">
    <div class="vhero__inner">
      <div class="vhero__eyebrow">See Vome in 2 minutes</div>
      <h1 class="vhero__h1">See how Vome works</h1>
      <p class="vhero__sub">
        No signup required — just hit play.
      </p>
    </div>
  </section>

  <!-- ── VIDEO ── -->
  <section class="vsec">
    <div class="vsec__inner">
      <div class="yt-wrap">
        <div
          class="yt-facade"
          role="button"
          tabindex="0"
          aria-label="Play Vome product video"
        >
          <img
            class="yt-thumb"
            src="https://i.ytimg.com/vi/wEGJ49XhOQg/maxresdefault.jpg"
            alt="Vome volunteer management software walkthrough"
            width="1280"
            height="720"
            loading="lazy"
          />
          <div class="yt-play" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="30" height="30" fill="#fff">
              <polygon points="6,4 20,12 6,20" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONVERSION CTA ── -->
  <section class="vcta">
    <div class="vcta__glow" aria-hidden="true"></div>
    <div class="vcta__wrap">
      <h2 class="vcta__h2">Ready to try it yourself?</h2>
      <p class="vcta__sub">Start free today, or book a personalized demo.</p>
      <div class="vcta__actions">
        <a href="/register" class="cta__btn cta__btn--primary">Start for free</a>
        <a href="/demo" class="cta__btn cta__btn--ghost">Book a demo</a>
      </div>
      <p class="vcta__foot">
        Questions? <a href="/contact" class="vcta__footlink">Contact us</a>
      </p>
    </div>
  </section>

  <!-- Lite embed: ~400 bytes of inline JS. Only script on the page. -->
  <script is:inline>
    (function () {
      var el = document.querySelector('.yt-facade');
      function play() {
        el.outerHTML =
          '<iframe' +
          ' style="position:absolute;inset:0;width:100%;height:100%;border:0"' +
          ' src="https://www.youtube-nocookie.com/embed/wEGJ49XhOQg?autoplay=1&rel=0"' +
          ' title="Vome product walkthrough"' +
          ' allow="autoplay; fullscreen"' +
          ' allowfullscreen></iframe>';
      }
      el.addEventListener('click', play);
      el.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); play(); }
      });
    })();
  </script>
</Layout>

<style>
  /* ── Shared horizontal padding — matches nav/hero column ── */
  .vhero,
  .vsec {
    padding-left: max(5%, calc((100% - 1120px) / 2));
    padding-right: max(5%, calc((100% - 1120px) / 2));
  }

  /* ── Hero ── */
  .vhero {
    background: var(--surface-1);
    padding-top: 60px;
    padding-bottom: 32px;
    text-align: center;
  }

  .vhero__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .vhero__eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    color: var(--vome-orange);
    background: var(--vome-peach-50);
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 16px;
  }

  .vhero__h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 3vw, 44px);
    line-height: 1.15;
    letter-spacing: -0.4px;
    color: #000;
    margin: 0 0 12px;
  }

  .vhero__sub {
    font-size: 17px;
    line-height: 1.6;
    color: var(--fg-4);
    font-weight: 500;
    margin: 0;
  }

  /* ── Video section ── */
  .vsec {
    background: var(--surface-1);
    padding-top: 12px;
    padding-bottom: 72px;
  }

  .vsec__inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .yt-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    background: #000;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.1),
      0 16px 48px -12px rgba(0, 0, 0, 0.22);
  }

  .yt-facade {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .yt-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .yt-facade:hover .yt-thumb {
    transform: scale(1.02);
  }

  .yt-play {
    position: relative;
    width: 72px;
    height: 72px;
    background: var(--vome-orange);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 28px -4px rgba(250, 147, 91, 0.55);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .yt-facade:hover .yt-play {
    transform: scale(1.1);
    box-shadow: 0 14px 36px -6px rgba(250, 147, 91, 0.7);
  }

  /* ── CTA section — mirrors ClosingCta visual language ── */
  .vcta {
    background: linear-gradient(160deg, #1a1b2e 0%, #0f1020 100%);
    padding: 72px max(5%, calc((100% - 1120px) / 2));
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .vcta__glow {
    position: absolute;
    inset: -20% 20%;
    background: radial-gradient(
      60% 60% at 50% 50%,
      rgba(250, 147, 91, 0.25),
      transparent 70%
    );
    pointer-events: none;
  }

  .vcta__wrap {
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 0 auto;
  }

  .vcta__h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 2.8vw, 42px);
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
  }

  .vcta__sub {
    font-size: 16px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.75);
    max-width: 480px;
    margin: 0 auto 28px;
  }

  .vcta__actions {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .vcta__foot {
    margin-top: 20px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 0;
  }

  .vcta__footlink {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }

  .vcta__footlink:hover {
    color: var(--vome-orange);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .vhero {
      padding-top: 40px;
      padding-bottom: 24px;
    }

    .vsec {
      padding-bottom: 48px;
    }

    .vcta {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    .yt-play {
      width: 60px;
      height: 60px;
    }
  }
</style>
