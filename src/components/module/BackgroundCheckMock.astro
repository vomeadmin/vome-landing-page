---
/**
 * Spotlight 2 (SCREEN) mockup: a single step-config card showing a
 * Sterling Volunteers background-check step in progress. Shows the
 * provider connection status, package, applicant, current verification
 * status with a progress strip, and the renewal cadence.
 *
 * Layout differs from `.sp-steps__*` and `.sp-status__*` so the three
 * spotlights look distinct: this one is a vertical key/value list with
 * a horizontal progress tracker in the middle.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.module_onboarding.bg_mock;

const trackerStages = [
  { label: t(m.status_pending, locale),  state: "done"     },
  { label: t(m.status_progress, locale), state: "active"   },
  { label: t(m.status_clear, locale),    state: "upcoming" },
];
---

<div class="sp-mock sp-mock--bg" aria-label="Background check step preview">
  <div class="sp-mock__head">
    <span class="sp-mock__chip">{t(m.chip, locale)}</span>
    <span class="sp-mock__title">{t(m.step_name, locale)}</span>
    <span class="sp-bg__connected">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
      {t(m.connected, locale)}
    </span>
  </div>

  <div class="sp-mock__body">
    <div class="sp-bg__row">
      <span class="sp-bg__row-label">{t(m.provider_label, locale)}</span>
      <div class="sp-bg__row-value sp-bg__row-value--provider">
        <span class="sp-bg__provider-mark" aria-hidden="true">SV</span>
        <span>{t(m.provider_name, locale)}</span>
      </div>
    </div>

    <div class="sp-bg__row">
      <span class="sp-bg__row-label">{t(m.package_label, locale)}</span>
      <div class="sp-bg__row-value">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 7l-9 5-9-5"/><path d="M3 7v10l9 5 9-5V7"/><path d="M3 7l9-5 9 5"/></svg>
        <span>{t(m.package_value, locale)}</span>
      </div>
    </div>

    <div class="sp-bg__row">
      <span class="sp-bg__row-label">{t(m.applicant_label, locale)}</span>
      <div class="sp-bg__row-value">
        <span class="sp-bg__avatar" aria-hidden="true">RT</span>
        <span>{t(m.applicant_name, locale)}</span>
      </div>
    </div>

    <div class="sp-bg__progress">
      <div class="sp-bg__progress-label">{t(m.progress_label, locale)}</div>
      <ol class="sp-bg__tracker">
        {trackerStages.map((stage, i) => (
          <li class={`sp-bg__tracker-step sp-bg__tracker-step--${stage.state}`}>
            <span class="sp-bg__tracker-dot" aria-hidden="true">
              {stage.state === "done" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              )}
              {stage.state !== "done" && <span class="sp-bg__tracker-num">{i + 1}</span>}
            </span>
            <span class="sp-bg__tracker-label">{stage.label}</span>
          </li>
        ))}
      </ol>
    </div>

    <div class="sp-bg__renewal">
      <span class="sp-bg__renewal-label">{t(m.renewal_label, locale)}</span>
      <span class="sp-bg__renewal-value">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 0 1 15.5-6.3L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15.5 6.3L3 16"/><path d="M3 21v-5h5"/></svg>
        {t(m.renewal_value, locale)}
      </span>
    </div>
  </div>
</div>
