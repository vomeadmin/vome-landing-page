---
/**
 * Spotlight 2 mockup for /volunteer-communications.
 *
 * Auto-generated shift chatroom view. Shape:
 *   • Header chip identifies the chatroom as auto-generated.
 *   • Members row (live count + admins) plus a one-line note explaining
 *     volunteers join when they reserve and leave when they cancel.
 *   • Message list: an admin reminder, a volunteer reply, then a
 *     system message confirming a new volunteer joined.
 *   • Disabled message input at the bottom for chrome.
 *
 * Mirrors `views/org/orgChats/` patterns. Decorative; volunteer names are
 * placeholders. No <img> tags — avatars are CSS-styled letter chips.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.module_comms.chatroom_mock;
---

<div class="sp-mock sp-mock--chat" aria-label="Auto-generated chatroom preview">
  <div class="sp-mock__head">
    <span class="sp-mock__chip">{t(m.chip, locale)}</span>
    <span class="sp-mock__title">{t(m.title, locale)}</span>
  </div>

  <div class="sp-mock__body">
    <div class="sp-chat__members">
      <div class="sp-chat__member-stack">
        <span class="sp-chat__avatar sp-chat__avatar--a">M</span>
        <span class="sp-chat__avatar sp-chat__avatar--b">J</span>
        <span class="sp-chat__avatar sp-chat__avatar--c">S</span>
        <span class="sp-chat__avatar sp-chat__avatar--more">+9</span>
      </div>
      <div class="sp-chat__members-text">
        <span class="sp-chat__members-label">{t(m.members_label, locale)}</span>
        <span class="sp-chat__members-count">{t(m.members_count, locale)}</span>
      </div>
    </div>

    <div class="sp-chat__note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v5h-5"/></svg>
      <span>{t(m.auto_note, locale)}</span>
    </div>

    <ul class="sp-chat__msgs">
      <li class="sp-chat__msg sp-chat__msg--in">
        <span class="sp-chat__avatar sp-chat__avatar--a">M</span>
        <span class="sp-chat__bubble">
          <span class="sp-chat__msg-meta">
            <span class="sp-chat__msg-name">{t(m.msg1_who, locale)}</span>
            <span class="sp-chat__msg-time">{t(m.msg1_time, locale)}</span>
          </span>
          <span class="sp-chat__msg-text">{t(m.msg1_text, locale)}</span>
        </span>
      </li>

      <li class="sp-chat__msg sp-chat__msg--in">
        <span class="sp-chat__avatar sp-chat__avatar--b">J</span>
        <span class="sp-chat__bubble">
          <span class="sp-chat__msg-meta">
            <span class="sp-chat__msg-name">{t(m.msg2_who, locale)}</span>
            <span class="sp-chat__msg-time">{t(m.msg2_time, locale)}</span>
          </span>
          <span class="sp-chat__msg-text">{t(m.msg2_text, locale)}</span>
        </span>
      </li>

      <li class="sp-chat__sys">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="8" r="3.5"/><path d="M3 20a6 6 0 0 1 12 0"/><path d="M16 11l2 2 4-4"/></svg>
        <span>
          <span class="sp-chat__sys-by">{t(m.msg3_who, locale)} · </span>
          {t(m.msg3_text, locale)}
          <span class="sp-chat__sys-time"> · {t(m.msg3_time, locale)}</span>
        </span>
      </li>
    </ul>

    <div class="sp-chat__input" aria-hidden="true">
      <span class="sp-chat__input-text">{t(m.input_placeholder, locale)}</span>
      <span class="sp-chat__input-send">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4z"/></svg>
      </span>
    </div>
  </div>
</div>
