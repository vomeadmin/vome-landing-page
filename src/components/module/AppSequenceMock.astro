---
/**
 * Spotlight 3 mockup for /app-for-volunteers — onboarding sequence.
 * Modeled on the live Vome volunteer-app sequence UI (see
 * `mobile-app/VomeApp/src/screens/volDashboard/SequenceViewData.js`,
 * `SequenceVideoPreview.js`, `SequenceStartBackgroundCheck.js`):
 * sequence title + assigned-by + progress bar + a list of typed step
 * rows (information, video, e-signature, document upload, training)
 * each with their own status, plus a primary "Continue step N" CTA.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props { locale?: Locale }

const { locale = "en" } = Astro.props;
const m = strings.module_app.sequence_mock;
---

<div class="app-mock app-mock--seq" aria-label="Onboarding sequence screen">
  <div class="mob__bezel">
    <div class="mob__notch"></div>
    <div class="mob__screen" style="background:#fafafa">
      <div class="mob__statusbar">
        <span>9:41</span>
        <span class="mob__statusicons">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M2 10h3v6H2zM7 8h3v8H7zM12 6h3v10h-3zM17 4h3v12h-3z" /></svg>
          <svg viewBox="0 0 24 12" width="16" height="10" fill="none" stroke="currentColor" stroke-width="1"><rect x=".5" y=".5" width="18" height="10" rx="2" fill="none" /><rect x="2" y="2" width="14" height="7" rx="1" fill="currentColor" /></svg>
        </span>
      </div>

      <div class="app-mock__topbar">
        <span class="app-mock__menu" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </span>
        <span class="app-mock__topbartitle">{t(m.header_title, locale)}</span>
        <span class="app-mock__topbarbell" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0112 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 004 0"/></svg>
        </span>
      </div>

      <div class="app-mock__seqcard">
        <span class="app-mock__seqlogo" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </span>
        <span class="app-mock__seqbody">
          <span class="app-mock__seqtitle">{t(m.seq_title, locale)}</span>
          <span class="app-mock__seqorg">{t(m.seq_org, locale)}</span>
        </span>
      </div>

      <div class="app-mock__seqprogwrap">
        <div class="app-mock__seqproglabel">{t(m.progress_label, locale)}</div>
        <div class="app-mock__seqprogbar">
          <div class="app-mock__seqprogfill" style="width:60%"></div>
        </div>
      </div>

      <ul class="app-mock__steplist">
        <li class="app-mock__step app-mock__step--done">
          <span class="app-mock__stepicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4L19 6"/></svg>
          </span>
          <span class="app-mock__stepbody">
            <span class="app-mock__steplbl">{t(m.step1_label, locale)}</span>
            <span class="app-mock__stepstatus">{t(m.step1_status, locale)}</span>
          </span>
        </li>
        <li class="app-mock__step app-mock__step--done">
          <span class="app-mock__stepicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4L19 6"/></svg>
          </span>
          <span class="app-mock__stepbody">
            <span class="app-mock__steplbl">{t(m.step2_label, locale)}</span>
            <span class="app-mock__stepstatus">{t(m.step2_status, locale)}</span>
          </span>
          <span class="app-mock__steptype" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </span>
        </li>
        <li class="app-mock__step app-mock__step--current">
          <span class="app-mock__stepicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
          </span>
          <span class="app-mock__stepbody">
            <span class="app-mock__steplbl">{t(m.step3_label, locale)}</span>
            <span class="app-mock__stepstatus">{t(m.step3_status, locale)}</span>
          </span>
          <span class="app-mock__steptype" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l3-1 11-11-2-2L4 18l-1 3z"/><path d="M14 7l3 3"/></svg>
          </span>
        </li>
        <li class="app-mock__step">
          <span class="app-mock__stepicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
          </span>
          <span class="app-mock__stepbody">
            <span class="app-mock__steplbl">{t(m.step4_label, locale)}</span>
            <span class="app-mock__stepstatus">{t(m.step4_status, locale)}</span>
          </span>
          <span class="app-mock__steptype" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><path d="M17 8l-5-5-5 5"/><path d="M12 3v12"/></svg>
          </span>
        </li>
        <li class="app-mock__step">
          <span class="app-mock__stepicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
          </span>
          <span class="app-mock__stepbody">
            <span class="app-mock__steplbl">{t(m.step5_label, locale)}</span>
            <span class="app-mock__stepstatus">{t(m.step5_status, locale)}</span>
          </span>
          <span class="app-mock__steptype" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </span>
        </li>
      </ul>

      <div class="app-mock__seqcta">{t(m.continue_btn, locale)}</div>
    </div>
  </div>
</div>
