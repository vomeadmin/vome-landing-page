---
/**
 * Spotlight 1 (VOME ACHIEVEMENTS) mockup: a 2-column grid showing the
 * Bronze→Platinum tier ladder fueled by Vome Points, plus two sample
 * platform challenges. Each card carries a 'tone' that drives the
 * accent color and icon. Mirrors the layout family in
 * `web-app/vome-react/src/views/org/orgRecognition/AchievementCard.js`.
 *
 * Distinct from the other spotlights: card-grid layout (not a vertical
 * list, not a vertical form, not a horizontal timeline).
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.module_recognition.cat_mock;

const cards = [
  { name: t(m.c1_name, locale), rule: t(m.c1_rule, locale), kind: t(m.c1_kind, locale), tone: "bronze" },
  { name: t(m.c2_name, locale), rule: t(m.c2_rule, locale), kind: t(m.c2_kind, locale), tone: "silver" },
  { name: t(m.c3_name, locale), rule: t(m.c3_rule, locale), kind: t(m.c3_kind, locale), tone: "gold" },
  { name: t(m.c4_name, locale), rule: t(m.c4_rule, locale), kind: t(m.c4_kind, locale), tone: "platinum" },
  { name: t(m.c5_name, locale), rule: t(m.c5_rule, locale), kind: t(m.c5_kind, locale), tone: "shift" },
  { name: t(m.c6_name, locale), rule: t(m.c6_rule, locale), kind: t(m.c6_kind, locale), tone: "hours" },
];

const isTier = (tone: string) => tone === "bronze" || tone === "silver" || tone === "gold" || tone === "platinum";
---

<div class="sp-mock sp-mock--cat" aria-label="Built-in achievements catalog preview">
  <div class="sp-mock__head">
    <span class="sp-mock__chip">{t(m.chip, locale)}</span>
    <span class="sp-mock__title">{t(m.title, locale)}</span>
  </div>
  <div class="sp-mock__body">
    <div class="sp-mock__col-label">{t(m.label, locale)}</div>
    <ul class="sp-cat__grid">
      {cards.map((c) => (
        <li class={`sp-cat__card sp-cat__card--${c.tone}`}>
          <span class={`sp-cat__icon sp-cat__icon--${c.tone}`} aria-hidden="true">
            {isTier(c.tone) && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="5"/><path d="M8.5 13l-2 8 5.5-3 5.5 3-2-8"/></svg>
            )}
            {c.tone === "shift" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/><path d="M8.5 14.5l2.5 2.5 4.5-5"/></svg>
            )}
            {c.tone === "hours" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            )}
          </span>
          <div class="sp-cat__body">
            <div class="sp-cat__name">{c.name}</div>
            <div class="sp-cat__rule">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12h6l3-7 3 14 3-7h3"/></svg>
              <span>{c.rule}</span>
            </div>
            <div class="sp-cat__row">
              <span class={`sp-cat__kind sp-cat__kind--${c.tone}`}>{c.kind}</span>
              <span class="sp-cat__auto">
                <span class="sp-cat__auto-dot"></span>{t(m.auto_badge, locale)}
              </span>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</div>
