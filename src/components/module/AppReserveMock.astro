---
/**
 * Spotlight 1 mockup for /app-for-volunteers — shift reservation detail
 * with the "bring a guest" group-reservation row. Mirrors the structure
 * in `mobile-app/VomeApp/src/screens/volDashboard/bookShift/` (BookShift,
 * ReservationReviewContainer, GroupReservationGuestsSheet).
 */
import { strings, t, type Locale } from "../../i18n";

interface Props { locale?: Locale }

const { locale = "en" } = Astro.props;
const m = strings.module_app.reserve_mock;
---

<div class="app-mock app-mock--reserve" aria-label="Reserve a shift screen">
  <div class="mob__bezel">
    <div class="mob__notch"></div>
    <div class="mob__screen" style="background:#fafafa">
      <div class="mob__statusbar">
        <span>9:41</span>
        <span class="mob__statusicons">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M2 10h3v6H2zM7 8h3v8H7zM12 6h3v10h-3zM17 4h3v12h-3z" /></svg>
          <svg viewBox="0 0 24 12" width="16" height="10" fill="none" stroke="currentColor" stroke-width="1"><rect x=".5" y=".5" width="18" height="10" rx="2" fill="none" /><rect x="2" y="2" width="14" height="7" rx="1" fill="currentColor" /></svg>
        </span>
      </div>

      <div class="app-mock__navrow">
        <span class="app-mock__back">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
          <span>{t(m.back, locale)}</span>
        </span>
        <span class="app-mock__kicker">{t(m.kicker, locale)}</span>
      </div>

      <div class="app-mock__hero">
        <div class="app-mock__opp">{t(m.opportunity, locale)}</div>
        <div class="app-mock__shifth1">{t(m.title, locale)}</div>
        <span class="app-mock__spots">
          <span class="app-mock__spotsdot"></span>
          {t(m.spots, locale)}
        </span>
      </div>

      <div class="app-mock__detail">
        <div class="app-mock__row">
          <span class="app-mock__rowicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </span>
          <span class="app-mock__rowlbl">{t(m.when_label, locale)}</span>
          <span class="app-mock__rowval">{t(m.when_value, locale)}</span>
        </div>
        <div class="app-mock__row">
          <span class="app-mock__rowicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span class="app-mock__rowlbl">{t(m.where_label, locale)}</span>
          <span class="app-mock__rowval">{t(m.where_value, locale)}</span>
        </div>
        <div class="app-mock__row">
          <span class="app-mock__rowicon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0116 0"/></svg>
          </span>
          <span class="app-mock__rowlbl">{t(m.role_label, locale)}</span>
          <span class="app-mock__rowval">{t(m.role_value, locale)}</span>
        </div>
      </div>

      <div class="app-mock__guest">
        <span class="app-mock__guesticon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.5"/><path d="M3 20a6 6 0 0 1 12 0"/><circle cx="17" cy="8" r="2.5"/><path d="M15 20a5 5 0 0 1 7 0"/></svg>
        </span>
        <span class="app-mock__guestbody">
          <span class="app-mock__guestlbl">{t(m.bring_label, locale)}</span>
          <span class="app-mock__guestmeta">{t(m.bring_value, locale)}</span>
        </span>
        <span class="app-mock__guestchip">{t(m.bring_chip, locale)}</span>
      </div>

      <div class="app-mock__cta">
        <span class="app-mock__cta-btn">{t(m.reserve_btn, locale)}</span>
        <span class="app-mock__cta-sub">{t(m.cancel_link, locale)}</span>
      </div>
    </div>
  </div>
</div>
