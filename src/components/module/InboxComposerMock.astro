---
/**
 * Hero mockup for /volunteer-communications.
 *
 * Two-pane layout inside the standard `.fb-mock` hero frame:
 *   • Left: auto-generated shift chatroom (Slack-style channel with header,
 *     three messages — text, voice note, image attachment — and an input row
 *     with attach affordances).
 *   • Right: bulk-email composer with from-mailbox row (Gmail badge),
 *     recipient segment, subject, template chip, body preview, and Send.
 *
 * Uses the same /integrations/gmail.webp asset as the homepage Enterprise grid.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.module_comms.inbox_mock;
---

<div class="fb-mock fb-mock--inbox" aria-label="Shift chatroom and email composer preview">
  <div class="fb-mock__chrome">
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__url">{t(m.url, locale)}</span>
  </div>

  <div class="fb-inbox">
    {/* Left pane: shift chatroom */}
    <aside class="fb-chat">
      <div class="fb-chat__head">
        <span class="fb-chat__hash" aria-hidden="true">#</span>
        <span class="fb-chat__head-body">
          <span class="fb-chat__title">{t(m.channel_title, locale)}</span>
          <span class="fb-chat__meta">{t(m.channel_meta, locale)}</span>
        </span>
      </div>

      <ul class="fb-chat__messages">
        {/* Message 1: text from admin */}
        <li class="fb-chat__msg">
          <span class="fb-chat__avatar fb-chat__avatar--admin">M</span>
          <span class="fb-chat__msg-body">
            <span class="fb-chat__msg-row">
              <span class="fb-chat__who">{t(m.msg1_who, locale)}</span>
              <span class="fb-chat__time">{t(m.msg1_time, locale)}</span>
            </span>
            <span class="fb-chat__bubble">{t(m.msg1_text, locale)}</span>
          </span>
        </li>

        {/* Message 2: voice note */}
        <li class="fb-chat__msg">
          <span class="fb-chat__avatar">J</span>
          <span class="fb-chat__msg-body">
            <span class="fb-chat__msg-row">
              <span class="fb-chat__who">{t(m.msg2_who, locale)}</span>
              <span class="fb-chat__time">{t(m.msg2_time, locale)}</span>
            </span>
            <span class="fb-chat__bubble fb-chat__bubble--voice">
              <span class="fb-chat__voice-play" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span class="fb-chat__voice-wave" aria-hidden="true">
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span>
              </span>
              <span class="fb-chat__voice-meta">
                <span class="fb-chat__voice-label">{t(m.msg2_voice_label, locale)}</span>
                <span class="fb-chat__voice-dur">{t(m.msg2_voice_dur, locale)}</span>
              </span>
            </span>
          </span>
        </li>

        {/* Message 3: image attachment */}
        <li class="fb-chat__msg">
          <span class="fb-chat__avatar">SL</span>
          <span class="fb-chat__msg-body">
            <span class="fb-chat__msg-row">
              <span class="fb-chat__who">{t(m.msg3_who, locale)}</span>
              <span class="fb-chat__time">{t(m.msg3_time, locale)}</span>
            </span>
            <span class="fb-chat__bubble fb-chat__bubble--attach">
              <span class="fb-chat__file-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </span>
              <span class="fb-chat__file-meta">
                <span class="fb-chat__file-name">{t(m.msg3_attach_name, locale)}</span>
                <span class="fb-chat__file-size">{t(m.msg3_attach_size, locale)}</span>
              </span>
            </span>
          </span>
        </li>
      </ul>

      <div class="fb-chat__input">
        <span class="fb-chat__input-tools" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><path d="M12 19v3"/></svg>
        </span>
        <span class="fb-chat__input-placeholder">{t(m.msg_input_placeholder, locale)}</span>
      </div>
    </aside>

    {/* Right pane: email composer */}
    <section class="fb-inbox__composer">
      <div class="fb-inbox__composer-head">
        <span class="fb-mock__kicker">{t(m.composer_chip, locale)}</span>
      </div>

      <div class="fb-inbox__row">
        <span class="fb-inbox__row-label">{t(m.from_label, locale)}</span>
        <span class="fb-inbox__row-value">
          <span class="fb-inbox__gmail">
            <img src="/integrations/gmail.webp" alt="Gmail" />
          </span>
          <span class="fb-inbox__from-stack">
            <span class="fb-inbox__from-addr">{t(m.from_value, locale)}</span>
            <span class="fb-inbox__from-provider">{t(m.from_provider, locale)}</span>
          </span>
        </span>
      </div>

      <div class="fb-inbox__row">
        <span class="fb-inbox__row-label">{t(m.to_label, locale)}</span>
        <span class="fb-inbox__row-value">
          <span class="fb-inbox__seg-chip">{t(m.to_segment, locale)}</span>
          <span class="fb-inbox__count">{t(m.to_count, locale)}</span>
        </span>
      </div>

      <div class="fb-inbox__row">
        <span class="fb-inbox__row-label">{t(m.subject_label, locale)}</span>
        <span class="fb-inbox__row-value fb-inbox__row-value--subject">{t(m.subject_value, locale)}</span>
      </div>

      <div class="fb-inbox__template">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 9v12"/></svg>
        <span>{t(m.template_chip, locale)}</span>
      </div>

      <p class="fb-inbox__body-preview">{t(m.body_preview, locale)}</p>

      <div class="fb-inbox__send-row">
        <span class="fb-inbox__send-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4z"/></svg>
          {t(m.send_label, locale)}
        </span>
      </div>
    </section>
  </div>
</div>
