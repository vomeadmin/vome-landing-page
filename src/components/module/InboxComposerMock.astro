---
/**
 * Hero mockup for /volunteer-communications.
 *
 * Two-pane layout inside the standard `.fb-mock` hero frame:
 *   • Left: chat threads list (private chat, custom group chat, auto shift chatroom).
 *   • Right: bulk-email composer with from-mailbox row, recipient segment, subject,
 *     template chip, and message body preview.
 *
 * Only structural labels translate; volunteer names, segments and previews are
 * decorative placeholders. No <img> tags.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.module_comms.inbox_mock;

const threads = [
  {
    name: t(m.thread1_name, locale),
    preview: t(m.thread1_preview, locale),
    meta: t(m.thread1_meta, locale),
    initial: "S",
    auto: true,
    active: true,
  },
  {
    name: t(m.thread2_name, locale),
    preview: t(m.thread2_preview, locale),
    meta: t(m.thread2_meta, locale),
    initial: "SL",
    auto: false,
    active: false,
  },
  {
    name: t(m.thread3_name, locale),
    preview: t(m.thread3_preview, locale),
    meta: t(m.thread3_meta, locale),
    initial: "HC",
    auto: false,
    active: false,
  },
];
---

<div class="fb-mock fb-mock--inbox" aria-label="Inbox and email composer preview">
  <div class="fb-mock__chrome">
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__url">{t(m.url, locale)}</span>
  </div>

  <div class="fb-inbox">
    {/* Left pane: threads list */}
    <aside class="fb-inbox__threads">
      <div class="fb-inbox__threads-head">
        <span class="fb-inbox__threads-label">{t(m.threads_label, locale)}</span>
      </div>
      <ul class="fb-inbox__list">
        {threads.map((th) => (
          <li class={`fb-inbox__thread${th.active ? " fb-inbox__thread--active" : ""}`}>
            <span class="fb-inbox__avatar">{th.initial}</span>
            <span class="fb-inbox__thread-body">
              <span class="fb-inbox__thread-row">
                <span class="fb-inbox__thread-name">{th.name}</span>
                {th.auto && (
                  <span class="fb-inbox__auto">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v5h-5"/></svg>
                  </span>
                )}
              </span>
              <span class="fb-inbox__thread-preview">{th.preview}</span>
              <span class="fb-inbox__thread-meta">{th.meta}</span>
            </span>
          </li>
        ))}
      </ul>
    </aside>

    {/* Right pane: email composer */}
    <section class="fb-inbox__composer">
      <div class="fb-inbox__composer-head">
        <span class="fb-mock__kicker">{t(m.composer_chip, locale)}</span>
      </div>

      <div class="fb-inbox__row">
        <span class="fb-inbox__row-label">{t(m.from_label, locale)}</span>
        <span class="fb-inbox__row-value">
          <span class="fb-inbox__provider-mark">G</span>
          <span>{t(m.from_value, locale)}</span>
        </span>
      </div>

      <div class="fb-inbox__row">
        <span class="fb-inbox__row-label">{t(m.to_label, locale)}</span>
        <span class="fb-inbox__row-value">
          <span class="fb-inbox__seg-chip">{t(m.to_segment, locale)}</span>
          <span class="fb-inbox__count">{t(m.to_count, locale)}</span>
        </span>
      </div>

      <div class="fb-inbox__row">
        <span class="fb-inbox__row-label">{t(m.subject_label, locale)}</span>
        <span class="fb-inbox__row-value fb-inbox__row-value--subject">{t(m.subject_value, locale)}</span>
      </div>

      <div class="fb-inbox__template">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 9v12"/></svg>
        <span>{t(m.template_chip, locale)}</span>
      </div>

      <p class="fb-inbox__body-preview">{t(m.body_preview, locale)}</p>

      <div class="fb-inbox__send-row">
        <span class="fb-inbox__send-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4z"/></svg>
          {t(m.send_label, locale)}
        </span>
      </div>
    </section>
  </div>
</div>
