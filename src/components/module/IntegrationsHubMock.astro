---
/**
 * Hero mockup for /integrations.
 *
 * Mirrors the Enterprise integrations card on the home page: real partner
 * logos arranged in a tight grid, with the white Vome mark sitting above
 * them on an orange disc. The whole thing lives inside the shared
 * .fb-mock browser-chrome shell so it reads as a family with the other
 * module heroes.
 *
 * Logo assets live in /public/integrations/. To swap which logos appear,
 * edit the `tiles` array below — order is left-to-right, top-to-bottom.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.module_integrations.hub_mock;

const tiles = [
  { src: "/integrations/salesforce.png", alt: "Salesforce" },
  { src: "/integrations/zapier.png",     alt: "Zapier", wide: true },
  { src: "/integrations/microsoft.png",  alt: "Microsoft Power Automate" },
  { src: "/integrations/sterling.jpeg",  alt: "Sterling Volunteers" },
  { src: "/integrations/dtd.png",        alt: "Double the Donation" },
  { src: "/integrations/outlook.svg",    alt: "Outlook" },
  { src: "/integrations/gmail.webp",     alt: "Gmail" },
];
---

<div class="fb-mock fb-mock--hub" aria-label="Integrations hub preview">
  <div class="fb-mock__chrome">
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__dot"></span>
    <span class="fb-mock__url">vomevolunteer.com/integrations</span>
  </div>

  <div class="fb-mock__body fb-hub__body">
    <div class="fb-mock__head">
      <div class="fb-mock__title-row">
        <span class="fb-mock__kicker">{t(m.chip, locale)}</span>
        <span class="fb-hub__live">
          <span class="fb-hub__live-dot"></span>{t(m.synced, locale)}
        </span>
      </div>
    </div>

    <div class="ent__visual ent__visual--int fb-hub__viz">
      <div class="ent__inthub" aria-label={t(m.vome, locale)}>
        <img src="/logos/app-logo-white.png" alt={t(m.vome, locale)} />
      </div>
      <div class="ent__intgrid fb-hub__intgrid">
        {tiles.map((tile) => (
          <div class="ent__int" title={tile.alt}>
            <img src={tile.src} alt={tile.alt} class={tile.wide ? "ent__int--wide" : undefined} />
          </div>
        ))}
        <div class="ent__int ent__int--more" title="And more">
          <span>{t(strings.enterprise.int_more, locale)}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Hero variant of the Enterprise hub. The base .ent__visual rules
     (fixed 260px height, gray panel, border, bottom margin) are written
     for the home-page card layout and don't fit inside the .fb-mock
     browser chrome — neutralize them, then keep the hub-specific layout
     from .ent__visual--int.

     Reuses .ent__inthub / .ent__intgrid / .ent__int from the Enterprise
     section so partner logos render at the same optical weight. */
  .fb-mock--hub .fb-hub__viz{
    background:transparent;
    border:0;
    border-radius:0;
    height:auto;
    margin:14px 0 0;
    padding:8px 4px 4px;
    gap:14px;
  }
  .fb-mock--hub .fb-hub__intgrid{
    grid-template-columns:repeat(4,1fr);
    gap:8px;
  }
  .fb-mock--hub .ent__inthub{
    width:52px;height:52px;
  }
</style>
