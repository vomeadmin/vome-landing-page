---
/**
 * Spotlight 3 mockup for /app-for-volunteers — Schedule tab.
 * Modeled on the live Vome volunteer-app schedule view: a top app bar,
 * a horizontal week strip with the current day pilled in orange, then
 * the agenda grouped by date with orange-stripe shift cards and an
 * inline cancel affordance. A small "Add time off" pill sits at the
 * bottom for the unavailability flow.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props { locale?: Locale }

const { locale = "en" } = Astro.props;
const m = strings.module_app.schedule_mock;

const week = [
  { letter: "S", date: "10" },
  { letter: "M", date: "11" },
  { letter: "T", date: "12", active: true },
  { letter: "W", date: "13" },
  { letter: "T", date: "14" },
  { letter: "F", date: "15" },
  { letter: "S", date: "16" },
];
---

<div class="app-mock app-mock--sched" aria-label="My schedule screen">
  <div class="mob__bezel">
    <div class="mob__notch"></div>
    <div class="mob__screen" style="background:#fafafa">
      <div class="mob__statusbar">
        <span>9:41</span>
        <span class="mob__statusicons">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M2 10h3v6H2zM7 8h3v8H7zM12 6h3v10h-3zM17 4h3v12h-3z" /></svg>
          <svg viewBox="0 0 24 12" width="16" height="10" fill="none" stroke="currentColor" stroke-width="1"><rect x=".5" y=".5" width="18" height="10" rx="2" fill="none" /><rect x="2" y="2" width="14" height="7" rx="1" fill="currentColor" /></svg>
        </span>
      </div>

      <div class="app-mock__topbar">
        <span class="app-mock__menu" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </span>
        <span class="app-mock__topbartitle">{t(m.header_title, locale)}</span>
      </div>

      <div class="app-mock__monthrow">
        <span class="app-mock__month">{t(m.month_label, locale)}</span>
      </div>

      <div class="app-mock__weekstrip" role="list">
        {week.map((d) => (
          <span class={`app-mock__day${d.active ? " app-mock__day--active" : ""}`} role="listitem">
            <span class="app-mock__daylet">{d.letter}</span>
            <span class="app-mock__daynum">{d.date}</span>
          </span>
        ))}
      </div>

      <div class="app-mock__agenda">
        <div class="app-mock__daygroup">
          <div class="app-mock__dayhead">{t(m.group1_label, locale)}</div>
          <div class="app-mock__shiftcard">
            <span class="app-mock__shiftstripe" aria-hidden="true"></span>
            <span class="app-mock__shifttime">{t(m.shift1_time, locale)}</span>
            <span class="app-mock__shiftbody">
              <span class="app-mock__shifttitle">{t(m.shift1_title, locale)}</span>
              <span class="app-mock__shiftorg">{t(m.shift1_org, locale)}</span>
            </span>
            <span class="app-mock__shiftcancel">{t(m.cancel_action, locale)}</span>
          </div>
        </div>

        <div class="app-mock__daygroup">
          <div class="app-mock__dayhead">{t(m.group2_label, locale)}</div>
          <div class="app-mock__shiftcard">
            <span class="app-mock__shiftstripe" aria-hidden="true"></span>
            <span class="app-mock__shifttime">{t(m.shift2_time, locale)}</span>
            <span class="app-mock__shiftbody">
              <span class="app-mock__shifttitle">{t(m.shift2_title, locale)}</span>
              <span class="app-mock__shiftorg">{t(m.shift2_org, locale)}</span>
            </span>
            <span class="app-mock__shiftcancel">{t(m.cancel_action, locale)}</span>
          </div>
        </div>

        <div class="app-mock__daygroup">
          <div class="app-mock__dayhead">{t(m.group3_label, locale)}</div>
          <div class="app-mock__empty">{t(m.group3_empty, locale)}</div>
        </div>
      </div>

      <div class="app-mock__timeoffpill">{t(m.timeoff_pill, locale)}</div>
    </div>
  </div>
</div>
