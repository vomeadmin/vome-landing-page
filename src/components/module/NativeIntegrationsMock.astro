---
/**
 * Spotlight 1 (CONNECT) mockup — native integrations dashboard.
 *
 * Five rows, one per shipped native integration. Each row is:
 *   ┌──┐  Integration name              live stat ●
 *   │M │  one-line description
 *   └──┘
 *
 * The square monogram tile (`.sp-native__tile`) replaces the old text
 * pill — brand-colored background with a 1–2 letter mark, fixed 40px.
 * That fixes the "Salesforce Lightni..." truncation and removes the
 * duplicate-name issue from the previous design.
 *
 * The right column shows a per-row live metric instead of five
 * identical "Connected" pills, so the panel reads as a real dashboard.
 *
 * Mirrors OrgIntegrations in the React app
 * (`src/views/org/orgIntegrations/OrgIntegrations.js`) where each
 * native integration tile shows its own status state.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.module_integrations.native_mock;

const rows = [
  { brand: "sf",       mono: "SF", name: t(m.sf_name, locale),       meta: t(m.sf_meta, locale),       stat: t(m.sf_stat, locale)       },
  { brand: "sterling", mono: "SV", name: t(m.sterling_name, locale), meta: t(m.sterling_meta, locale), stat: t(m.sterling_stat, locale) },
  { brand: "scorm",    mono: "SC", name: t(m.scorm_name, locale),    meta: t(m.scorm_meta, locale),    stat: t(m.scorm_stat, locale)    },
  { brand: "dtd",      mono: "DD", name: t(m.dtd_name, locale),      meta: t(m.dtd_meta, locale),      stat: t(m.dtd_stat, locale)      },
  { brand: "sheets",   mono: "GS", name: t(m.sheets_name, locale),   meta: t(m.sheets_meta, locale),   stat: t(m.sheets_stat, locale)   },
];
---

<div class="sp-mock sp-mock--native" aria-label="Native integrations preview">
  <div class="sp-mock__head sp-native__head">
    <span class="sp-mock__chip">{t(m.chip, locale)}</span>
    <span class="sp-native__count">
      <span class="sp-native__count-dot"></span>
      {t(m.title, locale)}
    </span>
  </div>
  <div class="sp-mock__body">
    <ul class="sp-native__list">
      {rows.map((r) => (
        <li class="sp-native__row">
          <span class={`sp-native__tile sp-native__tile--${r.brand}`} aria-hidden="true">
            {r.mono}
          </span>
          <div class="sp-native__copy">
            <div class="sp-native__name">{r.name}</div>
            <div class="sp-native__meta">{r.meta}</div>
          </div>
          <span class="sp-native__stat">
            {r.stat}
            <span class="sp-native__stat-dot" aria-hidden="true"></span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style is:global>
  /* ── Spotlight 1: Native integrations dashboard (redesigned) ── */
  .sp-native__head{
    display:flex;align-items:center;justify-content:space-between;gap:10px;
  }
  .sp-native__count{
    display:inline-flex;align-items:center;gap:6px;
    font-size:11.5px;font-weight:600;color:var(--fg-3);
  }
  .sp-native__count-dot{
    width:6px;height:6px;border-radius:50%;
    background:#3a9067;
    box-shadow:0 0 0 3px rgba(75,177,129,.18);
  }

  /* Row layout */
  .sp-native__row{
    display:flex;align-items:center;gap:12px;
    padding:10px 12px;
  }

  /* Square monogram tile — replaces old truncating text pill */
  .sp-native__tile{
    flex-shrink:0;
    width:40px;height:40px;
    border-radius:9px;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--font-display);
    font-size:13px;font-weight:800;
    letter-spacing:.5px;
    line-height:1;
  }
  .sp-native__tile--sf{       background:#e6f0fb;color:#0d68b1; }
  .sp-native__tile--sterling{ background:#e8eaf3;color:#1a2f6b; }
  .sp-native__tile--scorm{    background:#e0f3f1;color:#0e7d75; }
  .sp-native__tile--dtd{      background:#e7f4e6;color:#22823b; }
  .sp-native__tile--sheets{   background:#e3f1e3;color:#188038; }

  /* Right-side per-row live stat (replaces repeated Connected pill) */
  .sp-native__stat{
    flex-shrink:0;
    display:inline-flex;align-items:center;gap:7px;
    font-size:11.5px;font-weight:600;
    color:#2a8359;
    background:rgba(75,177,129,.1);
    padding:5px 10px;border-radius:999px;
    white-space:nowrap;
  }
  .sp-native__stat-dot{
    width:5px;height:5px;border-radius:50%;
    background:#3a9067;
    box-shadow:0 0 0 2px rgba(75,177,129,.2);
  }
</style>
