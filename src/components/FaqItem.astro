---
interface Props {
  question: string;
  open?: boolean;
}

const { question, open = false } = Astro.props;
---

<details class="faq__item" {...(open ? { open: "" } : {})}>
  <summary class="faq__q">
    <span>{question}</span>
    <span class="faq__chev" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </span>
  </summary>
  <div class="faq__a"><slot /></div>
</details>
