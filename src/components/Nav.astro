---
import Button from "./Button.astro";
import { strings, t, localeFromPath, switchLocaleHref, type Locale } from "../i18n";
import { appUrl } from "../lib/appUrl";

interface Props {
  locale?: Locale;
}

const { locale = localeFromPath(Astro.url.pathname) } = Astro.props;
const currentLabel = locale === "en" ? "English" : "Français";

const langOptions: { code: Locale; label: string; href: string }[] = [
  { code: "en", label: "English", href: switchLocaleHref(Astro.url.pathname, "en") },
  { code: "fr", label: "Français", href: switchLocaleHref(Astro.url.pathname, "fr") },
];

// Convenience accessors. Strings come from src/i18n/strings.ts.
const n = strings.nav;
const fp = strings.features_page;

// Features dropdown — 9 module tiles in a 3x3 grid + bottom "View all
// features" link. Icons + titles come from the platform-diagram source
// of truth (features_page.node_*_title) so the dropdown, diagram, and
// module cards stay in sync. Descriptions are dropdown-specific (short,
// single line) — the platform diagram uses the longer node_*_desc copy.
// Hrefs match the marketing routes mirrored on each module page.
const featurePrefix = locale === "fr" ? "/fr" : "";
const featDesc = {
  recruitment:  { en: "Application forms",     fr: "Formulaires" },
  onboarding:   { en: "Guided workflows",      fr: "Parcours guidés" },
  scheduling:   { en: "Shifts & self-booking", fr: "Quarts et réservation" },
  hours:        { en: "QR, kiosk & auto",      fr: "QR, borne et auto" },
  recognition:  { en: "Challenges & awards",   fr: "Défis et récompenses" },
  comms:        { en: "Chat & email",          fr: "Clavardage et courriel" },
  data:         { en: "Custom fields & views", fr: "Champs et vues personnalisés" },
  app:          { en: "iOS & Android",         fr: "iOS et Android" },
  integrations: { en: "Connect with your tools", fr: "Connectez vos outils" },
};
const featureItems: { href: string; label: string; desc: string; iconSvg: string }[] = [
  {
    href: `${featurePrefix}/volunteer-application-forms`,
    label: t(fp.node_recruitment_title, locale),
    desc: t(featDesc.recruitment, locale),
    iconSvg: '<circle cx="9" cy="8" r="3.5"/><path d="M3 20a6 6 0 0 1 12 0"/><line x1="18.5" y1="8" x2="18.5" y2="14"/><line x1="15.5" y1="11" x2="21.5" y2="11"/>',
  },
  {
    href: `${featurePrefix}/volunteer-onboarding-software`,
    label: t(fp.node_onboarding_title, locale),
    desc: t(featDesc.onboarding, locale),
    iconSvg: '<polyline points="4 19 9 19 9 14 14 14 14 9 19 9 19 4"/><line x1="3" y1="20" x2="20" y2="20"/>',
  },
  {
    href: `${featurePrefix}/volunteer-scheduling-software`,
    label: t(fp.node_scheduling_title, locale),
    desc: t(featDesc.scheduling, locale),
    iconSvg: '<rect x="3" y="5" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="3" x2="8" y2="7"/><line x1="16" y1="3" x2="16" y2="7"/>',
  },
  {
    href: `${featurePrefix}/volunteer-hour-tracking`,
    label: t(fp.node_hours_title, locale),
    desc: t(featDesc.hours, locale),
    iconSvg: '<circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/>',
  },
  {
    href: `${featurePrefix}/volunteer-recognition`,
    label: t(fp.node_recognition_title, locale),
    desc: t(featDesc.recognition, locale),
    iconSvg: '<circle cx="12" cy="9" r="5"/><path d="M9 13l-1 8 4-2 4 2-1-8"/>',
  },
  {
    href: `${featurePrefix}/volunteer-communications`,
    label: t(fp.node_comms_title, locale),
    desc: t(featDesc.comms, locale),
    iconSvg: '<path d="M21 12c0 4-4 7-9 7-1.4 0-2.7-.2-3.9-.7L3 20l1.5-3.7C3.6 15 3 13.6 3 12c0-4 4-7 9-7s9 3 9 7z"/>',
  },
  {
    href: `${featurePrefix}/volunteer-database`,
    label: t(fp.node_data_title, locale),
    desc: t(featDesc.data, locale),
    iconSvg: '<line x1="3" y1="20" x2="21" y2="20"/><rect x="5" y="13" width="3" height="7" rx="0.5"/><rect x="10.5" y="8" width="3" height="12" rx="0.5"/><rect x="16" y="15" width="3" height="5" rx="0.5"/>',
  },
  {
    href: `${featurePrefix}/app-for-volunteers`,
    label: t(fp.node_app_title, locale),
    desc: t(featDesc.app, locale),
    iconSvg: '<rect x="7" y="3" width="10" height="18" rx="2"/><line x1="11" y1="18" x2="13" y2="18"/>',
  },
  {
    href: `${featurePrefix}/integrations`,
    label: t(fp.node_integrations_title, locale),
    desc: t(featDesc.integrations, locale),
    iconSvg: '<circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/><circle cx="12" cy="6" r="2"/><path d="M11 7.6L6.8 16M13 7.6L17.2 16M8 18h8"/>',
  },
];
const featuresAllHref = `${featurePrefix}/features`;
---

<div class="topnav">
  <details class="topnav__lang-dd">
    <summary class="topnav__lang" aria-label="Change language">
      <svg class="globe" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"></path>
      </svg>
      <span>{currentLabel}</span>
      <svg class="caret" viewBox="0 0 24 24">
        <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </summary>
    <ul class="topnav__lang-menu" role="list">
      {langOptions.map((o) => (
        <li>
          <a
            href={o.href}
            hreflang={o.code}
            lang={o.code}
            aria-current={o.code === locale ? "true" : undefined}
            class={o.code === locale ? "is-active" : undefined}
          >
            {o.label}
          </a>
        </li>
      ))}
    </ul>
  </details>
  <div class="topnav__links">
    <details class="topnav__features-dd">
      <summary class="topnav__features" aria-label={t(n.features_menu_aria, locale)}>
        <span>{t(n.features, locale)}</span>
        <svg class="caret" viewBox="0 0 24 24">
          <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </summary>
      <div class="topnav__features-menu">
        <div class="topnav__features-eyebrow">{t(fp.modules_h2, locale)}</div>
        <div class="topnav__features-grid" role="list">
          {featureItems.map((item) => (
            <a class="feat-tile" href={item.href} role="listitem">
              <span class="feat-tile__icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={item.iconSvg}
                />
              </span>
              <span class="feat-tile__text">
                <span class="feat-tile__label">{item.label}</span>
                <span class="feat-tile__desc">{item.desc}</span>
              </span>
            </a>
          ))}
        </div>
        <a class="topnav__features-menu-all" href={featuresAllHref}>
          <span>{t(n.features_view_all, locale)}</span>
          <svg class="arrow" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </details>
    <a href={locale === "fr" ? "/fr/plans" : "/plans"}>{t(n.plans, locale)}</a>
    <a href={locale === "fr" ? "/fr/about-us" : "/about-us"}>{t(n.about, locale)}</a>
    <a href={locale === "fr" ? "/fr/contact" : "/contact"}>{t(n.contact, locale)}</a>
    <a href={appUrl("/login")}>{t(n.login, locale)}</a>
  </div>
</div>

<nav class="mainnav">
  <a href={locale === "fr" ? "/fr/" : "/"} aria-label="Vome home">
    <!-- Natural logo aspect is ~2.44:1 (844x346). Preserve it: 98x40. -->
    <img class="mainnav__logo" src="/logos/full-logo-orange.png" alt="Vome" width="98" height="40" />
  </a>

  <!-- Invented mobile hamburger (the reference did not design mobile nav behavior).
       Checkbox-hack approach: the hidden .nav__toggle drives .mainnav__cta
       visibility on narrow screens via a :checked sibling selector in landing.css. -->
  <input type="checkbox" id="nav-toggle" class="nav__toggle" aria-hidden="true" />
  <label for="nav-toggle" class="nav__burger" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
  </label>

  <div class="mainnav__cta">
    <Button href={locale === "fr" ? "/fr/demo" : "/demo"} variant="ghost">{t(n.book_demo, locale)}</Button>
    <Button href={appUrl("/register")} variant="primary">{t(n.signup_free, locale)}</Button>
  </div>
</nav>
