---
/**
 * Hand-built HTML/CSS mockup of the Vome app UI used as the hero visual.
 * Decorative only — no real data. Sample volunteer names and dates stay as-is;
 * structural labels (steps, chips, date prefixes, headings) translate via t().
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const m = strings.mockup;
---

<div class="app">
  <aside class="app__side">
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><path d="M3 12l9-8 9 8v8a1 1 0 01-1 1h-5v-6H9v6H4a1 1 0 01-1-1v-8z"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 8h8M8 12h8M8 16h5"/></svg></span></div>
    <div class="app__item app__item--active"><span class="i"><svg viewBox="0 0 24 24"><path d="M6 4l12 8-12 8V4z"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3 3-5 6-5s6 2 6 5M16 11h5M18 9v4"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><circle cx="8" cy="10" r="3"/><circle cx="16" cy="10" r="3"/><path d="M2 20c0-3 2-5 6-5s6 2 6 5M14 20c0-3 2-5 4-5s4 2 4 5"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><path d="M7 4h10v3a5 5 0 01-10 0V4zM5 5H3v2a3 3 0 003 3M19 5h2v2a3 3 0 01-3 3M10 14h4M9 20h6M12 14v6"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v6c0 1.7 3.6 3 8 3s8-1.3 8-3V6M4 12v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><rect x="4" y="4" width="5" height="16" rx="1"/><rect x="11" y="9" width="5" height="11" rx="1"/><rect x="18" y="14" width="2" height="6" rx="1"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><circle cx="8" cy="10" r="3"/><circle cx="16" cy="10" r="3"/><path d="M2 20c0-3 2-5 6-5s6 2 6 5M14 20c0-3 2-5 4-5s4 2 4 5"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="12" r="2"/><path d="M8 6h4a2 2 0 012 2v2M8 18h4a2 2 0 002-2v-2"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="5" height="5" rx="1"/><rect x="10" y="3" width="5" height="5" rx="1"/><rect x="17" y="3" width="4" height="5" rx="1"/><rect x="3" y="10" width="5" height="5" rx="1"/><rect x="10" y="10" width="5" height="5" rx="1"/><rect x="17" y="10" width="4" height="5" rx="1"/><rect x="3" y="17" width="5" height="4" rx="1"/><rect x="10" y="17" width="5" height="4" rx="1"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.8"/><path d="M5 9h14M12 9v4M12 13l-3 7M12 13l3 7"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 9l2 2 4-4M8 15l2 2 4-4"/></svg></span></div>
    <div class="app__item"><span class="i"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.5 2.5 0 015 0c0 1.5-2.5 2-2.5 3.5M12 17h.01"/></svg></span></div>
  </aside>

  <div class="app__main">
    <div class="app__crumb">{t(m.crumb_sequences, locale)} / <strong>{t(m.vol_onboarding, locale)}</strong></div>
    <div class="app__heading">
      <h3>{t(m.vol_onboarding, locale)}</h3>
      <span class="add-btn">{t(m.add_volunteer, locale)}</span>
    </div>

    <div class="board">
      <div>
        <div class="col__header">
          <span class="col__step">{t(m.step_1, locale)}</span>
          <span class="col__chip chip--interview"><span class="dot"></span>{t(m.chip_interview, locale)}</span>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Céline Dion</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__ok">✓</span></div>
          <div class="card__date">{t(m.started_label, locale)} Aug 28, 2025</div>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Gary Jones</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__ok">✓</span></div>
          <div class="card__date">{t(m.started_label, locale)} Mar 25, 2026</div>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Maria Santos</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__ok">✓</span></div>
          <div class="card__date">{t(m.started_label, locale)} Apr 15, 2026</div>
        </div>
      </div>

      <div>
        <div class="col__header">
          <span class="col__step">{t(m.step_2, locale)}</span>
          <span class="col__chip chip--pdf"><span class="dot"></span>{t(m.chip_fillable_pdf, locale)}</span>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Alex Lays</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__pending"></span></div>
          <div class="card__date">{t(m.assigned_label, locale)} Mar 25, 2026</div>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Danielle Mulaney</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__pending"></span></div>
          <div class="card__date">{t(m.assigned_label, locale)} Apr 08, 2026</div>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">James Park</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__ok">✓</span></div>
          <div class="card__date">{t(m.completed_label, locale)} Apr 20, 2026</div>
        </div>
      </div>

      <div>
        <div class="col__header">
          <span class="col__step">{t(m.step_3, locale)}</span>
          <span class="col__chip chip--bg"><span class="dot"></span>{t(m.chip_background_check, locale)}</span>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Abbie Dawson</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__pending"></span></div>
          <div class="card__date">{t(m.due_label, locale)} Apr 04, 2026</div>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Aly Miller</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__pending"></span></div>
          <div class="card__date">{t(m.assigned_label, locale)} Jan 29, 2025</div>
        </div>
        <div class="card">
          <div class="card__row"><span class="card__name">Dylan Randall</span><span class="card__menu">···</span></div>
          <div class="card__status"><span class="card__pending"></span></div>
          <div class="card__date">{t(m.due_label, locale)} Apr 28, 2026</div>
        </div>
      </div>
    </div>
  </div>
</div>
