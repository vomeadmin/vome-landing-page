---
/**
 * Feature tabs — 6 tabs with bespoke HTML/CSS mocks per tab.
 * CSS-only switching: hidden <input type="radio"> drives visibility
 * via :checked sibling selectors (see landing.css #ft-N:checked rules).
 *
 * Sample data inside the mockup panels (volunteer names, dates, sample URLs)
 * is decorative and stays as-is. Marketing copy (headlines, feature
 * descriptions, tab labels, panel sub) reads from strings.ts.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const videoHref = locale === "fr" ? "/fr/video" : "/video";
---

<section class="ftabs">
  <input type="radio" name="ftabs" id="ft-0" class="ftabs__radio" checked />
  <input type="radio" name="ftabs" id="ft-1" class="ftabs__radio" />
  <input type="radio" name="ftabs" id="ft-2" class="ftabs__radio" />
  <input type="radio" name="ftabs" id="ft-3" class="ftabs__radio" />
  <input type="radio" name="ftabs" id="ft-4" class="ftabs__radio" />
  <input type="radio" name="ftabs" id="ft-5" class="ftabs__radio" />

  <div class="ftabs__intro">
    <h2 class="ftabs__h2">
      {t(strings.feature_tabs.intro_h2_part1, locale)} <span class="ftabs__h2-accent">{t(strings.feature_tabs.intro_h2_accent, locale)}</span>
    </h2>
    <p class="ftabs__sub">{t(strings.feature_tabs.intro_sub, locale)}</p>
    <a class="ftabs__videobtn" href={videoHref}>
      <span class="ftabs__videoplay"><svg viewBox="0 0 24 24" width="10" height="10" fill="currentColor"><polygon points="6,4 20,12 6,20" /></svg></span>
      {t(strings.feature_tabs.intro_video_btn, locale)}
    </a>
  </div>

  <div class="ftabs__bar">
    <label for="ft-0" class="ftabs__tab">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      {t(strings.feature_tabs.tab_recruitment, locale)}
    </label>
    <label for="ft-1" class="ftabs__tab">
      <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      {t(strings.feature_tabs.tab_onboarding, locale)}
    </label>
    <label for="ft-2" class="ftabs__tab">
      <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      {t(strings.feature_tabs.tab_scheduling, locale)}
    </label>
    <label for="ft-3" class="ftabs__tab">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      {t(strings.feature_tabs.tab_hours, locale)}
    </label>
    <label for="ft-4" class="ftabs__tab">
      <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      {t(strings.feature_tabs.tab_data, locale)}
    </label>
    <label for="ft-5" class="ftabs__tab">
      <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      {t(strings.feature_tabs.tab_comms, locale)}
    </label>
  </div>

  <div class="ftabs__panels">
    <!-- Panel 0: Recruitment -->
    <div class="ftabs__panel" data-panel="0">
      <div class="ftabs__panel-left">
        <h3 class="ftabs__headline">{t(strings.feature_tabs.rec_headline, locale)}</h3>
        <div class="ftabs__grid">
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 10h8M8 14h5"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.rec_f1_title, locale)}</strong>
              <p>{t(strings.feature_tabs.rec_f1_body, locale)}</p>
            </div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.rec_f2_title, locale)}</strong>
              <p>{t(strings.feature_tabs.rec_f2_body, locale)}</p>
            </div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.rec_f3_title, locale)}</strong>
              <p>{t(strings.feature_tabs.rec_f3_body, locale)}</p>
            </div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.rec_f4_title, locale)}</strong>
              <p>{t(strings.feature_tabs.rec_f4_body, locale)}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="ftabs__panel-right">
        <div class="ftabs__mock ftabs__mock--recruitment">
          <div class="ftmock__bar"><span></span><span></span><span></span><div class="ftmock__bartitle">{t(strings.mockup.bartitle_share_url, locale)}</div></div>
          <div class="ftmock__cover">
            <div class="ftmock__coverdot"></div>
            <div class="ftmock__coverdot ftmock__coverdot--r"></div>
            <div class="ftmock__covertext">{t(strings.mockup.cover_photo, locale)}</div>
          </div>
          <div class="ftmock__orgblock">
            <div class="ftmock__orglogo">{t(strings.mockup.side_logo_l1, locale)}<br />{t(strings.mockup.side_logo_l2, locale)}</div>
            <div class="ftmock__orginfo">
              <div class="ftmock__orgname">{t(strings.mockup.side_org, locale)}</div>
              <div class="ftmock__orgtags">
                <span class="ftmock__orgtag">{t(strings.mockup.org_tag_community, locale)}</span>
                <span class="ftmock__orgtag">{t(strings.mockup.org_tag_education, locale)}</span>
              </div>
            </div>
          </div>
          <div class="ftmock__section">
            <div class="ftmock__sectiontitle"><span>{t(strings.mockup.featured_opps, locale)}</span><span class="ftmock__count">33</span></div>
            <div class="ftmock__cards">
              <div class="ftmock__card ftmock__card--featured">
                <div class="ftmock__cardimg"></div>
                <div class="ftmock__cardbody">
                  <div class="ftmock__title">{t(strings.mockup.opp_food_bank, locale)}</div>
                  <div class="ftmock__meta"><span class="ftmock__metaico">📍</span>{t(strings.mockup.opp_food_bank_meta, locale)}</div>
                  <div class="ftmock__chips">
                    <span class="ftmock__chip">{t(strings.mockup.chip_adults, locale)}</span><span class="ftmock__chip">{t(strings.mockup.chip_groups, locale)}</span><span class="ftmock__chip">{t(strings.mockup.chip_social, locale)}</span>
                  </div>
                </div>
                <button class="ftmock__viewbtn">{t(strings.mockup.view_btn, locale)}</button>
              </div>
              <div class="ftmock__card">
                <div class="ftmock__cardimg ftmock__cardimg--alt"></div>
                <div class="ftmock__cardbody">
                  <div class="ftmock__title">{t(strings.mockup.opp_hospital, locale)}</div>
                  <div class="ftmock__meta"><span class="ftmock__metaico">📍</span>{t(strings.mockup.opp_hospital_meta, locale)}</div>
                  <div class="ftmock__chips">
                    <span class="ftmock__chip">{t(strings.mockup.chip_adults, locale)}</span><span class="ftmock__chip">{t(strings.mockup.chip_indoors, locale)}</span>
                  </div>
                </div>
                <button class="ftmock__viewbtn">{t(strings.mockup.view_btn, locale)}</button>
              </div>
            </div>
          </div>
          <div class="ftmock__share">
            <div class="ftmock__shareinput">
              <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" fill="none" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
              <span class="ftmock__shareurl">share.vomevolunteer.com/AAp8kxzat2b</span>
            </div>
            <button class="ftmock__copybtn">{t(strings.mockup.copy_link_btn, locale)}</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Panel 1: Onboarding -->
    <div class="ftabs__panel" data-panel="1">
      <div class="ftabs__panel-left">
        <h3 class="ftabs__headline">{t(strings.feature_tabs.onb_headline_l1, locale)}<br />{t(strings.feature_tabs.onb_headline_l2, locale)}</h3>
        <div class="ftabs__grid">
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.onb_f1_title, locale)}</strong>
              <p>{t(strings.feature_tabs.onb_f1_body, locale)}</p>
            </div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.onb_f2_title, locale)}</strong>
              <p>{t(strings.feature_tabs.onb_f2_body, locale)}</p>
            </div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.onb_f3_title, locale)}</strong>
              <p>{t(strings.feature_tabs.onb_f3_body, locale)}</p>
            </div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <div>
              <strong>{t(strings.feature_tabs.onb_f4_title, locale)}</strong>
              <p>{t(strings.feature_tabs.onb_f4_body, locale)}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="ftabs__panel-right">
        <div class="ftabs__mock ftabs__mock--seq">
          <div class="ftmock__bar"><span></span><span></span><span></span><div class="ftmock__bartitle">{t(strings.mockup.bartitle_sequences, locale)}</div></div>
          <div class="ftseq__head">
            <div class="ftseq__headleft">
              <div class="ftseq__seqname">{t(strings.mockup.seq_name, locale)}</div>
              <div class="ftseq__seqmeta"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg> {t(strings.mockup.seq_general, locale)}</div>
            </div>
            <div class="ftseq__stats">
              <div class="ftseq__stat"><div class="ftseq__statnum">22</div><div class="ftseq__statpill ftseq__statpill--active">{t(strings.mockup.pill_active, locale)}</div></div>
              <div class="ftseq__stat"><div class="ftseq__statnum">8</div><div class="ftseq__statpill">{t(strings.mockup.step_1, locale)}</div></div>
              <div class="ftseq__stat"><div class="ftseq__statnum ftseq__statnum--orange">14</div><div class="ftseq__statpill ftseq__statpill--mytasks">{t(strings.mockup.pill_my_tasks, locale)}</div></div>
            </div>
          </div>
          <div class="ftseq__board">
            <div class="ftseq__col">
              <div class="ftseq__colhead"><span class="ftseq__steppill">{t(strings.mockup.step_1, locale)}</span><span class="ftseq__steptype ftseq__steptype--interview"><span class="ftseq__steptype-dot"></span>{t(strings.mockup.chip_interview, locale)}</span></div>
              <div class="ftseq__coltitle">{t(strings.mockup.col_zoom_interview, locale)}</div>
              <div class="ftseq__vcard">
                <div class="ftseq__vname">Céline Dion</div>
                <div class="ftseq__vprogress"><span class="ftseq__vplay">▶</span><span class="ftseq__vstep">{t(strings.mockup.step_1, locale)}</span><span class="ftseq__vdot ftseq__vdot--done">✓</span></div>
                <div class="ftseq__vmeta">{t(strings.mockup.started_label, locale)} Aug 28, 2025</div>
              </div>
              <div class="ftseq__vcard">
                <div class="ftseq__vname">Gary Jones</div>
                <div class="ftseq__vprogress"><span class="ftseq__vplay">▶</span><span class="ftseq__vstep">{t(strings.mockup.step_1, locale)}</span><span class="ftseq__vdot ftseq__vdot--done">✓</span></div>
                <div class="ftseq__vmeta">{t(strings.mockup.started_label, locale)} Mar 25, 2026</div>
              </div>
            </div>
            <div class="ftseq__col">
              <div class="ftseq__colhead"><span class="ftseq__steppill">{t(strings.mockup.step_2, locale)}</span><span class="ftseq__steptype ftseq__steptype--pdf"><span class="ftseq__steptype-dot"></span>{t(strings.mockup.chip_fillable_pdf, locale)}</span></div>
              <div class="ftseq__coltitle">{t(strings.mockup.col_liability_waiver, locale)}</div>
              <div class="ftseq__vcard">
                <div class="ftseq__vname">Alex Lays</div>
                <div class="ftseq__vprogress"><span class="ftseq__vplay">▶</span><span class="ftseq__vstep">{t(strings.mockup.step_2, locale)}</span><span class="ftseq__vdot ftseq__vdot--waiting">◷</span></div>
                <div class="ftseq__vmeta">{t(strings.mockup.assigned_label, locale)} Mar 25, 2026</div>
              </div>
              <div class="ftseq__vcard">
                <div class="ftseq__vname">Danielle Mulaney</div>
                <div class="ftseq__vprogress"><span class="ftseq__vplay">▶</span><span class="ftseq__vstep">{t(strings.mockup.step_2, locale)}</span><span class="ftseq__vdot ftseq__vdot--waiting">◷</span></div>
                <div class="ftseq__vmeta">{t(strings.mockup.assigned_label, locale)} Apr 08, 2026</div>
              </div>
            </div>
            <div class="ftseq__col">
              <div class="ftseq__colhead"><span class="ftseq__steppill">{t(strings.mockup.step_3, locale)}</span><span class="ftseq__steptype ftseq__steptype--bg"><span class="ftseq__steptype-dot"></span>{t(strings.mockup.chip_background, locale)}</span></div>
              <div class="ftseq__coltitle">{t(strings.mockup.col_background_check, locale)}</div>
              <div class="ftseq__vcard ftseq__vcard--overdue">
                <div class="ftseq__vname">Abbie Dawson <span class="ftseq__vbell">!</span></div>
                <div class="ftseq__vprogress"><span class="ftseq__vplay">▶</span><span class="ftseq__vstep">{t(strings.mockup.step_3, locale)}</span><span class="ftseq__vdot ftseq__vdot--waiting">◷</span></div>
                <div class="ftseq__vmeta ftseq__vmeta--due">{t(strings.mockup.due_label, locale)} Apr 04, 2026</div>
              </div>
              <div class="ftseq__vcard">
                <div class="ftseq__vname">Aly Miller</div>
                <div class="ftseq__vprogress"><span class="ftseq__vplay">▶</span><span class="ftseq__vstep">{t(strings.mockup.step_3, locale)}</span><span class="ftseq__vdot ftseq__vdot--waiting">◷</span></div>
                <div class="ftseq__vmeta">{t(strings.mockup.assigned_label, locale)} Jan 29, 2025</div>
              </div>
            </div>
          </div>
          <div class="ftseq__toast">
            <div class="ftseq__toastavatar">BS</div>
            <div class="ftseq__toastbody">
              <div class="ftseq__toasttext"><strong>Barney Slottman</strong> {t(strings.mockup.toast_completed_part, locale)} {t(strings.mockup.toast_seq_name, locale)}. {t(strings.mockup.toast_status_change, locale)}</div>
              <div class="ftseq__toasttime">{t(strings.mockup.toast_time, locale)}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Panel 2: Scheduling -->
    <div class="ftabs__panel" data-panel="2">
      <div class="ftabs__panel-left">
        <h3 class="ftabs__headline">{t(strings.feature_tabs.sch_headline, locale)}</h3>
        <p class="ftabs__panel-sub">{t(strings.feature_tabs.sch_panel_sub, locale)}</p>
        <div class="ftabs__grid">
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <div><strong>{t(strings.feature_tabs.sch_f1_title, locale)}</strong><p>{t(strings.feature_tabs.sch_f1_body, locale)}</p></div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></div>
            <div><strong>{t(strings.feature_tabs.sch_f2_title, locale)}</strong><p>{t(strings.feature_tabs.sch_f2_body, locale)}</p></div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></div>
            <div><strong>{t(strings.feature_tabs.sch_f3_title, locale)}</strong><p>{t(strings.feature_tabs.sch_f3_body, locale)}</p></div>
          </div>
          <div class="ftabs__feat">
            <div class="ftabs__icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg></div>
            <div><strong>{t(strings.feature_tabs.sch_f4_title, locale)}</strong><p>{t(strings.feature_tabs.sch_f4_body, locale)}</p></div>
          </div>
        </div>
      </div>
      <div class="ftabs__panel-right">
        <div class="ftabs__mock ftabs__mock--sched">
          <div class="ftmock__bar"><span></span><span></span><span></span><div class="ftmock__bartitle">{t(strings.mockup.bartitle_schedule, locale)}</div></div>
          <div class="ftsched__toolbar">
            <button class="ftsched__createbtn">{t(strings.mockup.create_shifts, locale)}</button>
            <div class="ftsched__navgroup">
              <button class="ftsched__navbtn">{t(strings.mockup.today, locale)}</button>
              <button class="ftsched__navarrow">‹</button>
              <button class="ftsched__navarrow">›</button>
              <span class="ftsched__daterange">{t(strings.mockup.daterange, locale)}</span>
            </div>
            <div class="ftsched__viewgroup">
              <span class="ftsched__view">{t(strings.mockup.view_calendar, locale)}</span>
              <span class="ftsched__view ftsched__view--active">{t(strings.mockup.view_month, locale)}</span>
            </div>
          </div>
          <div class="ftsched__body">
            <div class="ftsched__cal">
              <div class="ftsched__caldow">{t(strings.mockup.dow_sun, locale)}</div><div class="ftsched__caldow">{t(strings.mockup.dow_mon, locale)}</div><div class="ftsched__caldow">{t(strings.mockup.dow_tue, locale)}</div><div class="ftsched__caldow">{t(strings.mockup.dow_wed, locale)}</div><div class="ftsched__caldow">{t(strings.mockup.dow_thu, locale)}</div><div class="ftsched__caldow">{t(strings.mockup.dow_fri, locale)}</div><div class="ftsched__caldow">{t(strings.mockup.dow_sat, locale)}</div>
              <div class="ftsched__day"><span class="ftsched__daynum">5</span></div>
              <div class="ftsched__day"><span class="ftsched__daynum">6</span><div class="ftsched__evt ftsched__evt--peach">{t(strings.mockup.evt_opp_a, locale)}</div><div class="ftsched__evt ftsched__evt--yellow">{t(strings.mockup.evt_pos_b, locale)}</div></div>
              <div class="ftsched__day"><span class="ftsched__daynum">7</span><div class="ftsched__evt ftsched__evt--peach">{t(strings.mockup.evt_opp_a, locale)}</div><div class="ftsched__evt ftsched__evt--pink">{t(strings.mockup.evt_job_c, locale)}</div></div>
              <div class="ftsched__day"><span class="ftsched__daynum">8</span><div class="ftsched__evt ftsched__evt--peach">{t(strings.mockup.evt_opp_a, locale)}</div><div class="ftsched__evt ftsched__evt--yellow">{t(strings.mockup.evt_pos_b, locale)}</div></div>
              <div class="ftsched__day"><span class="ftsched__daynum">9</span><div class="ftsched__evt ftsched__evt--peach">{t(strings.mockup.evt_opp_a, locale)}</div><div class="ftsched__evt ftsched__evt--pink">{t(strings.mockup.evt_job_c, locale)}</div></div>
              <div class="ftsched__day ftsched__day--today"><span class="ftsched__daynum">10</span><div class="ftsched__evt ftsched__evt--teal">{t(strings.mockup.evt_orientation, locale)}</div></div>
