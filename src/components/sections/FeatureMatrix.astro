    rows: [
      { name: p.da_profiles_n, desc: p.da_profiles_d, recruit: p.comp_basic, pro: C, ent: C, ult: C },
      { name: p.da_import_n, desc: p.da_import_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_imp_field_n, desc: p.da_imp_field_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.da_offline_n, desc: p.da_offline_d, recruit: X, pro: C, ent: C, ult: C },
