// Filter logic:
// - onlySection="all" → render every section as primary (no toggle).
// - onlySection=<key>, showAllToggle=false → render just that section.
// - onlySection=<key>, showAllToggle=true → render that section as primary
//   and the rest hidden by default; a button below the table reveals them.
const isPartialView = onlySection !== "all";
const sections =
  isPartialView && !showAllToggle
    ? allSections.filter((s) => s.key === onlySection)
    : allSections;
const useToggle = isPartialView && showAllToggle;
const headingText = t(heading ?? p.comp_h2, locale);

// The footnote refers to asterisks in the customer-success rows. It's only
// meaningful when that section is actually rendered. So we only show it
// if the success section is in the rendered list, and on toggle pages it
// inherits the same secondary visibility (hidden until expanded).
const successInSections = sections.some((s) => s.key === "success");
const footnoteIsSecondary =
  useToggle && successInSections && onlySection !== "success";
---

<section class="pp-comp">
  <div class={`pp-comp__inner${useToggle ? " pp-comp__inner--toggle" : ""}`}>
    <h2 class="pp-section-h2">{headingText}</h2>

    <div class="pp-table-wrap">
      <table class="pp-table">
        <thead>
          <tr>
            <th class="pp-table__col-feat">{t(p.comp_th_plans, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--rec">{t(p.plan_recruit, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--pro">{t(p.plan_pro, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--ent">{t(p.plan_ent, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--ult">{t(p.plan_ult, locale)}</th>
          </tr>
        </thead>
        {sections.map((sec) => (
          <tbody class={`pp-tbody${useToggle && sec.key !== onlySection ? " pp-tbody--secondary" : ""}`}>
            <tr class="pp-table__divider">
              <td colspan="5">{t(sec.title, locale)}</td>
            </tr>
            {sec.rows.map((row) => (
                <tr class="pp-table__row">
                  <td class="pp-table__feat-cell">
                    <span class="pp-table__feat-name">
                      {t(row.name, locale)}
                      {row.desc && (
                        <span class="pp-tip" tabindex="0" aria-label={t(row.desc, locale)}>
                          <svg class="pp-tip__icon" viewBox="0 0 512 512" fill="currentColor" width="15" height="15" aria-hidden="true"><path d="M256 8C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm0 110c23.196 0 42 18.804 42 42s-18.804 42-42 42-42-18.804-42-42 18.804-42 42-42zm56 254c0 6.627-5.373 12-12 12h-88c-6.627 0-12-5.373-12-12v-24c0-6.627 5.373-12 12-12h12v-64h-12c-6.627 0-12-5.373-12-12v-24c0-6.627 5.373-12 12-12h64c6.627 0 12 5.373 12 12v100h12c6.627 0 12 5.373 12 12v24z"/></svg>
                          <span class="pp-tip__bubble" role="tooltip">{t(row.desc, locale)}</span>
                        </span>
                      )}
                    </span>
                  </td>
                  <td class="pp-table__val" align="center">
                    {row.recruit === true ? (
                      <svg class="pp-icon pp-icon--rec" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-label={t(p.comp_aria_included, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm-2 14.4l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z"/></svg>
                    ) : row.recruit === false ? (
                      <svg class="pp-icon pp-icon--x" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-label={t(p.comp_aria_excluded, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm3.5 12.1l-1.4 1.4-2.1-2.1-2.1 2.1-1.4-1.4 2.1-2.1-2.1-2.1 1.4-1.4 2.1 2.1 2.1-2.1 1.4 1.4-2.1 2.1 2.1 2.1z"/></svg>
                    ) : (
                      <span class="pp-val-text">{t(row.recruit, locale)}</span>
                    )}
                  </td>
                  <td class="pp-table__val" align="center">
                    {row.pro === true ? (
                      <svg class="pp-icon pp-icon--pro" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-label={t(p.comp_aria_included, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm-2 14.4l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z"/></svg>
                    ) : row.pro === false ? (
                      <svg class="pp-icon pp-icon--x" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-label={t(p.comp_aria_excluded, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm3.5 12.1l-1.4 1.4-2.1-2.1-2.1 2.1-1.4-1.4 2.1-2.1-2.1-2.1 1.4-1.4 2.1 2.1 2.1-2.1 1.4 1.4-2.1 2.1 2.1 2.1z"/></svg>
                    ) : (
                      <span class="pp-val-text">{t(row.pro, locale)}</span>
                    )}
                  </td>
                  <td class="pp-table__val" align="center">
                    {row.ent === true ? (
                      <svg class="pp-icon pp-icon--ent" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-label={t(p.comp_aria_included, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm-2 14.4l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z"/></svg>
                    ) : row.ent === false ? (
                      <svg class="pp-icon pp-icon--x" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-label={t(p.comp_aria_excluded, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm3.5 12.1l-1.4 1.4-2.1-2.1-2.1 2.1-1.4-1.4 2.1-2.1-2.1-2.1 1.4-1.4 2.1 2.1 2.1-2.1 1.4 1.4-2.1 2.1 2.1 2.1z"/></svg>
                    ) : (
                      <span class="pp-val-text">{t(row.ent, locale)}</span>
                    )}
                  </td>
                  <td class="pp-table__val" align="center">
                    {row.ult === true ? (
                      <svg class="pp-icon pp-icon--ult" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-label={t(p.comp_aria_included, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm-2 14.4l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z"/></svg>
                    ) : row.ult === false ? (
                      <svg class="pp-icon pp-icon--x" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-label={t(p.comp_aria_excluded, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm3.5 12.1l-1.4 1.4-2.1-2.1-2.1 2.1-1.4-1.4 2.1-2.1-2.1-2.1 1.4-1.4 2.1 2.1 2.1-2.1 1.4 1.4-2.1 2.1 2.1 2.1z"/></svg>
                    ) : (
                      <span class="pp-val-text">{t(row.ult, locale)}</span>
                    )}
                  </td>
                </tr>
            ))}
          </tbody>
        ))}
      </table>
    </div>
    {useToggle && (
      <button
        type="button"
        class="pp-comp__toggle"
        data-show-label={t(p.comp_show_all, locale)}
        data-hide-label={t(p.comp_show_less, locale)}
        aria-expanded="false"
      >
        {t(p.comp_show_all, locale)}
      </button>
    )}
    {successInSections && (
      <p class={`pp-comp__footnote${footnoteIsSecondary ? " pp-comp__footnote--secondary" : ""}`}>
        {t(p.comp_footnote, locale)}
      </p>
    )}
  </div>
</section>

<style>
  /* Matrix styling — kept inside this component so the table renders the
     same on /plans and /features. Originally lived inline in PlansBody;
     moved here so the styles travel with the markup wherever the
     component is mounted. */
  .pp-comp{
    background:var(--surface-0);
    padding:72px 5%;
  }
  .pp-comp__inner{
    max-width:1200px;
    margin:0 auto;
  }
  .pp-section-h2{
    font-family:var(--font-display);
    font-size:clamp(24px, 2.5vw, 32px);
    font-weight:700;
    color:var(--fg-2);
    margin:0 0 32px;
    text-wrap:balance;
    text-align:center;
  }

  .pp-table-wrap{
    overflow-x:auto;
    border-radius:10px;
    border:1px solid #e2e0e0;
    box-shadow:0 1px 4px rgba(0,0,0,0.07);
  }
  .pp-table{
    width:100%;
    border-collapse:collapse;
    min-width:700px;
    font-size:14px;
  }
  .pp-table thead tr{
    height:72px;
    background:var(--surface-0);
  }
  .pp-table th{
    font-size:13px;
    font-weight:700;
    color:var(--fg-2);
    padding:0 16px;
    text-align:center;
    border-bottom:2px solid #f0eff4;
  }
  .pp-table__col-feat{
    text-align:left !important;
    width:38%;
    min-width:260px;
  }
  .pp-table__col-plan{
    width:15.5%;
    font-size:15px;
  }
  .pp-table__col-plan--rec{color:var(--vome-orange)}
  .pp-table__col-plan--pro{color:#4bb181}
  .pp-table__col-plan--ent{color:#4b95e9}
  .pp-table__col-plan--ult{color:#7c3aed}

  .pp-table__divider td{
    background:#fef4ea;
    padding:12px 16px;
    font-size:13px;
    font-weight:700;
    color:rgba(0,0,0,0.7);
    letter-spacing:0.03em;
    text-transform:uppercase;
    border-top:1px solid #e8e6ee;
    border-bottom:1px solid #e8e6ee;
  }
  .pp-table__row:hover td{background:#fafafa}
  .pp-table__row td{
    border-bottom:1px solid #f0eff4;
    padding:14px 16px;
    vertical-align:middle;
  }
  .pp-table__feat-cell{vertical-align:middle}
  .pp-table__feat-name{
    font-weight:600;
    color:rgba(0,0,0,0.8);
    font-size:13.5px;
    line-height:1.4;
    display:inline;
  }
  .pp-table__val{
    text-align:center !important;
    vertical-align:middle !important;
  }
  .pp-icon{display:inline-block;vertical-align:middle}
  .pp-icon--rec{color:var(--vome-orange)}
  .pp-icon--pro{color:#4bb181}
  .pp-icon--ent{color:#4b95e9}
  .pp-icon--ult{color:#7c3aed}
  .pp-icon--x{color:rgba(0,0,0,0.2)}
  .pp-val-text{
    font-size:12px;
    font-weight:600;
    color:rgba(0,0,0,0.6);
  }
  .pp-comp__footnote{
    font-size:12px;
    color:rgba(0,0,0,0.4);
    margin:10px 0 0;
    font-weight:500;
  }

  .pp-tip{
    display:inline-flex;
    align-items:center;
    margin-left:6px;
    cursor:pointer;
    position:relative;
    vertical-align:middle;
    flex-shrink:0;
  }
  .pp-tip:focus{outline:none}
  .pp-tip__icon{
    color:#000;
    opacity:0.75;
    flex-shrink:0;
    transition:opacity 0.15s;
    display:block;
  }
  .pp-tip:hover .pp-tip__icon,
  .pp-tip:focus .pp-tip__icon{opacity:1}
  .pp-tip__bubble{
    display:none;
    position:fixed;
    background:#0a0a0a;
    color:#fefefe;
    font-size:13px;
    font-weight:500;
    line-height:1.5;
    padding:10px 14px;
    border-radius:6px;
    width:280px;
    z-index:9999;
    box-shadow:0 4px 16px rgba(0,0,0,0.35);
    pointer-events:none;
    white-space:normal;
  }
  .pp-tip:hover .pp-tip__bubble,
  .pp-tip:focus-within .pp-tip__bubble{display:block}
  .pp-tip__bubble.is-visible{display:block}

  /* Phone: tighter vertical padding so the table doesn't dominate. */
  @media (max-width: 720px){
    .pp-comp{padding-top:48px;padding-bottom:48px}
  }

  /* Show-all toggle — used on per-module pages. Secondary tbodies are
     hidden until the user opts in to the full matrix. The footnote
     references the customer-success section and inherits the same
     visibility so it only shows when its referent is on screen. */
  .pp-comp__inner--toggle .pp-tbody--secondary,
  .pp-comp__inner--toggle .pp-comp__footnote--secondary{display:none}
  .pp-comp__inner--toggle.is-expanded .pp-tbody--secondary{display:table-row-group}
  .pp-comp__inner--toggle.is-expanded .pp-comp__footnote--secondary{display:block}
  .pp-comp__toggle{
    display:inline-flex;align-items:center;gap:8px;
    margin:24px auto 0;
    padding:12px 22px;
    font-family:var(--font-display);
    font-size:14px;font-weight:600;
    color:var(--vome-orange);
    background:#fff;
    border:1.5px solid rgba(250,147,91,.45);
    border-radius:10px;
    cursor:pointer;
    transition:background .15s, border-color .15s, color .15s;
  }
  .pp-comp__toggle::after{
    content:"↓";
    display:inline-block;
    transition:transform .2s;
  }
  .pp-comp__inner--toggle.is-expanded .pp-comp__toggle::after{
    transform:rotate(180deg);
  }
  .pp-comp__toggle:hover{
    background:var(--vome-peach-50);
    border-color:var(--vome-orange);
  }
  .pp-comp__inner--toggle{
    display:flex;
    flex-direction:column;
    align-items:stretch;
  }
  .pp-comp__inner--toggle .pp-comp__toggle{align-self:center}
</style>

<script>
  /* Tooltip positioning for the feature-name info icons. The bubble is
     position:fixed so it can escape the table's overflow:auto wrapper.
     We compute placement on hover/focus relative to the trigger and clamp
     to the viewport. Lives here (not on the host page) so the matrix
     works wherever it's mounted. */
  document.querySelectorAll<HTMLElement>('.pp-tip').forEach((tip) => {
    const bubble = tip.querySelector<HTMLElement>('.pp-tip__bubble');
    if (!bubble) return;

    const show = () => {
      const rect = tip.getBoundingClientRect();
      const bw = 280;

      bubble.style.visibility = 'hidden';
      bubble.style.left = '-9999px';
      bubble.classList.add('is-visible');
      const bh = bubble.offsetHeight;

      let left = rect.left + rect.width / 2 - bw / 2;
      left = Math.max(8, Math.min(left, window.innerWidth - bw - 8));

      let top = rect.bottom + 8;
      if (top + bh > window.innerHeight - 8) {
        top = rect.top - bh - 8;
      }

      bubble.style.left = `${left}px`;
      bubble.style.top = `${top}px`;
      bubble.style.visibility = '';
    };

    const hide = () => bubble.classList.remove('is-visible');

    tip.addEventListener('mouseenter', show);
    tip.addEventListener('mouseleave', hide);
    tip.addEventListener('focus', show);
    tip.addEventListener('blur', hide);
  });

  /* Show-all toggle on module pages: expand to reveal secondary tbodies. */
  document.querySelectorAll<HTMLButtonElement>('.pp-comp__toggle').forEach((btn) => {
    const wrap = btn.closest<HTMLElement>('.pp-comp__inner--toggle');
    if (!wrap) return;
    btn.addEventListener('click', () => {
      const expanded = wrap.classList.toggle('is-expanded');
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      btn.textContent = expanded
        ? btn.dataset.hideLabel ?? 'Show fewer features'
        : btn.dataset.showLabel ?? 'Show all features by plan';
    });
  });
</script>
