---
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const demoHref = locale === "fr" ? "/fr/demo" : "/demo";
---

<section class="cta">
  <div class="cta__wrap">
    <div class="cta__glow" aria-hidden="true"></div>
    <h2 class="cta__h2">{t(strings.cta.headline, locale)}</h2>
    <p class="cta__sub">{t(strings.cta.sub, locale)}</p>
    <div class="cta__actions">
      <a href="https://www.vomevolunteer.com/register" class="cta__btn cta__btn--primary">{t(strings.cta.primary, locale)}</a>
      <a href={demoHref} class="cta__btn cta__btn--ghost">{t(strings.cta.secondary, locale)}</a>
    </div>
    <div class="cta__meta">
      <span class="cta__metaitem"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>{t(strings.cta.meta_free, locale)}</span>
      <span class="cta__metaitem"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>{t(strings.cta.meta_migration, locale)}</span>
      <span class="cta__metaitem"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>{t(strings.cta.meta_onboarding, locale)}</span>
    </div>
  </div>
</section>
