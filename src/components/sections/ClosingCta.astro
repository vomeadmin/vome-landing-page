<section class="cta">
  <div class="cta__wrap">
    <div class="cta__glow" aria-hidden="true"></div>
    <h2 class="cta__h2">Ready to see it in action, or want a walk-through with our team?</h2>
    <p class="cta__sub">Sign up for free or schedule a demo to see why thousands of volunteer managers and coordinators are choosing Vome.</p>
    <div class="cta__actions">
      <a href="/register" class="cta__btn cta__btn--primary">Start for free</a>
      <a href="/demo" class="cta__btn cta__btn--ghost">Schedule a demo</a>
    </div>
    <div class="cta__meta">
      <span class="cta__metaitem"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>Start with free plan</span>
      <span class="cta__metaitem"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>Migration assistance included</span>
      <span class="cta__metaitem"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>Live onboarding support</span>
    </div>
  </div>
</section>
