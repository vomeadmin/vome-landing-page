---
/**
 * Mobile app section. Three phone mockups + callout columns.
 * Phone screens are hand-built HTML/CSS, not images. Sample names/dates inside
 * the phone screens are decorative placeholders and stay as-is.
 */
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
---

<section class="mob">
  <div class="mob__wrap">
    <div class="mob__intro">
      <h2 class="mob__h2">{t(strings.mobile_app.h2, locale)}</h2>
      <div class="mob__h2sub">{t(strings.mobile_app.h2_sub, locale)}</div>
      <p class="mob__sub">
        {t(strings.mobile_app.sub, locale)}
      </p>
      <div class="mob__badges">
        <a href="https://apps.apple.com/ca/app/vome-volunteer/id1490871417" target="_blank" rel="noopener noreferrer" class="mob__badge" aria-label={t(strings.mobile_app.badge_apple_aria, locale)}>
          <svg viewBox="0 0 160 54" width="160" height="54" aria-hidden="true">
            <rect width="160" height="54" rx="9" fill="#000" />
            <path d="M29.5 27.2c0-2.7 2.2-4 2.3-4.1-1.3-1.8-3.2-2.1-3.9-2.1-1.6-.2-3.2 1-4.1 1-.9 0-2.2-.9-3.6-.9-1.8.1-3.6 1.1-4.5 2.7-1.9 3.4-.5 8.4 1.4 11.1.9 1.3 2 2.9 3.4 2.8 1.4 0 1.9-.9 3.6-.9 1.6 0 2.1.9 3.6.9 1.5 0 2.4-1.4 3.3-2.7 1.1-1.6 1.5-3.2 1.5-3.2-.1 0-2.9-1.1-3-4.6zm-2.7-7.6c.8-.9 1.3-2.2 1.1-3.5-1.1 0-2.4.7-3.2 1.6-.7.8-1.3 2.1-1.1 3.4 1.2.1 2.4-.6 3.2-1.5z" fill="#fff" />
            <text x="45" y="22" font-family="-apple-system, Helvetica, Arial, sans-serif" font-size="9" fill="#fff">Download on the</text>
            <text x="45" y="40" font-family="-apple-system, Helvetica, Arial, sans-serif" font-size="19" font-weight="600" fill="#fff" letter-spacing="-.3">App Store</text>
          </svg>
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.vome.vomevolunteer" target="_blank" rel="noopener noreferrer" class="mob__badge" aria-label={t(strings.mobile_app.badge_google_aria, locale)}>
          <svg viewBox="0 0 180 54" width="180" height="54" aria-hidden="true">
            <rect width="180" height="54" rx="9" fill="#000" />
            <g transform="translate(18 14)">
              <path d="M.6.7C.2 1.1 0 1.8 0 2.7v22.6c0 .9.2 1.6.6 2l12-12.3L.6.7z" fill="#fff" />
              <path d="M17 17.9l-4-4L.6 26.7c.4.4 1 .5 1.8.1l14.6-8.9z" fill="#fff" />
              <path d="M17 10.1L2.4-.1C1.7-.5 1 -.4.6.1L13 12.4l4-2.3z" fill="#fff" />
              <path d="M17 10.1L13 12.4l4 4 4.4-2.6c1.3-.8 1.3-2.1 0-2.9L17 10.1z" fill="#fff" />
            </g>
            <text x="50" y="22" font-family="Roboto, Helvetica, Arial, sans-serif" font-size="9" fill="#fff" letter-spacing=".5">GET IT ON</text>
            <text x="50" y="40" font-family="Roboto, Helvetica, Arial, sans-serif" font-size="19" font-weight="500" fill="#fff" letter-spacing="-.1">Google Play</text>
          </svg>
        </a>
      </div>
    </div>

    <div class="mob__stage">
      <div class="mob__callcol mob__callcol--l">
        <div class="mob__call">
          <div class="mob__calldot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" /></svg></div>
          <div class="mob__calltxt" set:html={t(strings.mobile_app.callout_browse, locale).replace(/\n/g, "<br />")} />
        </div>
        <div class="mob__call">
          <div class="mob__calldot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M3 10h18M8 2v4M16 2v4" /></svg></div>
          <div class="mob__calltxt" set:html={t(strings.mobile_app.callout_reserve, locale).replace(/\n/g, "<br />")} />
        </div>
        <div class="mob__call">
          <div class="mob__calldot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6" /><path d="M8 13l-2 9 6-4 6 4-2-9" /></svg></div>
          <div class="mob__calltxt" set:html={t(strings.mobile_app.callout_awards, locale).replace(/\n/g, "<br />")} />
        </div>
      </div>

      <div class="mob__phones">
        <div class="mob__phone mob__phone--back mob__phone--left">
          <div class="mob__bezel">
            <div class="mob__notch"></div>
            <div class="mob__screen" style="background:#fff7ee">
              <div class="mob__statusbar"><span>9:41</span><span class="mob__statusicons"><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M2 10h3v6H2zM7 8h3v8H7zM12 6h3v10h-3zM17 4h3v12h-3z" /></svg><svg viewBox="0 0 24 12" width="16" height="10" fill="none" stroke="currentColor" stroke-width="1"><rect x=".5" y=".5" width="18" height="10" rx="2" fill="none" /><rect x="2" y="2" width="14" height="7" rx="1" fill="currentColor" /></svg></span></div>
              <div class="mob__appbar"><div class="mob__appavatar">D</div><div><div class="mob__appgreet">{t(strings.mockup.phone_greet, locale)}</div><div class="mob__appname">Daisy</div></div></div>
              <div class="mob__appcard"><div class="mob__appcardlbl">{t(strings.mockup.phone_upcoming, locale)}</div><div class="mob__appcardtitle">{t(strings.mockup.phone_meal_prep, locale)}</div><div class="mob__appcardmeta">{t(strings.mockup.phone_when, locale)}</div><div class="mob__appcardtag">{t(strings.mockup.phone_in_2_days, locale)}</div></div>
              <div class="mob__appsect">{t(strings.mockup.phone_available, locale)}</div>
              <div class="mob__applist">
                <div class="mob__applistitem"><div class="mob__applistimg" style="background:linear-gradient(135deg,#fdd9be,#fa935b)"></div><div class="mob__applistinfo"><div class="mob__applistname">{t(strings.mockup.phone_food_pantry, locale)}</div><div class="mob__applistmeta">{t(strings.mockup.phone_sat_10, locale)}</div></div></div>
                <div class="mob__applistitem"><div class="mob__applistimg" style="background:linear-gradient(135deg,#c6e3d4,#6aad8a)"></div><div class="mob__applistinfo"><div class="mob__applistname">{t(strings.mockup.phone_tutoring, locale)}</div><div class="mob__applistmeta">{t(strings.mockup.phone_tue_4, locale)}</div></div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="mob__phone mob__phone--front">
          <div class="mob__bezel">
            <div class="mob__notch"></div>
            <div class="mob__screen mob__screen--dark">
              <div class="mob__statusbar mob__statusbar--dark"><span>9:41</span><span class="mob__statusicons"><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M2 10h3v6H2zM7 8h3v8H7zM12 6h3v10h-3zM17 4h3v12h-3z" /></svg><svg viewBox="0 0 24 12" width="16" height="10" fill="none" stroke="currentColor" stroke-width="1"><rect x=".5" y=".5" width="18" height="10" rx="2" fill="none" /><rect x="2" y="2" width="14" height="7" rx="1" fill="currentColor" /></svg></span></div>
              <div class="mob__chktop"><div class="mob__chklbl">{t(strings.mockup.phone_checkin, locale)}</div><div class="mob__chkevent">{t(strings.mockup.phone_meal_shift, locale)}</div><div class="mob__chkwhen">{t(strings.mockup.phone_when, locale)}</div></div>
              <div class="mob__qr">
                <div class="mob__qrinner">
                  <svg viewBox="0 0 40 40" width="100%" height="100%">
                    <rect width="40" height="40" fill="#fff" />
                    <g fill="#1a1a2a">
                      <rect x="2" y="2" width="10" height="10" /><rect x="4" y="4" width="6" height="6" fill="#fff" /><rect x="5" y="5" width="4" height="4" />
                      <rect x="28" y="2" width="10" height="10" /><rect x="30" y="4" width="6" height="6" fill="#fff" /><rect x="31" y="5" width="4" height="4" />
                      <rect x="2" y="28" width="10" height="10" /><rect x="4" y="30" width="6" height="6" fill="#fff" /><rect x="5" y="31" width="4" height="4" />
                      <rect x="14" y="3" width="2" height="2" /><rect x="18" y="4" width="2" height="2" /><rect x="22" y="3" width="2" height="2" /><rect x="16" y="8" width="2" height="2" /><rect x="20" y="8" width="2" height="2" /><rect x="24" y="8" width="2" height="2" />
                      <rect x="3" y="14" width="2" height="2" /><rect x="7" y="14" width="2" height="2" /><rect x="14" y="14" width="2" height="2" /><rect x="18" y="14" width="2" height="2" /><rect x="22" y="14" width="2" height="2" /><rect x="28" y="14" width="2" height="2" /><rect x="32" y="14" width="2" height="2" /><rect x="36" y="14" width="2" height="2" />
                      <rect x="5" y="18" width="2" height="2" /><rect x="9" y="18" width="2" height="2" /><rect x="13" y="18" width="2" height="2" /><rect x="17" y="18" width="2" height="2" /><rect x="21" y="18" width="2" height="2" /><rect x="25" y="18" width="2" height="2" /><rect x="29" y="18" width="2" height="2" /><rect x="33" y="18" width="2" height="2" />
                      <rect x="3" y="22" width="2" height="2" /><rect x="7" y="22" width="2" height="2" /><rect x="11" y="22" width="2" height="2" /><rect x="15" y="22" width="2" height="2" /><rect x="19" y="22" width="2" height="2" /><rect x="23" y="22" width="2" height="2" /><rect x="27" y="22" width="2" height="2" /><rect x="31" y="22" width="2" height="2" /><rect x="35" y="22" width="2" height="2" />
                      <rect x="5" y="26" width="2" height="2" /><rect x="9" y="26" width="2" height="2" /><rect x="14" y="26" width="2" height="2" /><rect x="18" y="26" width="2" height="2" /><rect x="22" y="26" width="2" height="2" /><rect x="26" y="26" width="2" height="2" /><rect x="32" y="26" width="2" height="2" /><rect x="36" y="26" width="2" height="2" />
                      <rect x="14" y="30" width="2" height="2" /><rect x="18" y="30" width="2" height="2" /><rect x="22" y="30" width="2" height="2" /><rect x="26" y="30" width="2" height="2" /><rect x="30" y="30" width="2" height="2" /><rect x="34" y="30" width="2" height="2" />
                      <rect x="16" y="34" width="2" height="2" /><rect x="20" y="34" width="2" height="2" /><rect x="24" y="34" width="2" height="2" /><rect x="28" y="34" width="2" height="2" /><rect x="32" y="34" width="2" height="2" /><rect x="36" y="34" width="2" height="2" />
                    </g>
                  </svg>
                  <img class="mob__qrlogo" src="/logos/app-logo-white.png" alt="Vome" />
                </div>
              </div>
              <div class="mob__chkscan">{t(strings.mockup.phone_scan, locale)}</div>
              <div class="mob__chkbar"><div class="mob__chkhours"><span>{t(strings.mockup.phone_total_hours, locale)}</span><strong>24.5</strong></div></div>
            </div>
          </div>
        </div>

        <div class="mob__phone mob__phone--back mob__phone--right">
          <div class="mob__bezel">
            <div class="mob__notch"></div>
            <div class="mob__screen" style="background:#fff">
              <div class="mob__statusbar"><span>9:41</span><span class="mob__statusicons"><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M2 10h3v6H2zM7 8h3v8H7zM12 6h3v10h-3zM17 4h3v12h-3z" /></svg><svg viewBox="0 0 24 12" width="16" height="10" fill="none" stroke="currentColor" stroke-width="1"><rect x=".5" y=".5" width="18" height="10" rx="2" fill="none" /><rect x="2" y="2" width="14" height="7" rx="1" fill="currentColor" /></svg></span></div>
              <div class="mob__achhead">{t(strings.mockup.phone_achievements, locale)}</div>
              <div class="mob__achnext">
                <div class="mob__achbadge"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6" /><path d="M8 13l-2 9 6-4 6 4-2-9" /></svg></div>
                <div><div class="mob__achlbl">{t(strings.mockup.phone_next_badge, locale)}</div><div class="mob__achname">{t(strings.mockup.phone_bronze_vol, locale)}</div></div>
              </div>
              <div class="mob__achbar"><div class="mob__achbarfill"></div></div>
              <div class="mob__achprog">{t(strings.mockup.phone_progress, locale)}</div>
              <div class="mob__achlist">
                <div class="mob__achitem mob__achitem--on"><div class="mob__achmedal" style="background:linear-gradient(135deg,#e5a572,#b46a2f)"></div><div class="mob__achtxt"><strong>{t(strings.mockup.phone_bronze, locale)}</strong><span>{t(strings.mockup.phone_500h, locale)}</span></div></div>
                <div class="mob__achitem"><div class="mob__achmedal" style="background:linear-gradient(135deg,#e6e6e6,#a8a8a8)"></div><div class="mob__achtxt"><strong>{t(strings.mockup.phone_silver, locale)}</strong><span>{t(strings.mockup.phone_1000h, locale)}</span></div></div>
                <div class="mob__achitem"><div class="mob__achmedal" style="background:linear-gradient(135deg,#f5d87a,#c7a03e)"></div><div class="mob__achtxt"><strong>{t(strings.mockup.phone_gold, locale)}</strong><span>{t(strings.mockup.phone_2500h, locale)}</span></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mob__callcol mob__callcol--r">
        <div class="mob__call">
          <div class="mob__calldot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg></div>
          <div class="mob__calltxt" set:html={t(strings.mobile_app.callout_checkin, locale).replace(/\n/g, "<br />")} />
        </div>
        <div class="mob__call">
          <div class="mob__calldot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0112 0c0 7 3 9 3 9H3s3-2 3-9" /><path d="M10 21a2 2 0 004 0" /></svg></div>
          <div class="mob__calltxt" set:html={t(strings.mobile_app.callout_push, locale).replace(/\n/g, "<br />")} />
        </div>
        <div class="mob__call">
          <div class="mob__calldot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" /></svg></div>
          <div class="mob__calltxt" set:html={t(strings.mobile_app.callout_chat, locale).replace(/\n/g, "<br />")} />
        </div>
      </div>
    </div>
  </div>
</section>
