---
import Button from "../Button.astro";
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const demoHref = locale === "fr" ? "/fr/demo" : "/demo";
const plansHref = locale === "fr" ? "/fr/plans" : "/plans";
---

<section class="ent">
  <div class="ent__intro">
    <h2 class="ent__h2">{t(strings.enterprise.h2, locale)}</h2>
    <p class="ent__sub">{t(strings.enterprise.sub, locale)}</p>
  </div>

  <div class="ent__grid">
    <article class="ent__card">
      <div class="ent__visual ent__visual--struct">
        <div class="ent__node ent__node--root"><span class="ent__nodedot"></span>{t(strings.enterprise.node_org, locale)}</div>
        <div class="ent__branch">
          <div class="ent__node"><span class="ent__nodedot ent__nodedot--blue"></span>{t(strings.enterprise.node_downtown, locale)}<span class="ent__nodetag">284 {t(strings.enterprise.node_volunteers_count, locale)}</span></div>
          <div class="ent__node"><span class="ent__nodedot ent__nodedot--green"></span>{t(strings.enterprise.node_east, locale)}<span class="ent__nodetag">156 {t(strings.enterprise.node_volunteers_count, locale)}</span></div>
          <div class="ent__node ent__node--active"><span class="ent__nodedot ent__nodedot--orange"></span>{t(strings.enterprise.node_youth, locale)}<span class="ent__nodetag">92 {t(strings.enterprise.node_volunteers_count, locale)}</span></div>
        </div>
      </div>
      <h3 class="ent__cardtitle">{t(strings.enterprise.card_struct_title, locale)}</h3>
      <p class="ent__cardbody">{t(strings.enterprise.card_struct_body, locale)}</p>
    </article>

    <article class="ent__card">
      <div class="ent__visual ent__visual--roles">
        <div class="ent__role">
          <div class="ent__roleav" style="background:#f7c7a8;color:#8a3f0f">KR</div>
          <div class="ent__roleinfo"><div class="ent__rolename">Kendra Rivera</div><div class="ent__rolelabel">{t(strings.enterprise.role_full_access, locale)}</div></div>
          <div class="ent__rolebadge ent__rolebadge--full">●●●●</div>
        </div>
        <div class="ent__role">
          <div class="ent__roleav" style="background:#c6d9f2;color:#1a4580">JT</div>
          <div class="ent__roleinfo"><div class="ent__rolename">Jordan Tan</div><div class="ent__rolelabel">{t(strings.enterprise.role_site_manager, locale)}</div></div>
          <div class="ent__rolebadge ent__rolebadge--mid">●●●○</div>
        </div>
        <div class="ent__role">
          <div class="ent__roleav" style="background:#d3eddf;color:#0a5f32">MP</div>
          <div class="ent__roleinfo"><div class="ent__rolename">Maya Patel</div><div class="ent__rolelabel">{t(strings.enterprise.role_scheduler, locale)}</div></div>
          <div class="ent__rolebadge ent__rolebadge--low">●●○○</div>
        </div>
        <div class="ent__role ent__role--ghost">
          <div class="ent__roleav" style="background:#efe2f9;color:#5a2d8f">+</div>
          <div class="ent__roleinfo"><div class="ent__rolename">{t(strings.enterprise.role_invite, locale)}</div><div class="ent__rolelabel">{t(strings.enterprise.role_custom, locale)}</div></div>
        </div>
      </div>
      <h3 class="ent__cardtitle">{t(strings.enterprise.card_roles_title, locale)}</h3>
      <p class="ent__cardbody">{t(strings.enterprise.card_roles_body, locale)}</p>
    </article>

    <article class="ent__card">
      <div class="ent__visual ent__visual--int">
        <div class="ent__inthub" aria-label="Vome">
          <img src="/logos/app-logo-white.png" alt="Vome" />
        </div>
        <div class="ent__intgrid">
          <div class="ent__int" title="Salesforce"><img src="/integrations/salesforce.png" alt="Salesforce" /></div>
          <div class="ent__int" title="Zapier"><img src="/integrations/zapier.png" alt="Zapier" class="ent__int--wide" /></div>
          <div class="ent__int" title="Microsoft Power Automate"><img src="/integrations/microsoft.png" alt="Microsoft" /></div>
          <div class="ent__int" title="Sterling Volunteers"><img src="/integrations/sterling.jpeg" alt="Sterling Volunteers" /></div>
          <div class="ent__int" title="Outlook"><img src="/integrations/outlook.svg" alt="Outlook" /></div>
          <div class="ent__int" title="Gmail"><img src="/integrations/gmail.webp" alt="Gmail" /></div>
          <div class="ent__int" title="Double the Donation"><img src="/integrations/dtd.png" alt="Double the Donation" /></div>
          <div class="ent__int ent__int--more" title="And more"><span>{t(strings.enterprise.int_more, locale)}</span></div>
        </div>
      </div>
      <h3 class="ent__cardtitle">{t(strings.enterprise.card_int_title, locale)}</h3>
      <p class="ent__cardbody">{t(strings.enterprise.card_int_body, locale)}</p>
    </article>
  </div>

  <div class="ent__ctas">
    <Button href={demoHref} variant="primary">{t(strings.enterprise.cta_demo, locale)}</Button>
    <Button href={plansHref} variant="ghost">{t(strings.enterprise.cta_pricing, locale)}</Button>
  </div>
</section>
