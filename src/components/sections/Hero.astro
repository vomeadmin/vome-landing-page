---
import Button from "../Button.astro";
import HeroMockup from "./HeroMockup.astro";
---

<section class="hero">
  <div class="hero__grid">
    <div class="hero__copy">
      <div class="hero__eyebrow">4.6 ★ on Capterra, GetApp &amp; G2</div>

      <h1 class="hero__h1">
        The volunteer management software your <span class="accent">volunteers and staff</span> actually want to use
      </h1>

      <p class="hero__sub">
        From a single coordinator to teams running programs across multiple sites, <strong>Vome automates the manual work</strong> behind onboarding, scheduling, and communication. All in one platform, with unlimited volunteers on every plan.
      </p>

      <div class="hero__ctas">
        <Button href="/register" variant="primary" class="btn--hero">Sign up for Free</Button>
        <Button href="/demo" variant="ghost" class="btn--hero">Book a demo</Button>
      </div>

      <div class="hero__meta">
        <span><span class="check">✓</span>Free plan + 30-day trials on paid</span>
        <span><span class="check">✓</span>Set up in minutes</span>
        <span><span class="check">✓</span>HIPAA, GDPR &amp; SOC 2</span>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__fly hero__fly--volunteer">
        <span class="avatar">DR</span>
        <div>
          <strong>Dylan Randall</strong>
          <span class="hours">Hours Logged: 1h 00</span>
          <div class="party">Party size: <span class="party__count">3 people</span></div>
        </div>
      </div>

      <div class="hero__fly hero__fly--msg">
        <span class="msg-ic"></span>
        <div><strong>New message</strong><small>Céline: See you Saturday!</small></div>
      </div>

      <HeroMockup />
    </div>
  </div>
</section>
