---
import { strings, t, switchLocaleHref, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const year = new Date().getFullYear();
const enHref = switchLocaleHref(Astro.url.pathname, "en");
const frHref = switchLocaleHref(Astro.url.pathname, "fr");

const f = strings.footer;
const prefix = locale === "fr" ? "/fr" : "";

const featureLinks = [
  { href: `${prefix}/features`, label: t(f.feat_overview, locale) },
  { href: `${prefix}/volunteer-application-forms`, label: t(f.feat_apps, locale) },
  { href: `${prefix}/volunteer-onboarding-software`, label: t(f.feat_onboarding, locale) },
  { href: `${prefix}/volunteer-scheduling-software`, label: t(f.feat_scheduling, locale) },
  { href: `${prefix}/volunteer-hour-tracking`, label: t(f.feat_hours, locale) },
  { href: `${prefix}/volunteer-database`, label: t(f.feat_database, locale) },
  { href: `${prefix}/volunteer-communications`, label: t(f.feat_comms, locale) },
  { href: `${prefix}/app-for-volunteers`, label: t(f.feat_app, locale) },
];

const softwareLinks = [
  { href: locale === "fr" ? "/fr/" : "/", label: t(f.sw_home, locale) },
  { href: `${prefix}/plans`, label: t(f.sw_plans, locale) },
  { href: "https://www.vomevolunteer.com/register", label: t(f.sw_signup_org, locale) },
  { href: "https://www.vomevolunteer.com/register-volunteer", label: t(f.sw_signup_vol, locale) },
  { href: "https://www.vomevolunteer.com/login", label: t(f.sw_login, locale) },
];

interface FooterLink { href: string; label: string; external?: boolean; }

const aboutLinks: FooterLink[] = [
  { href: `${prefix}/about-us`, label: t(f.about_story, locale) },
  { href: `${prefix}/video`, label: t(f.about_video, locale) },
  { href: `${prefix}/demo`, label: t(f.about_demo, locale) },
  { href: `${prefix}/contact`, label: t(f.about_contact, locale) },
  { href: `${prefix}/affiliates`, label: t(f.about_affiliate, locale) },
];

const resourceLinks: FooterLink[] = [
  { href: `${prefix}/blog`, label: t(f.res_blog, locale) },
  { href: `${prefix}/privacy`, label: t(f.res_privacy, locale) },
  { href: `${prefix}/terms`, label: t(f.res_terms, locale) },
  { href: `${prefix}/cookie`, label: t(f.res_cookie, locale) },
  { href: `${prefix}/glossary`, label: t(f.res_glossary, locale) },
  {
    href: locale === "fr"
      ? "https://support.vomevolunteer.com/portal/fr/home"
      : "https://support.vomevolunteer.com/portal/en/home",
    label: t(f.res_support, locale),
    external: true,
  },
];
---

<footer class="site-footer">
  <div class="site-footer__top">
    <div class="site-footer__brand">
      <a href={locale === "fr" ? "/fr/" : "/"} aria-label={t(strings.nav.vome_home, locale)}>
        <img class="site-footer__logo" src="/logos/full-logo-orange.png" alt="Vome" width="88" height="36" />
      </a>
      <p class="site-footer__tagline">{t(f.tagline, locale)}</p>

      <div class="site-footer__badges">
        <a
          class="site-footer__badge"
          href="https://apps.apple.com/ca/app/vome-volunteer/id1490871417"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t(f.badge_apple_aria, locale)}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M17.05 12.04c-.03-2.98 2.43-4.41 2.54-4.48-1.38-2.02-3.54-2.3-4.31-2.33-1.84-.19-3.58 1.08-4.51 1.08-.94 0-2.37-1.06-3.9-1.03-2.01.03-3.86 1.17-4.9 2.95-2.09 3.62-.53 8.97 1.5 11.91 1 1.44 2.19 3.06 3.74 3 1.5-.06 2.07-.97 3.88-.97 1.81 0 2.32.97 3.91.94 1.62-.03 2.64-1.47 3.63-2.91 1.14-1.67 1.61-3.29 1.63-3.37-.04-.02-3.13-1.2-3.16-4.76zM14.1 4.47c.83-1 1.39-2.39 1.23-3.77-1.2.05-2.65.79-3.51 1.79-.77.88-1.44 2.29-1.26 3.65 1.34.1 2.71-.68 3.54-1.67z" />
          </svg>
          <span>
            <span class="site-footer__badge-sm">{t(f.badge_apple_sm, locale)}</span>
            <span class="site-footer__badge-lg">{t(f.badge_apple_lg, locale)}</span>
          </span>
        </a>
        <a
          class="site-footer__badge"
          href="https://play.google.com/store/apps/details?id=com.vome.vomevolunteer"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t(f.badge_google_aria, locale)}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M3 2.5v19l15-9.5-15-9.5z" />
          </svg>
          <span>
            <span class="site-footer__badge-sm">{t(f.badge_google_sm, locale)}</span>
            <span class="site-footer__badge-lg">{t(f.badge_google_lg, locale)}</span>
          </span>
        </a>
      </div>

      <div class="site-footer__socials">
        <a class="site-footer__social" href="https://www.facebook.com/vomevolunteer/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12a10 10 0 10-11.6 9.87v-6.98H7.9V12h2.5V9.8c0-2.47 1.47-3.84 3.72-3.84 1.08 0 2.2.19 2.2.19v2.42h-1.24c-1.22 0-1.6.76-1.6 1.54V12h2.72l-.44 2.89h-2.28v6.98A10 10 0 0022 12z" />
          </svg>
        </a>
        <a class="site-footer__social" href="https://www.instagram.com/vomevolunteer/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a class="site-footer__social" href="https://twitter.com/vomevolunteer" target="_blank" rel="noopener noreferrer" aria-label="X (formerly Twitter)">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.82-5.964 6.82H1.68l7.73-8.835L1.254 2.25h6.83l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <a class="site-footer__social" href="https://ca.linkedin.com/company/vomevolunteer" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05a3.74 3.74 0 013.37-1.85c3.61 0 4.27 2.37 4.27 5.45zM5.34 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.12 20.45H3.56V9h3.56z" />
          </svg>
        </a>
      </div>
    </div>

    <nav class="site-footer__col" aria-label={t(f.col_features, locale)}>
      <h4>{t(f.col_features, locale)}</h4>
      <ul>
        {featureLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label={t(f.col_software, locale)}>
      <h4>{t(f.col_software, locale)}</h4>
      <ul>
        {softwareLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label={t(f.col_about, locale)}>
      <h4>{t(f.col_about, locale)}</h4>
      <ul>
        {aboutLinks.map((l) => (
          <li>
            <a href={l.href}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label={t(f.col_resources, locale)}>
      <h4>{t(f.col_resources, locale)}</h4>
      <ul>
        {resourceLinks.map((l) => (
          <li>
            <a href={l.href} {...(l.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="site-footer__bottom">
    <span>© {year} Vome · {t(f.address, locale)}</span>
    <span class="site-footer__lang" aria-label={t(f.lang_label, locale)}>
      <a href={enHref} {...(locale === "en" ? { "aria-current": "page" } : {})}>EN</a>
      <span aria-hidden="true">·</span>
      <a href={frHref} {...(locale === "fr" ? { "aria-current": "page" } : {})}>FR</a>
    </span>
  </div>
</footer>
