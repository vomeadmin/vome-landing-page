---
import Layout from "../../layouts/Layout.astro";
import { strings, t, localeFromPath, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = localeFromPath(Astro.url.pathname) } = Astro.props;
const a = strings.affiliates_page;

const FORM_BASE =
  "https://forms.zohopublic.com/vomevolunteer/form/Affiliate/formperma/JjTAijzp1SinYE56TbJhNRDdsrC-DOjfunlKihXhkFo";
const formUrl = locale === "fr" ? `${FORM_BASE}?zf_lang=fr` : FORM_BASE;

const contactHref = locale === "fr" ? "/fr/contact" : "/contact";
---

<Layout
  locale={locale}
  title={t(a.page_title, locale)}
  description={t(a.page_description, locale)}
>
  <section class="aff">
    <div class="aff__inner">
      <div class="aff__header">
        <div class="aff__eyebrow">{t(a.eyebrow, locale)}</div>
        <h1 class="aff__h1">{t(a.h1, locale)}</h1>
        <p class="aff__sub">{t(a.sub, locale)}</p>
      </div>
      <div class="aff__form">
        <iframe
          src={formUrl}
          title={t(a.h1, locale)}
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="aff-fallback">
    <div class="aff-fallback__inner">
      <p class="aff-fallback__text">
        {t(a.fallback_part_1, locale)}
        <a href={contactHref} class="aff-fallback__link">{t(a.fallback_link, locale)}</a>
        {t(a.fallback_part_2, locale)}
      </p>
    </div>
  </section>
</Layout>

<style>
  .aff,
  .aff-fallback {
    padding-left: max(5%, calc((100% - 1120px) / 2));
    padding-right: max(5%, calc((100% - 1120px) / 2));
  }

  .aff {
    background: var(--surface-1);
    padding-top: 48px;
    padding-bottom: 56px;
  }

  .aff__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .aff__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .aff__eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    color: var(--vome-orange);
    background: var(--vome-peach-50);
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 16px;
  }

  .aff__h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 2.4vw, 38px);
    line-height: 1.15;
    letter-spacing: -0.4px;
    color: #000;
    margin: 0 0 12px;
  }

  .aff__sub {
    font-size: 16px;
    line-height: 1.6;
    color: var(--fg-4);
    font-weight: 500;
    margin: 0;
  }

  .aff__form {
    background: #fff;
    border: 1px solid var(--border-2);
    border-radius: 12px;
    overflow: hidden;
  }

  .aff__form iframe {
    width: 100%;
    height: 700px;
    border: 0;
    display: block;
    background: #fff;
  }

  .aff-fallback {
    background: var(--surface-1);
    border-top: 1px solid var(--border-2);
    padding-top: 28px;
    padding-bottom: 28px;
    text-align: center;
  }

  .aff-fallback__inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .aff-fallback__text {
    font-size: 14px;
    color: var(--fg-5);
    margin: 0;
    font-weight: 500;
  }

  .aff-fallback__link {
    color: var(--vome-orange);
    font-weight: 600;
    text-decoration: none;
  }

  .aff-fallback__link:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .aff {
      padding-top: 32px;
      padding-bottom: 40px;
    }
    .aff__form iframe {
      height: 900px;
    }
  }
</style>
