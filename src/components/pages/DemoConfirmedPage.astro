---
import Layout from "../../layouts/Layout.astro";
import { strings, t, localeFromPath, type Locale } from "../../i18n";
import { appUrl } from "../../lib/appUrl";

interface Props {
  locale?: Locale;
}

const { locale = localeFromPath(Astro.url.pathname) } = Astro.props;
const d = strings.demo_confirmed;
const videoHref = locale === "fr" ? "/fr/video" : "/video";
const contactHref = locale === "fr" ? "/fr/contact" : "/contact";
---

<Layout
  locale={locale}
  title={t(d.page_title, locale)}
  description={t(d.page_description, locale)}
>
  <section class="dc-hero">
    <div class="dc-hero__inner">
      <div class="dc-check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6L9 17l-5-5" />
        </svg>
      </div>
      <h1 class="dc-hero__h1">{t(d.h1, locale)}</h1>
      <p class="dc-hero__sub">{t(d.sub, locale)}</p>
    </div>
  </section>

  <section class="dc-prep">
    <div class="dc-prep__inner">
      <h2 class="dc-prep__h2">{t(d.prep_h2, locale)}</h2>
      <p class="dc-prep__sub">{t(d.prep_sub, locale)}</p>

      <div class="dc-prep__steps">
        <div class="dc-step">
          <div class="dc-step__num" aria-hidden="true">1</div>
          <div class="dc-step__body">
            <h3 class="dc-step__title">{t(d.step1_title, locale)}</h3>
            <p class="dc-step__text">{t(d.step1_text, locale)}</p>
            <a href={appUrl("/register")} class="dc-step__cta btn btn--primary">
              {t(d.step1_cta, locale)}
            </a>
          </div>
        </div>

        <div class="dc-step">
          <div class="dc-step__num" aria-hidden="true">2</div>
          <div class="dc-step__body">
            <h3 class="dc-step__title">{t(d.step2_title, locale)}</h3>
            <p class="dc-step__text">{t(d.step2_text, locale)}</p>
            <a href={videoHref} class="dc-step__cta btn btn--ghost">
              {t(d.step2_cta, locale)}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="dc-foot">
    <div class="dc-foot__inner">
      <p class="dc-foot__text">
        {t(d.foot_part_1, locale)}
        <a href={contactHref} class="dc-foot__link">{t(d.foot_link, locale)}</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .dc-hero,
  .dc-prep,
  .dc-foot {
    padding-left: max(5%, calc((100% - 1120px) / 2));
    padding-right: max(5%, calc((100% - 1120px) / 2));
  }

  .dc-hero {
    background: var(--vome-peach-50);
    padding-top: 64px;
    padding-bottom: 64px;
    text-align: center;
  }

  .dc-hero__inner {
    max-width: 580px;
    margin: 0 auto;
  }

  .dc-check {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--vome-orange);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }

  .dc-hero__h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 2.4vw, 36px);
    line-height: 1.2;
    letter-spacing: -0.4px;
    color: var(--fg-2);
    margin: 0 0 16px;
    text-wrap: balance;
  }

  .dc-hero__sub {
    font-size: 16px;
    line-height: 1.65;
    color: var(--fg-4);
    font-weight: 500;
    margin: 0;
    text-wrap: pretty;
  }

  .dc-prep {
    background: var(--surface-0);
    padding-top: 72px;
    padding-bottom: 80px;
  }

  .dc-prep__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .dc-prep__h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 2vw, 30px);
    font-weight: 700;
    color: var(--fg-2);
    line-height: 1.2;
    letter-spacing: -0.3px;
    margin: 0 0 12px;
  }

  .dc-prep__sub {
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-4);
    margin: 0 0 48px;
    text-wrap: pretty;
  }

  .dc-prep__steps {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .dc-step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 24px;
    align-items: start;
  }

  .dc-step__num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--vome-orange);
    color: #fff;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .dc-step__title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--fg-2);
    line-height: 1.3;
    margin: 0 0 10px;
  }

  .dc-step__text {
    font-size: 15px;
    line-height: 1.65;
    color: var(--fg-4);
    margin: 0 0 18px;
    text-wrap: pretty;
  }

  .dc-step__cta {
    display: inline-flex;
  }

  .dc-foot {
    background: var(--surface-1);
    border-top: 1px solid var(--border-2);
    padding-top: 28px;
    padding-bottom: 28px;
    text-align: center;
  }

  .dc-foot__inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .dc-foot__text {
    font-size: 14px;
    color: var(--fg-5);
    margin: 0;
    font-weight: 500;
  }

  .dc-foot__link {
    color: var(--vome-orange);
    font-weight: 600;
    text-decoration: none;
  }

  .dc-foot__link:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .dc-hero {
      padding-top: 48px;
      padding-bottom: 48px;
    }

    .dc-prep {
      padding-top: 48px;
      padding-bottom: 56px;
    }

    .dc-step {
      grid-template-columns: 40px 1fr;
      gap: 16px;
    }

    .dc-step__num {
      width: 40px;
      height: 40px;
      font-size: 17px;
    }
  }
</style>
