---
import FaqItem from "../FaqItem.astro";

type PlanVal = true | false | string;
interface Row { name: string; desc: string; recruit: PlanVal; pro: PlanVal; ent: PlanVal; ult: PlanVal; }
interface Section { title: string; rows: Row[]; }

const C = true;
const X = false;

const sections: Section[] = [
  {
    title: "Fundamentals",
    rows: [
      { name: "Max number of manageable users & profiles", desc: "You can grow your volunteer base without worrying about paying more — we don't charge for volunteer records.", recruit: "Unlimited", pro: "Unlimited", ent: "Unlimited", ult: "Unlimited" },
      { name: "Max number of admin seats", desc: "You can invite an unlimited number of admins to the portal. On paid plans you're charged per seat you activate.", recruit: "Unlimited", pro: "Unlimited", ent: "Unlimited", ult: "Unlimited" },
      { name: "Access on any device (iOS & Android apps, web & mobile browser)", desc: "Our platform is accessible from any device. The Vome Volunteer mobile app on the App Store and Google Play is free to download for all users.", recruit: C, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: "Recruitment",
    rows: [
      { name: "Custom-branded recruitment page", desc: "Build a volunteer recruitment page featuring volunteer opportunities and application forms.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Feature volunteer opportunities", desc: "Build volunteer opportunities structured by activity, role, or anything you want.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Group opportunities by category", desc: "Group your opportunities by location, program, event, department, or whatever works best for you.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Access to opportunity dashboards", desc: "View everything about your opportunity from a single page — applicants, shift requests, hour claims, analytics and more.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Opportunity-specific application forms", desc: "Customize application forms for your opportunities and events, including templates to reuse across opportunities.", recruit: "Unlimited", pro: "Unlimited", ent: "Unlimited", ult: "Unlimited" },
      { name: "Customize forms for recruitment, data collection & surveys", desc: "Get access to a dynamic form-builder that allows you to collect any information you need from volunteers.", recruit: "1 form", pro: "Unlimited", ent: "Unlimited", ult: "Unlimited" },
      { name: "Custom recruitment process", desc: "Choose the volunteer recruitment workflow that works best for your organization.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Generate direct landing page links to your page, forms, opportunities, programs, events, locations, etc.", desc: "Dynamic shareable links open the mobile app if the person is already logged into the Vome Volunteer app.", recruit: C, pro: C, ent: C, ult: C },
      { name: "App & email notifications for new applicants", desc: "Choose which admin users will receive app and/or email notifications when you receive new applicants.", recruit: C, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: "Onboarding",
    rows: [
      { name: "Build onboarding sequences to manage your entire screening process", desc: "Build step-by-step onboarding processes for volunteers to complete, with optional visibility for the volunteer.", recruit: "1 sequence", pro: "Unlimited", ent: "Unlimited", ult: "Unlimited" },
      { name: "Manage interviews, orientation & training sessions for opportunities", desc: "Build a screening checklist to use across your opportunities to stay on track about who completed what.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Sterling Volunteers background check integration", desc: "Integrate background checks directly into volunteer sequences with automatic status updates and ongoing monitoring.", recruit: C, pro: C, ent: C, ult: C },
      { name: "SCORM Cloud E-Learning integration", desc: "Add SCORM-compliant e-learning courses directly into volunteer sequences with automatic progress tracking.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Manage submitted waivers", desc: "Allow volunteers to submit signed forms and waivers as part of your screening process.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Create and manage notes", desc: "Create notes on volunteer profiles and specific components of their onboarding process.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Onboarding status tracking", desc: "Easily keep track of whether volunteers completed their screening requirements and if there are any expiration dates.", recruit: C, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: "Scheduling",
    rows: [
      { name: "Generate one-time and recurring shifts", desc: "Easily add available shifts on your calendar in a few clicks, with bulk creation for recurring time slots.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Allow volunteers to self-schedule pre-determined shifts", desc: "Volunteers who are eligible for your opportunities can directly reserve their spots to available shifts.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Double the Donation corporate matching gifts integration", desc: "Unlock corporate matching gifts during volunteer registration and shift reservations.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Allow instant bookings for approved volunteers", desc: "Choose to allow approved volunteers to instantly reserve spots to shifts or require them to submit a request first.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Allow volunteers to create their own schedule", desc: "Allow approved volunteers to create shifts based on their availabilities, which automatically populate your calendar.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Create custom scheduling policies to manage check-ins, cancellations and more", desc: "Control how many reservations volunteers can create, when they can check-in, and much more.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Recurring schedule assignments", desc: "Bulk-assign volunteers to shifts, log hours, and manage cancellations directly from your schedule view.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Auto-generated shift chatrooms", desc: "Streamline communication among attendees with auto-generated shift chatrooms for each shift.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Export & print your schedule in PDF, Excel or .CSV format", desc: "Export your calendar in various formats with customizable field visibility.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Mobile app & email scheduling reminders", desc: "Automate all sorts of scheduling notifications to keep volunteers and administrators in the loop.", recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: "Hour tracking",
    rows: [
      { name: "Receive hour claims", desc: "Allow volunteers to submit hour claims for shifts they completed. Once approved, their hours are added to their profiles.", recruit: C, pro: C, ent: C, ult: C },
      { name: "QR-code attendance tracking", desc: "Print and display a QR code to allow volunteers to scan via the mobile app to check-in/out of shifts and automate hour tracking.", recruit: X, pro: C, ent: C, ult: C },
      { name: "On-site Attendance Kiosk", desc: "Customize unlimited on-site attendance kiosks to let volunteers self check-in/out from any device (tablet, computer, smartphone).", recruit: X, pro: C, ent: C, ult: C },
      { name: "Mass hour loggings", desc: "Bulk log hours for volunteers in a few clicks, keeping accurate date/time records without manual work.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Hours reports", desc: "Easily generate reservation and hours reports with integrated analytics.", recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: "Data & reports",
    rows: [
      { name: "Access volunteer profiles", desc: "View everything you need about a volunteer from a single view — contacts, opportunities, shifts, notes and more.", recruit: "Basic", pro: C, ent: C, ult: C },
      { name: "Import volunteer profiles", desc: "Add up to 10,000 volunteer contacts from Excel per import with batch assignment of tags, opportunities, and shifts.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Import custom field data", desc: "Import and map data into any custom field in your database via Excel or .CSV.", recruit: X, pro: X, ent: C, ult: C },
      { name: "Offline profile management", desc: "Create offline profiles for volunteers who will not claim their profile on Vome — ideal for seniors or non-digital participants.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Unlimited custom & dynamic database fields", desc: "Choose from various field types (lists, dates, attachments, links, etc.) when creating custom database fields.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Profile tags", desc: "Group volunteers in your database by anything you want — great for bulk actions like emails or shift assignments.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Advanced group management", desc: "Unlock the Groups module to associate group reservations to dedicated groups for cleaner workflows and analytics.", recruit: X, pro: X, ent: C, ult: C },
      { name: "Filtering, sorting & exporting", desc: "Use filters and sorting to get the data you need quickly, plus export everything to Excel at any time.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Google Sheets ↔ Vome Database integration", desc: "Sync your Vome database with a Google Sheet to automatically keep a backup or perform additional operations on your data.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Access instant reports", desc: "Instantly generate different types of reports about attendees, hours, volunteers, shifts and more.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Access instant analytics dashboards", desc: "Integrated analytics dashboards show you key metrics about your volunteers and activity to detail performance.", recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: "Communications",
    rows: [
      { name: "Individual & bulk emailing", desc: "Send targeted emails to specific contact lists or one-off emails to individuals directly from Vome.", recruit: "Basic", pro: C, ent: C, ult: C },
      { name: "Integrate your email domain using Google or Microsoft", desc: "Send more personalized emails on Vome from your own mailbox using our integrations with Google and Microsoft.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Private chats", desc: "Use Vome's integrated instant messaging feature to message volunteers directly from the platform.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Custom group chats", desc: "Build custom group chats with volunteers and other administrators to simplify coordination.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Auto-generated chatrooms", desc: "Choose to use auto-generated chatrooms for your opportunities or shifts with automatic participant management.", recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: "Recognition",
    rows: [
      { name: "Achievements", desc: "Give volunteers automatic achievements based on their progress — hours logged, shifts completed, and more.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Custom awards", desc: "Create custom awards and badges to recognize volunteers for milestones, contributions, or special moments.", recruit: X, pro: X, ent: C, ult: C },
    ],
  },
  {
    title: "Advanced",
    rows: [
      { name: "Custom admin roles & permissions", desc: "Restrict administrative access by assigning admin roles with custom permission sets.", recruit: X, pro: X, ent: C, ult: C },
      { name: "Two-Factor Authentication (2FA)", desc: "Protect your account with Two-Factor Authentication. Add a secure phone number and enter a code upon each login attempt.", recruit: X, pro: X, ent: C, ult: C },
      { name: "Built-in KPI & metric dashboards", desc: "Access integrated analytics dashboards and reports to gain a deeper understanding of your operation.", recruit: X, pro: "Basic", ent: "Advanced", ult: "Advanced" },
      { name: "Multi-site segmentation", desc: "Setup your portal to better manage multiple sites under a single account.", recruit: X, pro: X, ent: C, ult: C },
      { name: "Map form fields to database fields", desc: "Map any question or attachment field on a form to a database field to centralize your data.", recruit: X, pro: X, ent: C, ult: C },
      { name: "API integration & custom webhooks", desc: "Access a developer dashboard to create integrations with Vome using APIs or custom webhooks.", recruit: X, pro: X, ent: X, ult: C },
      { name: "Automations with Zapier & Power Automate", desc: "Choose from thousands of custom automations using our integrations with Zapier and Microsoft Power Automate.", recruit: X, pro: X, ent: X, ult: C },
      { name: "Native integration with Salesforce", desc: "Access an installable Vome package on Salesforce to achieve a native integration.", recruit: X, pro: X, ent: X, ult: C },
      { name: "SAML & Azure SSO for admins", desc: "Ensure you're compliant by provisioning admin users and enforcing SSO for their accounts.", recruit: X, pro: X, ent: X, ult: C },
    ],
  },
  {
    title: "Customer success",
    rows: [
      { name: "FAQ & Knowledge base", desc: "Access many articles for quick answers to frequently asked questions.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Email support", desc: "Personalized customer support with guaranteed quick response times.", recruit: "Basic", pro: "Standard", ent: "Priority", ult: "Priority" },
      { name: "Technical support", desc: "We offer base tech support when you come across a technical issue that needs to be resolved by a developer.", recruit: C, pro: C, ent: C, ult: C },
      { name: "Onboarding sessions", desc: "One-hour calls with a platform specialist to get you fully set up on Vome. Unlocked as a one-time benefit upon upgrading.", recruit: "1", pro: "1", ent: "5", ult: "Unlimited *" },
      { name: "Account review sessions", desc: "30-minute check-ins with a Vome specialist to go through new features, improvements, or any questions your team has. Unlocked as a one-time benefit upon upgrading.", recruit: X, pro: "1", ent: "4", ult: "Unlimited *" },
      { name: "Dedicated account management", desc: "Gain access to a dedicated Vome expert to help you optimize your portal and share best practices for managing volunteers at scale.", recruit: X, pro: X, ent: C, ult: C },
      { name: "New Admin & Transition Onboarding", desc: "When your team brings on a new admin or transitions coordinators, we provide a complimentary onboarding session for a smooth handoff.", recruit: X, pro: C, ent: C, ult: C },
      { name: "Tech & operational consulting", desc: "Get access to Vome's software engineers and onboarding experts to help you strategize your tech setup.", recruit: X, pro: X, ent: X, ult: C },
    ],
  },
];

const faqItems = [
  {
    question: "Do you offer a free trial for any of the premium plans?",
    answer: "Yes, we offer a 30-day free trial for all premium plans — Pro, Enterprise, and Ultimate. The free trial begins automatically as soon as you upgrade from your admin portal.",
  },
  {
    question: "Which organizations are eligible to use Vome?",
    answer: "Any organization looking to streamline community engagement for volunteers, staff, members, clients, or event attendees. We serve hospitals and healthcare networks, membership associations, grassroots organizations, multi-national NGOs, community centres, food banks and shelters, municipalities and government agencies, festivals, school districts and universities, and businesses. Vome's Enterprise plan is well-suited for multi-site entities.",
  },
  {
    question: "How many volunteers am I allowed to manage?",
    answer: "As many as you have. There is no limit to the number of volunteers you can recruit or import. Our pricing depends on the number of administrative seats you wish to use on any paid plan.",
  },
  {
    question: "Why do you charge per administrator?",
    answer: "We charge per administrative seat to help you with budgetary planning. Most organizations know how many administrators will need access to Vome, but the number of active volunteers may vary throughout the year.",
  },
  {
    question: "Can I use monthly and annual pricing at the same time for different administrators?",
    answer: "Yes. We allow organizations to purchase a combination of monthly and annual seats for maximum flexibility. For example, you can purchase annual seats for your full-time employees and monthly seats for part-time employees who do not require year-round access.",
  },
  {
    question: "What happens if we decide to cancel our plan?",
    answer: "If you no longer wish to use a premium plan, you may cancel at any time. You will be able to use your premium plan until your current billing cycle is over, and will then be downgraded to the free base plan.",
  },
  {
    question: "Do you offer any discounts?",
    answer: "Yes. When you choose the annual billing option on Vome Pro, you receive a 33% discount compared to 12 monthly payments. We also offer additional savings for organizations that require a sizeable number of admin seats, have unique organizational structures, or are looking to partner for longer terms. We do not offer general nonprofit discounts because all of our clients are nonprofits.",
  },
  {
    question: "What languages do you support?",
    answer: "Vome is a bilingual platform, available in both English and French.",
  },
  {
    question: "What if I have more questions?",
    answer: "That's what we're here for! You can contact us to share your questions, or book a demo to see the platform in action.",
  },
];
---

<!-- ─── HERO ─── -->
<section class="pp-hero">
  <div class="pp-hero__inner">
    <span class="pp-eyebrow">Plans &amp; Pricing</span>
    <h1 class="pp-hero__h1">Choosing the right plan is simple.</h1>
    <p class="pp-hero__sub">
      Get started with the free plan — no credit card required. Upgrade any time and get a
      30-day free trial on any premium plan.
    </p>
    <ul class="pp-hero__pills">
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        Flexible pricing
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        Unlimited volunteers
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        30-day free trial on premium plans
      </li>
    </ul>
  </div>
</section>

<!-- ─── BILLING TOGGLE ─── -->
<section class="pp-controls">
  <div class="pp-controls__inner">
    <div class="pp-toggle" role="group" aria-label="Currency">
      <button class="pp-toggle__btn pp-toggle__btn--active" data-currency="cad">CAD</button>
      <button class="pp-toggle__btn" data-currency="usd">USD</button>
    </div>
    <div class="pp-toggle" role="group" aria-label="Billing cycle">
      <button class="pp-toggle__btn" data-billing="monthly">Monthly</button>
      <button class="pp-toggle__btn pp-toggle__btn--active" data-billing="annual">
        Annual
        <span class="pp-save-chip">Save 33%</span>
      </button>
    </div>
  </div>
  <p class="pp-controls__note">For customized pricing on multi-year plans, <a href="/contact" class="pp-link">contact us</a> for a personalized quote.</p>
</section>

<!-- ─── PLAN CARDS ─── -->
<section class="pp-plans">
  <div class="pp-plans__grid">

    <!-- Recruit -->
    <div class="pp-card pp-card--recruit">
      <div class="pp-card__head">
        <p class="pp-card__name">Recruit</p>
        <p class="pp-card__sub">For recruiters that need to collect application forms and manage an onboarding process.</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount">0</span>
        </div>
        <p class="pp-card__billing-note">Forever free</p>
      </div>
      <a href="https://app.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--outline">Get started</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">Features include:</p>
        <ul>
          <li>Recruitment page with featured opportunities &amp; access to forms</li>
          <li>Custom application form, onboarding sequence &amp; recruitment automation workflows</li>
          <li>Manage opportunities &amp; assignments</li>
          <li>Hour tracking via user-generated hour claims</li>
          <li>35 default database fields, profile management with notes &amp; document storage (no export)</li>
          <li>Integrated communication tools (email &amp; instant messaging)</li>
        </ul>
      </div>
    </div>

    <!-- Pro -->
    <div class="pp-card pp-card--pro">
      <div class="pp-card__head">
        <p class="pp-card__name">Pro</p>
        <p class="pp-card__sub">For coordinators that need to manage scheduling, hour tracking and generate reports.</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount" data-cad-annual="30" data-cad-monthly="45" data-usd-annual="25" data-usd-monthly="35">30</span>
        </div>
        <p class="pp-card__seat-note">Per admin seat, per month</p>
        <p class="pp-card__billing-note" data-billing-label="annual">Billed annually</p>
        <p class="pp-card__billing-note" data-billing-label="monthly" hidden>Billed monthly</p>
      </div>
      <a href="https://app.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--filled">Get started</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">Everything in Recruit, plus:</p>
        <ul>
          <li>Unlimited forms &amp; sequences</li>
          <li>Shift management &amp; user reservations</li>
          <li>Streamline group reservations</li>
          <li>Advanced hour tracking via Attendance QR Code &amp; Kiosk</li>
          <li>Unlimited profile tags &amp; database export</li>
          <li>Advanced mass communication tools (email lists, group chats &amp; auto-generated shift chatrooms)</li>
          <li>Mobile app, custom &amp; automated notifications, reminders &amp; updates</li>
          <li>Canned reports &amp; analytics with advanced filtering and sorting</li>
        </ul>
      </div>
    </div>

    <!-- Enterprise — Most Popular -->
    <div class="pp-card pp-card--ent pp-card--featured">
      <div class="pp-card__badge">Most Popular</div>
      <div class="pp-card__head">
        <p class="pp-card__name">Enterprise</p>
        <p class="pp-card__sub">For management teams that need custom database fields and admin role provisioning.</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount" data-cad-annual="55" data-usd-annual="40">55</span>
        </div>
        <p class="pp-card__seat-note">Per admin seat, per month</p>
        <p class="pp-card__billing-note">Billed annually | Minimum 3 seats</p>
      </div>
      <a href="https://app.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--filled-ent">Get started</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">Everything in Pro, plus:</p>
        <ul>
          <li>Unlimited custom &amp; dynamic database fields</li>
          <li>Import custom field data</li>
          <li>Advanced group management</li>
          <li>Custom admin roles &amp; permissions</li>
          <li>Multi-site segmentation</li>
          <li>Two-Factor Authentication (2FA)</li>
          <li>Map form fields to database fields</li>
          <li>Advanced email customizations</li>
          <li>Recognition module with custom awards</li>
        </ul>
      </div>
    </div>

    <!-- Ultimate -->
    <div class="pp-card pp-card--ult">
      <div class="pp-card__head">
        <p class="pp-card__name">Ultimate</p>
        <p class="pp-card__sub">For any team that needs more security features &amp; the ability to integrate Vome with other apps.</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount" data-cad-annual="80" data-usd-annual="60">80</span>
        </div>
        <p class="pp-card__seat-note">Per admin seat, per month</p>
        <p class="pp-card__billing-note">Billed annually | Minimum 5 seats</p>
      </div>
      <a href="https://app.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--filled-ult">Get started</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">Everything in Enterprise, plus:</p>
        <ul>
          <li>API integration &amp; custom webhooks</li>
          <li>Automations with Zapier &amp; Power Automate</li>
          <li>Native integration with Salesforce</li>
          <li>SAML &amp; Azure SSO for admins</li>
          <li>Tech &amp; operational consulting</li>
        </ul>
      </div>
    </div>

  </div>
  <p class="pp-disclaimer">*Additional sales tax may apply.</p>
</section>

<!-- ─── FEATURE COMPARISON TABLE ─── -->
<section class="pp-comp">
  <div class="pp-comp__inner">
    <h2 class="pp-section-h2">Feature comparison by plan</h2>

    <div class="pp-table-wrap">
      <table class="pp-table">
        <thead>
          <tr>
            <th class="pp-table__col-feat">Plans</th>
            <th class="pp-table__col-plan pp-table__col-plan--rec">Recruit</th>
            <th class="pp-table__col-plan pp-table__col-plan--pro">Pro</th>
            <th class="pp-table__col-plan pp-table__col-plan--ent">Enterprise</th>
            <th class="pp-table__col-plan pp-table__col-plan--ult">Ultimate</th>
          </tr>
        </thead>
        <tbody>
          {sections.map((sec) => (
            <>
              <tr class="pp-table__divider">
                <td colspan="5">{sec.title}</td>
              </tr>
              {sec.rows.map((row) => (
                <tr class="pp-table__row">
                  <td class="pp-table__feat-cell">
                    <span class="pp-table__feat-name">
                      {row.name}
                      {row.desc && (
                        <span class="pp-tip" tabindex="0">
                          <svg class="pp-tip__icon" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                          <span class="pp-tip__bubble" role="tooltip">{row.desc}</span>
                        </span>
                      )}
                    </span>
                  </td>
                  <td class="pp-table__val" align="center">
                    {row.recruit === true ? (
