<script>
  /* ── Currency / billing toggles ── */
  let currency: 'cad' | 'usd' = 'cad';
  let billing: 'annual' | 'monthly' = 'annual';

  function updatePrices() {
    document.querySelectorAll<HTMLElement>('[data-show]').forEach((el) => {
      el.hidden = el.dataset.show !== currency;
    });

    document.querySelectorAll<HTMLElement>('[data-cad-annual]').forEach((el) => {
      const key = `${currency}${billing === 'annual' ? 'Annual' : 'Monthly'}` as
        'cadAnnual' | 'cadMonthly' | 'usdAnnual' | 'usdMonthly';
      const map: Record<string, string> = {
        cadAnnual: el.dataset.cadAnnual ?? '',
        cadMonthly: el.dataset.cadMonthly ?? el.dataset.cadAnnual ?? '',
        usdAnnual: el.dataset.usdAnnual ?? '',
        usdMonthly: el.dataset.usdMonthly ?? el.dataset.usdAnnual ?? '',
      };
      if (map[key]) el.textContent = map[key];
    });

    document.querySelectorAll<HTMLElement>('[data-billing-label]').forEach((el) => {
      el.hidden = el.dataset.billingLabel !== billing;
    });
  }

  function setActiveToggle(group: 'currency' | 'billing', value: string) {
    const attr = group === 'currency' ? 'data-currency' : 'data-billing';
    document.querySelectorAll<HTMLElement>(`[${attr}]`).forEach((btn) => {
      btn.classList.toggle('pp-toggle__btn--active', btn.getAttribute(attr) === value);
    });
  }

  document.querySelectorAll<HTMLElement>('[data-currency]').forEach((btn) => {
    btn.addEventListener('click', () => {
      currency = btn.dataset.currency as 'cad' | 'usd';
      setActiveToggle('currency', currency);
      updatePrices();
    });
  });

  document.querySelectorAll<HTMLElement>('[data-billing]').forEach((btn) => {
    btn.addEventListener('click', () => {
      billing = btn.dataset.billing as 'annual' | 'monthly';
      setActiveToggle('billing', billing);
      updatePrices();
    });
  });

  updatePrices();

  /* ── Equalize card head + price-block heights so all CTA buttons align ── */
  function equalizeCardSections() {
    const heads  = Array.from(document.querySelectorAll<HTMLElement>('.pp-card__head'));
    const prices = Array.from(document.querySelectorAll<HTMLElement>('.pp-card__price-block'));

    // Reset to natural heights first
    [...heads, ...prices].forEach((el) => (el.style.minHeight = ''));

    // Only equalise when cards are in a multi-column layout
    const grid = document.querySelector<HTMLElement>('.pp-plans__grid');
    if (!grid) return;
    const cols = getComputedStyle(grid).gridTemplateColumns.split(' ').length;
    if (cols < 2) return;

    const maxHead  = Math.max(...heads.map((el) => el.offsetHeight));
    const maxPrice = Math.max(...prices.map((el) => el.offsetHeight));
    heads.forEach((el)  => (el.style.minHeight  = `${maxHead}px`));
    prices.forEach((el) => (el.style.minHeight = `${maxPrice}px`));
  }

  equalizeCardSections();

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(equalizeCardSections, 60);
  });

  /* ── Info tooltips (fixed-position to escape overflow:auto containers) ── */
  document.querySelectorAll<HTMLElement>('.pp-tip').forEach((tip) => {
    const bubble = tip.querySelector<HTMLElement>('.pp-tip__bubble');
    if (!bubble) return;

    const show = () => {
      const rect = tip.getBoundingClientRect();
      bubble.classList.add('is-visible');
      // Position above the icon, centred horizontally
      const bw = 260;
      let left = rect.left + rect.width / 2 - bw / 2;
      // Keep within viewport
      left = Math.max(8, Math.min(left, window.innerWidth - bw - 8));
      bubble.style.left = `${left}px`;
      bubble.style.top = `${rect.top - bubble.offsetHeight - 10 + window.scrollY}px`;
      // Switch to below if clipped at top
      if (rect.top - bubble.offsetHeight - 10 < 0) {
        bubble.style.top = `${rect.bottom + 8 + window.scrollY}px`;
      }
    };

    const hide = () => bubble.classList.remove('is-visible');

    tip.addEventListener('mouseenter', show);
    tip.addEventListener('mouseleave', hide);
    tip.addEventListener('focus', show);
    tip.addEventListener('blur', hide);
  });
</script>
