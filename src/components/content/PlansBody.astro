  .pp-cta__btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .pp-btn-primary {
    background: #fff;
    color: var(--vome-orange);
    font-size: 15px;
    font-weight: 700;
    padding: 13px 32px;
    border-radius: 10px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .pp-btn-primary:hover { opacity: 0.9; }

  .pp-btn-ghost {
    background: transparent;
    color: #fff;
    font-size: 15px;
