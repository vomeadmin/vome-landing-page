---
import FaqItem from "../FaqItem.astro";
import { strings, t, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const p = strings.plans;
const contactHref = locale === "fr" ? "/fr/contact" : "/contact";
const demoHref = locale === "fr" ? "/fr/demo" : "/demo";

type PlanVal = true | false | { en: string; fr?: string };
interface Row { name: { en: string; fr?: string }; desc: { en: string; fr?: string }; recruit: PlanVal; pro: PlanVal; ent: PlanVal; ult: PlanVal; }
interface Section { title: { en: string; fr?: string }; rows: Row[]; }

const C = true;
const X = false;

const sections: Section[] = [
  {
    title: p.sec_fundamentals,
    rows: [
      { name: p.f_users_n, desc: p.f_users_d, recruit: p.comp_unlimited, pro: p.comp_unlimited, ent: p.comp_unlimited, ult: p.comp_unlimited },
      { name: p.f_seats_n, desc: p.f_seats_d, recruit: p.comp_unlimited, pro: p.comp_unlimited, ent: p.comp_unlimited, ult: p.comp_unlimited },
      { name: p.f_devices_n, desc: p.f_devices_d, recruit: C, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_recruitment,
    rows: [
      { name: p.rc_page_n, desc: p.rc_page_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.rc_opps_n, desc: p.rc_opps_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.rc_group_n, desc: p.rc_group_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.rc_dash_n, desc: p.rc_dash_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.rc_appforms_n, desc: p.rc_appforms_d, recruit: p.comp_unlimited, pro: p.comp_unlimited, ent: p.comp_unlimited, ult: p.comp_unlimited },
      { name: p.rc_forms_n, desc: p.rc_forms_d, recruit: p.comp_form_1, pro: p.comp_unlimited, ent: p.comp_unlimited, ult: p.comp_unlimited },
      { name: p.rc_proc_n, desc: p.rc_proc_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.rc_links_n, desc: p.rc_links_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.rc_notif_n, desc: p.rc_notif_d, recruit: C, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_onboarding,
    rows: [
      { name: p.on_seq_n, desc: p.on_seq_d, recruit: p.comp_seq_1, pro: p.comp_unlimited, ent: p.comp_unlimited, ult: p.comp_unlimited },
      { name: p.on_int_n, desc: p.on_int_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.on_bg_n, desc: p.on_bg_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.on_scorm_n, desc: p.on_scorm_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.on_waiv_n, desc: p.on_waiv_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.on_notes_n, desc: p.on_notes_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.on_status_n, desc: p.on_status_d, recruit: C, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_scheduling,
    rows: [
      { name: p.sc_shifts_n, desc: p.sc_shifts_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_self_n, desc: p.sc_self_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_dtd_n, desc: p.sc_dtd_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_inst_n, desc: p.sc_inst_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_own_n, desc: p.sc_own_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_pol_n, desc: p.sc_pol_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_assign_n, desc: p.sc_assign_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_rooms_n, desc: p.sc_rooms_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_export_n, desc: p.sc_export_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.sc_remind_n, desc: p.sc_remind_d, recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_hours,
    rows: [
      { name: p.hr_claims_n, desc: p.hr_claims_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.hr_qr_n, desc: p.hr_qr_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.hr_kiosk_n, desc: p.hr_kiosk_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.hr_mass_n, desc: p.hr_mass_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.hr_reports_n, desc: p.hr_reports_d, recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_data,
    rows: [
      { name: p.da_profiles_n, desc: p.da_profiles_d, recruit: p.comp_basic, pro: C, ent: C, ult: C },
      { name: p.da_import_n, desc: p.da_import_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_imp_field_n, desc: p.da_imp_field_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.da_offline_n, desc: p.da_offline_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_fields_n, desc: p.da_fields_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_tags_n, desc: p.da_tags_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_groups_n, desc: p.da_groups_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.da_filter_n, desc: p.da_filter_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_sheets_n, desc: p.da_sheets_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_reports_n, desc: p.da_reports_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.da_analytics_n, desc: p.da_analytics_d, recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_comms,
    rows: [
      { name: p.co_email_n, desc: p.co_email_d, recruit: p.comp_basic, pro: C, ent: C, ult: C },
      { name: p.co_dom_n, desc: p.co_dom_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.co_priv_n, desc: p.co_priv_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.co_grp_n, desc: p.co_grp_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.co_auto_n, desc: p.co_auto_d, recruit: X, pro: C, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_recognition,
    rows: [
      { name: p.re_ach_n, desc: p.re_ach_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.re_aw_n, desc: p.re_aw_d, recruit: X, pro: X, ent: C, ult: C },
    ],
  },
  {
    title: p.sec_advanced,
    rows: [
      { name: p.ad_roles_n, desc: p.ad_roles_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.ad_2fa_n, desc: p.ad_2fa_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.ad_kpi_n, desc: p.ad_kpi_d, recruit: X, pro: p.comp_basic, ent: p.comp_advanced, ult: p.comp_advanced },
      { name: p.ad_multi_n, desc: p.ad_multi_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.ad_map_n, desc: p.ad_map_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.ad_api_n, desc: p.ad_api_d, recruit: X, pro: X, ent: X, ult: C },
      { name: p.ad_zap_n, desc: p.ad_zap_d, recruit: X, pro: X, ent: X, ult: C },
      { name: p.ad_sf_n, desc: p.ad_sf_d, recruit: X, pro: X, ent: X, ult: C },
      { name: p.ad_sso_n, desc: p.ad_sso_d, recruit: X, pro: X, ent: X, ult: C },
    ],
  },
  {
    title: p.sec_success,
    rows: [
      { name: p.cs_kb_n, desc: p.cs_kb_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.cs_email_n, desc: p.cs_email_d, recruit: p.comp_basic, pro: p.comp_standard, ent: p.comp_priority, ult: p.comp_priority },
      { name: p.cs_tech_n, desc: p.cs_tech_d, recruit: C, pro: C, ent: C, ult: C },
      { name: p.cs_onb_n, desc: p.cs_onb_d, recruit: p.comp_one, pro: p.comp_one, ent: p.comp_five, ult: p.comp_unlimited_star },
      { name: p.cs_rev_n, desc: p.cs_rev_d, recruit: X, pro: p.comp_one, ent: p.comp_four, ult: p.comp_unlimited_star },
      { name: p.cs_dam_n, desc: p.cs_dam_d, recruit: X, pro: X, ent: C, ult: C },
      { name: p.cs_trans_n, desc: p.cs_trans_d, recruit: X, pro: C, ent: C, ult: C },
      { name: p.cs_consult_n, desc: p.cs_consult_d, recruit: X, pro: X, ent: X, ult: C },
    ],
  },
];

const faqItems = [
  { question: t(strings.faq.q_free_trial, locale), answer: t(strings.faq.a_free_trial, locale) },
  { question: t(strings.faq.q_eligible, locale), answer: t(strings.faq.a_eligible, locale) },
  { question: t(strings.faq.q_max_volunteers, locale), answer: t(strings.faq.a_max_volunteers, locale) },
  { question: t(strings.faq.q_per_admin, locale), answer: t(strings.faq.a_per_admin, locale) },
  { question: t(strings.faq.q_mix_billing, locale), answer: t(strings.faq.a_mix_billing, locale) },
  { question: t(strings.faq.q_cancel, locale), answer: t(strings.faq.a_cancel, locale) },
  { question: t(strings.faq.q_discounts, locale), answer: t(strings.faq.a_discounts, locale) },
  { question: t(strings.faq.q_languages, locale), answer: t(strings.faq.a_languages, locale) },
  { question: t(p.plans_q_more, locale), answer: t(p.plans_a_more, locale) },
];
---

<section class="pp-hero">
  <div class="pp-hero__inner">
    <span class="pp-eyebrow">{t(p.eyebrow, locale)}</span>
    <h1 class="pp-hero__h1">{t(p.hero_h1, locale)}</h1>
    <p class="pp-hero__sub">{t(p.hero_sub, locale)}</p>
    <ul class="pp-hero__pills">
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        {t(p.pill_flexible, locale)}
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        {t(p.pill_unlimited, locale)}
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
        {t(p.pill_trial, locale)}
      </li>
    </ul>
  </div>
</section>

<section class="pp-controls">
  <div class="pp-controls__inner">
    <div class="pp-toggle" role="group" aria-label={t(p.aria_currency, locale)}>
      <button class="pp-toggle__btn pp-toggle__btn--active" data-currency="cad">CAD</button>
      <button class="pp-toggle__btn" data-currency="usd">USD</button>
    </div>
    <div class="pp-toggle" role="group" aria-label={t(p.aria_billing, locale)}>
      <button class="pp-toggle__btn" data-billing="monthly">{t(p.monthly, locale)}</button>
      <button class="pp-toggle__btn pp-toggle__btn--active" data-billing="annual">
        {t(p.annual, locale)}
        <span class="pp-save-chip">{t(p.save_chip, locale)}</span>
      </button>
    </div>
  </div>
  <p class="pp-controls__note">{t(p.custom_pricing_part_1, locale)} <a href={contactHref} class="pp-link">{t(p.custom_pricing_link, locale)}</a> {t(p.custom_pricing_part_2, locale)}</p>
</section>

<section class="pp-plans">
  <div class="pp-plans__grid">

    <div class="pp-card pp-card--recruit">
      <div class="pp-card__head">
        <p class="pp-card__name">{t(p.plan_recruit, locale)}</p>
        <p class="pp-card__sub">{t(p.plan_recruit_sub, locale)}</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount">0</span>
        </div>
        <p class="pp-card__billing-note">{t(p.forever_free, locale)}</p>
      </div>
      <a href="https://www.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--outline">{t(p.get_started, locale)}</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">{t(p.feat_head, locale)}</p>
        <ul>
          <li>{t(p.rec_b1, locale)}</li>
          <li>{t(p.rec_b2, locale)}</li>
          <li>{t(p.rec_b3, locale)}</li>
          <li>{t(p.rec_b4, locale)}</li>
          <li>{t(p.rec_b5, locale)}</li>
          <li>{t(p.rec_b6, locale)}</li>
        </ul>
      </div>
    </div>

    <div class="pp-card pp-card--pro">
      <div class="pp-card__head">
        <p class="pp-card__name">{t(p.plan_pro, locale)}</p>
        <p class="pp-card__sub">{t(p.plan_pro_sub, locale)}</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount" data-cad-annual="30" data-cad-monthly="45" data-usd-annual="25" data-usd-monthly="35">30</span>
        </div>
        <p class="pp-card__seat-note">{t(p.seat_note, locale)}</p>
        <p class="pp-card__billing-note" data-billing-label="annual">{t(p.billed_annual, locale)}</p>
        <p class="pp-card__billing-note" data-billing-label="monthly" hidden>{t(p.billed_monthly, locale)}</p>
      </div>
      <a href="https://www.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--filled">{t(p.get_started, locale)}</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">{t(p.feat_head_pro, locale)}</p>
        <ul>
          <li>{t(p.pro_b1, locale)}</li>
          <li>{t(p.pro_b2, locale)}</li>
          <li>{t(p.pro_b3, locale)}</li>
          <li>{t(p.pro_b4, locale)}</li>
          <li>{t(p.pro_b5, locale)}</li>
          <li>{t(p.pro_b6, locale)}</li>
          <li>{t(p.pro_b7, locale)}</li>
          <li>{t(p.pro_b8, locale)}</li>
        </ul>
      </div>
    </div>

    <div class="pp-card pp-card--ent pp-card--featured">
      <div class="pp-card__badge">{t(p.most_popular, locale)}</div>
      <div class="pp-card__head">
        <p class="pp-card__name">{t(p.plan_ent, locale)}</p>
        <p class="pp-card__sub">{t(p.plan_ent_sub, locale)}</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount" data-cad-annual="55" data-usd-annual="40">55</span>
        </div>
        <p class="pp-card__seat-note">{t(p.seat_note, locale)}</p>
        <p class="pp-card__billing-note">{t(p.billed_annual_min3, locale)}</p>
      </div>
      <a href="https://www.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--filled-ent">{t(p.get_started, locale)}</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">{t(p.feat_head_ent, locale)}</p>
        <ul>
          <li>{t(p.ent_b1, locale)}</li>
          <li>{t(p.ent_b2, locale)}</li>
          <li>{t(p.ent_b3, locale)}</li>
          <li>{t(p.ent_b4, locale)}</li>
          <li>{t(p.ent_b5, locale)}</li>
          <li>{t(p.ent_b6, locale)}</li>
          <li>{t(p.ent_b7, locale)}</li>
          <li>{t(p.ent_b8, locale)}</li>
          <li>{t(p.ent_b9, locale)}</li>
        </ul>
      </div>
    </div>

    <div class="pp-card pp-card--ult">
      <div class="pp-card__head">
        <p class="pp-card__name">{t(p.plan_ult, locale)}</p>
        <p class="pp-card__sub">{t(p.plan_ult_sub, locale)}</p>
      </div>
      <div class="pp-card__price-block">
        <div class="pp-card__price">
          <span class="pp-card__currency" data-show="cad">C$</span>
          <span class="pp-card__currency" data-show="usd" hidden>$</span>
          <span class="pp-card__amount" data-cad-annual="80" data-usd-annual="60">80</span>
        </div>
        <p class="pp-card__seat-note">{t(p.seat_note, locale)}</p>
        <p class="pp-card__billing-note">{t(p.billed_annual_min5, locale)}</p>
      </div>
      <a href="https://www.vomevolunteer.com/register" class="pp-card__cta pp-card__cta--filled-ult">{t(p.get_started, locale)}</a>
      <div class="pp-card__features">
        <p class="pp-card__feat-head">{t(p.feat_head_ult, locale)}</p>
        <ul>
          <li>{t(p.ult_b1, locale)}</li>
          <li>{t(p.ult_b2, locale)}</li>
          <li>{t(p.ult_b3, locale)}</li>
          <li>{t(p.ult_b4, locale)}</li>
          <li>{t(p.ult_b5, locale)}</li>
        </ul>
      </div>
    </div>

  </div>
  <p class="pp-disclaimer">{t(p.disclaimer, locale)}</p>
</section>

<section class="pp-comp">
  <div class="pp-comp__inner">
    <h2 class="pp-section-h2">{t(p.comp_h2, locale)}</h2>

    <div class="pp-table-wrap">
      <table class="pp-table">
        <thead>
          <tr>
            <th class="pp-table__col-feat">{t(p.comp_th_plans, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--rec">{t(p.plan_recruit, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--pro">{t(p.plan_pro, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--ent">{t(p.plan_ent, locale)}</th>
            <th class="pp-table__col-plan pp-table__col-plan--ult">{t(p.plan_ult, locale)}</th>
          </tr>
        </thead>
        <tbody>
          {sections.map((sec) => (
            <>
              <tr class="pp-table__divider">
                <td colspan="5">{t(sec.title, locale)}</td>
              </tr>
              {sec.rows.map((row) => (
                <tr class="pp-table__row">
                  <td class="pp-table__feat-cell">
                    <span class="pp-table__feat-name">
                      {t(row.name, locale)}
                      {row.desc && (
                        <span class="pp-tip" tabindex="0" aria-label={t(row.desc, locale)}>
                          <svg class="pp-tip__icon" viewBox="0 0 512 512" fill="currentColor" width="15" height="15" aria-hidden="true"><path d="M256 8C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm0 110c23.196 0 42 18.804 42 42s-18.804 42-42 42-42-18.804-42-42 18.804-42 42-42zm56 254c0 6.627-5.373 12-12 12h-88c-6.627 0-12-5.373-12-12v-24c0-6.627 5.373-12 12-12h12v-64h-12c-6.627 0-12-5.373-12-12v-24c0-6.627 5.373-12 12-12h64c6.627 0 12 5.373 12 12v100h12c6.627 0 12 5.373 12 12v24z"/></svg>
                          <span class="pp-tip__bubble" role="tooltip">{t(row.desc, locale)}</span>
                        </span>
                      )}
                    </span>
                  </td>
                  <td class="pp-table__val" align="center">
                    {row.recruit === true ? (
                      <svg class="pp-icon pp-icon--rec" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-label={t(p.comp_aria_included, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm-2 14.4l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z"/></svg>
                    ) : row.recruit === false ? (
                      <svg class="pp-icon pp-icon--x" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-label={t(p.comp_aria_excluded, locale)}><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm3.5 12.1l-1.4 1.4-2.1-2.1-2.1 2.1-1.4-1.4 2.1-2.1-2.1-2.1 1.4-1.4 2.1 2.1 2.1-2.1 1.4 1.4-2.1 2.1 2.1 2.1z"/></svg>
                    ) : (
                      <span class="pp-val-text">{t(row.recruit, locale)}</span>
                    )}
                  </td>
                  <td class="pp-table__val" align="center">
                    {row.pro === true ? (
